---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase, createAuthClient } from '../lib/supabase';

const authHeaders = new Headers();
const authClient = createAuthClient(Astro.request, authHeaders);
const { data: { user: authUser } } = await authClient.auth.getUser();

let currentUser: { id: number; username: string; display_name: string } | null = null;
if (authUser) {
  const { data } = await supabase
    .from('users').select('id, username, display_name').eq('auth_id', authUser.id).single();
  currentUser = data;
}

// Spotify playlists
const { data: spRaw } = await supabase
  .from('spotify_playlists')
  .select('id, playlist_id, title, created_at, user_id, users(username, display_name)')
  .order('created_at', { ascending: false })
  .limit(30);

const spotifyItems = (spRaw ?? []).map((r: any) => ({
  id:           r.id as number,
  playlist_id:  r.playlist_id as string,
  title:        r.title as string,
  created_at:   r.created_at as string,
  user_id:      r.user_id as number,
  username:     (r.users?.username     ?? '') as string,
  display_name: (r.users?.display_name ?? '') as string,
}));

// YouTube items
const { data: ytRaw } = await supabase
  .from('youtube_items')
  .select('id, item_type, item_id, title, created_at, user_id, users(username, display_name)')
  .order('created_at', { ascending: false })
  .limit(30);

const youtubeItems = (ytRaw ?? []).map((r: any) => ({
  id:           r.id as number,
  item_type:    r.item_type as 'video' | 'playlist',
  item_id:      r.item_id as string,
  title:        r.title as string,
  created_at:   r.created_at as string,
  user_id:      r.user_id as number,
  username:     (r.users?.username     ?? '') as string,
  display_name: (r.users?.display_name ?? '') as string,
}));

function avatarBg(u: string): string {
  const gs = [
    'linear-gradient(135deg,#6366f1,#8b5cf6)',
    'linear-gradient(135deg,#1db954,#1ed760)',
    'linear-gradient(135deg,#ec4899,#8b5cf6)',
    'linear-gradient(135deg,#f97316,#ef4444)',
    'linear-gradient(135deg,#14b8a6,#06b6d4)',
    'linear-gradient(135deg,#3b82f6,#6366f1)',
  ];
  let h = 0;
  for (const c of u) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return gs[Math.abs(h) % gs.length];
}

function timeAgo(d: string) {
  const m = Math.floor((Date.now() - new Date(d).getTime()) / 60000);
  if (m < 60) return `${m}d`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}sa`;
  return `${Math.floor(h / 24)}g`;
}
---

<BaseLayout title="Müzik" activeNav="muzik">
  <main class="main-content music-page">
    <div class="feed-header">Müzik</div>

    <!-- Tab bar -->
    <div class="music-tabs">
      <button class="music-tab active" data-tab="spotify">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.622.622 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 0 1-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 0 1 .207.857zm1.223-2.722a.78.78 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.517.781.781 0 0 1 .518-.973c3.632-1.102 8.147-.568 11.234 1.328a.78.78 0 0 1 .258 1.071zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 1 1-.543-1.793c3.532-1.072 9.404-.865 13.115 1.338a.937.937 0 0 1-.955 1.612z"/></svg>
        Spotify
      </button>
      <button class="music-tab" data-tab="youtube">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
        YouTube
      </button>
    </div>

    <!-- ── SPOTIFY TAB ─────────────────────────── -->
    <div class="music-section" id="tab-spotify">

      {currentUser && (
        <div class="add-bar">
          <div class="add-bar-inner" id="sp-add-inner">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="#1db954"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.622.622 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 0 1-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 0 1 .207.857zm1.223-2.722a.78.78 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.517.781.781 0 0 1 .518-.973c3.632-1.102 8.147-.568 11.234 1.328a.78.78 0 0 1 .258 1.071zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 1 1-.543-1.793c3.532-1.072 9.404-.865 13.115 1.338a.937.937 0 0 1-.955 1.612z"/></svg>
            <input id="sp-url" class="add-input" type="text" placeholder="Spotify playlist URL yapıştır…" autocomplete="off" />
            <button id="sp-btn" class="add-submit sp-submit">Ekle</button>
          </div>
          <div id="sp-error" class="add-error" style="display:none"></div>
        </div>
      )}

      <div class="items-list" id="sp-list">
        {spotifyItems.length === 0 ? (
          <div class="empty-state">
            <svg viewBox="0 0 24 24" width="36" height="36" fill="#1db954" opacity=".4"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.622.622 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 0 1-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 0 1 .207.857zm1.223-2.722a.78.78 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.517.781.781 0 0 1 .518-.973c3.632-1.102 8.147-.568 11.234 1.328a.78.78 0 0 1 .258 1.071zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 1 1-.543-1.793c3.532-1.072 9.404-.865 13.115 1.338a.937.937 0 0 1-.955 1.612z"/></svg>
            <p>Henüz Spotify playlist eklenmedi.</p>
          </div>
        ) : spotifyItems.map(item => (
          <div class="music-card" data-id={item.id}>
            <div class="card-header">
              <a href={`/u/${item.username}`} class="card-avatar" style={`background:${avatarBg(item.username)}`}>
                {(item.display_name[0] ?? '?').toUpperCase()}
              </a>
              <div class="card-info">
                <a href={`/u/${item.username}`} class="card-user">{item.display_name}</a>
                <span class="card-title">{item.title}</span>
                <span class="card-time">{timeAgo(item.created_at)}</span>
              </div>
              <div class="card-btns">
                <button
                  class="play-btn sp-play"
                  data-embed={`https://open.spotify.com/embed/playlist/${item.playlist_id}?utm_source=generator&theme=0`}
                  data-target={`embed-${item.id}`}
                  title="Oynat"
                >
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
                  Dinle
                </button>
                {currentUser?.id === item.user_id && (
                  <button class="del-btn" data-id={item.id} data-api="/api/spotify/playlist" title="Kaldır">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                  </button>
                )}
              </div>
            </div>
            <div class="embed-wrap" id={`embed-${item.id}`} style="display:none">
              <iframe
                src=""
                data-src={`https://open.spotify.com/embed/playlist/${item.playlist_id}?utm_source=generator&theme=0`}
                width="100%"
                height="352"
                frameborder="0"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                loading="lazy"
              ></iframe>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── YOUTUBE TAB ─────────────────────────── -->
    <div class="music-section" id="tab-youtube" style="display:none">

      {currentUser && (
        <div class="add-bar">
          <div class="add-bar-inner">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="#ff0000"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
            <input id="yt-url" class="add-input" type="text" placeholder="YouTube video veya playlist URL yapıştır…" autocomplete="off" />
            <button id="yt-btn" class="add-submit yt-submit">Ekle</button>
          </div>
          <div id="yt-error" class="add-error" style="display:none"></div>
        </div>
      )}

      <div class="items-list" id="yt-list">
        {youtubeItems.length === 0 ? (
          <div class="empty-state">
            <svg viewBox="0 0 24 24" width="36" height="36" fill="#ff0000" opacity=".4"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
            <p>Henüz YouTube içeriği eklenmedi.</p>
          </div>
        ) : youtubeItems.map(item => {
          const embedSrc = item.item_type === 'playlist'
            ? `https://www.youtube.com/embed/videoseries?list=${item.item_id}&rel=0&modestbranding=1`
            : `https://www.youtube.com/embed/${item.item_id}?rel=0&modestbranding=1`;
          return (
            <div class="music-card" data-id={item.id}>
              <div class="card-header">
                <a href={`/u/${item.username}`} class="card-avatar" style={`background:${avatarBg(item.username)}`}>
                  {(item.display_name[0] ?? '?').toUpperCase()}
                </a>
                <div class="card-info">
                  <a href={`/u/${item.username}`} class="card-user">{item.display_name}</a>
                  <span class="card-title">{item.title}</span>
                  <span class="card-time">
                    {item.item_type === 'playlist' ? '▶ Playlist' : '▶ Video'} · {timeAgo(item.created_at)}
                  </span>
                </div>
                <div class="card-btns">
                  <button
                    class="play-btn yt-play"
                    data-embed={embedSrc}
                    data-target={`embed-${item.id}`}
                    title="Oynat"
                  >
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
                    İzle
                  </button>
                  {currentUser?.id === item.user_id && (
                    <button class="del-btn" data-id={item.id} data-api="/api/youtube/item" title="Kaldır">
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                  )}
                </div>
              </div>
              <div class="embed-wrap" id={`embed-${item.id}`} style="display:none">
                <iframe
                  src=""
                  data-src={embedSrc}
                  width="100%"
                  height="315"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </main>

  <aside class="right-panel">
    <div class="widget-card">
      <h3>Nasıl eklenir?</h3>
      <div class="help-list">
        <div class="help-item">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="#1db954"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.622.622 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 0 1-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 0 1 .207.857zm1.223-2.722a.78.78 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.517.781.781 0 0 1 .518-.973c3.632-1.102 8.147-.568 11.234 1.328a.78.78 0 0 1 .258 1.071zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 1 1-.543-1.793c3.532-1.072 9.404-.865 13.115 1.338a.937.937 0 0 1-.955 1.612z"/></svg>
          <span><strong>Spotify:</strong> Playlist → Paylaş → Bağlantıyı kopyala</span>
        </div>
        <div class="help-item">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="#ff0000"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
          <span><strong>YouTube:</strong> Video/Playlist URL'sini kopyala</span>
        </div>
      </div>
    </div>
  </aside>
</BaseLayout>

<style>
.music-page { padding-bottom: 40px; }

/* ── Tabs */
.music-tabs {
  display: flex;
  gap: 4px;
  padding: 4px 0 16px;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 16px;
}

.music-tab {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 8px 20px;
  border-radius: 9999px;
  border: 1.5px solid var(--color-border);
  background: transparent;
  color: var(--color-text-muted);
  font-size: 0.88rem;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  transition: all 0.15s;
}

.music-tab:hover { border-color: var(--color-text-muted); color: var(--color-text); }

.music-tab.active[data-tab="spotify"] {
  background: #1db954;
  border-color: #1db954;
  color: #fff;
}

.music-tab.active[data-tab="youtube"] {
  background: #ff0000;
  border-color: #ff0000;
  color: #fff;
}

/* ── Add bar */
.add-bar { margin-bottom: 16px; }

.add-bar-inner {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--color-card);
  border: 1.5px solid var(--color-border);
  border-radius: 12px;
  padding: 10px 14px;
}

.add-input {
  flex: 1;
  border: none;
  background: transparent;
  outline: none;
  font-size: 0.88rem;
  color: var(--color-text);
  font-family: inherit;
}
.add-input::placeholder { color: var(--color-text-muted); }

.add-submit {
  border: none;
  border-radius: 8px;
  padding: 7px 18px;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  font-family: inherit;
  transition: opacity 0.15s;
  white-space: nowrap;
  color: #fff;
}
.add-submit:disabled { opacity: 0.5; cursor: not-allowed; }
.sp-submit { background: #1db954; }
.sp-submit:hover { background: #1aa34a; }
.yt-submit { background: #ff0000; }
.yt-submit:hover { background: #cc0000; }

.add-error {
  font-size: 0.8rem;
  color: #ef4444;
  margin-top: 8px;
  padding-left: 4px;
}

/* ── Cards */
.items-list { display: flex; flex-direction: column; gap: 10px; }

.music-card {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: 14px;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
}

.card-avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.card-user {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--color-text);
  text-decoration: none;
}
.card-user:hover { text-decoration: underline; }

.card-title {
  font-size: 0.85rem;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-time {
  font-size: 0.74rem;
  color: var(--color-text-muted);
}

.card-btns {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

.play-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  border: none;
  border-radius: 9999px;
  padding: 7px 14px;
  font-size: 0.8rem;
  font-weight: 700;
  cursor: pointer;
  font-family: inherit;
  color: #fff;
  transition: opacity 0.15s, transform 0.12s;
}
.play-btn:hover { opacity: 0.85; transform: scale(1.03); }
.play-btn.open { opacity: 0.7; }
.sp-play { background: #1db954; }
.yt-play { background: #ff0000; }

.del-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  border-radius: 50%;
  color: var(--color-text-muted);
  display: flex;
  align-items: center;
  transition: all 0.15s;
}
.del-btn:hover { background: rgba(239,68,68,0.1); color: #ef4444; }

.embed-wrap { border-top: 1px solid var(--color-border); }
.embed-wrap iframe { display: block; }

/* ── Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 48px 0;
  color: var(--color-text-muted);
  font-size: 0.9rem;
}
.empty-state p { margin: 0; }

/* ── Help widget */
.help-list { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
.help-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.5;
}
.help-item svg { flex-shrink: 0; margin-top: 2px; }
.help-item strong { color: var(--color-text); }
</style>

<script>
  // ── Tab switcher ────────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.music-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      document.querySelectorAll('.music-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.music-section').forEach(s => (s as HTMLElement).style.display = 'none');
      tab.classList.add('active');
      (document.getElementById(`tab-${target}`) as HTMLElement).style.display = 'block';
    });
  });

  // ── Embed toggle (lazy-load src) ────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.play-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const wrap = document.getElementById(btn.dataset.target!);
      if (!wrap) return;
      const isOpen = wrap.style.display !== 'none';
      wrap.style.display = isOpen ? 'none' : 'block';
      btn.classList.toggle('open', !isOpen);
      btn.innerHTML = !isOpen
        ? `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg> Kapat`
        : `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg> ${btn.classList.contains('sp-play') ? 'Dinle' : 'İzle'}`;

      // iframe src'yi sadece ilk açılışta yükle
      if (!isOpen) {
        const iframe = wrap.querySelector('iframe')!;
        if (!iframe.src || iframe.src === window.location.href) {
          iframe.src = iframe.dataset.src!;
        }
      }
    });
  });

  // ── Add: Spotify ────────────────────────────────────────────────────────────
  const spUrl    = document.getElementById('sp-url')    as HTMLInputElement | null;
  const spBtn    = document.getElementById('sp-btn')    as HTMLButtonElement | null;
  const spErr    = document.getElementById('sp-error')  as HTMLElement | null;

  async function addSpotify() {
    const url = spUrl?.value.trim() ?? '';
    if (!url) return;
    if (spErr) spErr.style.display = 'none';
    if (spBtn) { spBtn.disabled = true; spBtn.textContent = '...'; }

    const res = await fetch('/api/spotify/playlist', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url }),
    });

    if (spBtn) { spBtn.disabled = false; spBtn.textContent = 'Ekle'; }
    if (res.status === 401) { window.location.href = '/login'; return; }
    if (!res.ok) {
      const d = await res.json().catch(() => ({})) as { error?: string };
      if (spErr) { spErr.textContent = d.error ?? 'Hata oluştu.'; spErr.style.display = 'block'; }
      return;
    }
    window.location.reload();
  }

  spBtn?.addEventListener('click', addSpotify);
  spUrl?.addEventListener('keydown', e => { if (e.key === 'Enter') addSpotify(); });

  // ── Add: YouTube ────────────────────────────────────────────────────────────
  const ytUrl = document.getElementById('yt-url') as HTMLInputElement | null;
  const ytBtn = document.getElementById('yt-btn') as HTMLButtonElement | null;
  const ytErr = document.getElementById('yt-error') as HTMLElement | null;

  async function addYouTube() {
    const url = ytUrl?.value.trim() ?? '';
    if (!url) return;
    if (ytErr) ytErr.style.display = 'none';
    if (ytBtn) { ytBtn.disabled = true; ytBtn.textContent = '...'; }

    const res = await fetch('/api/youtube/item', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url }),
    });

    if (ytBtn) { ytBtn.disabled = false; ytBtn.textContent = 'Ekle'; }
    if (res.status === 401) { window.location.href = '/login'; return; }
    if (!res.ok) {
      const d = await res.json().catch(() => ({})) as { error?: string };
      if (ytErr) { ytErr.textContent = d.error ?? 'Hata oluştu.'; ytErr.style.display = 'block'; }
      return;
    }
    window.location.reload();
  }

  ytBtn?.addEventListener('click', addYouTube);
  ytUrl?.addEventListener('keydown', e => { if (e.key === 'Enter') addYouTube(); });

  // ── Delete ──────────────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.del-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Bu içeriği kaldırmak istiyor musun?')) return;
      const id = Number(btn.dataset.id);
      const api = btn.dataset.api!;
      const res = await fetch(api, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      if (res.ok) btn.closest('.music-card')?.remove();
    });
  });
</script>
