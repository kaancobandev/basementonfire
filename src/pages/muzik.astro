---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase, createAuthClient } from '../lib/supabase';

const authHeaders = new Headers();
const authClient = createAuthClient(Astro.request, authHeaders);
const { data: { user: authUser } } = await authClient.auth.getUser();

let currentUser: { id: number; username: string; display_name: string } | null = null;
if (authUser) {
  const { data } = await supabase
    .from('users').select('id, username, display_name').eq('auth_id', authUser.id).single();
  currentUser = data;
}

type SpotifyPlaylist = {
  id: number;
  playlist_id: string;
  title: string;
  created_at: string;
  user_id: number;
  username: string;
  display_name: string;
};

const { data: spRaw } = await supabase
  .from('spotify_playlists')
  .select('id, playlist_id, title, created_at, user_id, users(username, display_name)')
  .order('created_at', { ascending: false })
  .limit(20);

const spotifyPlaylists: SpotifyPlaylist[] = (spRaw ?? []).map((r: any) => ({
  ...r,
  username:     r.users?.username     ?? '',
  display_name: r.users?.display_name ?? '',
}));

function avatarBg(u: string): string {
  const gs = [
    'linear-gradient(135deg,#6366f1,#8b5cf6)', 'linear-gradient(135deg,#1db954,#1ed760)',
    'linear-gradient(135deg,#ec4899,#8b5cf6)',  'linear-gradient(135deg,#f97316,#ef4444)',
    'linear-gradient(135deg,#14b8a6,#06b6d4)',  'linear-gradient(135deg,#3b82f6,#6366f1)',
  ];
  let h = 0;
  for (const c of u) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return gs[Math.abs(h) % gs.length];
}
---

<BaseLayout title="Müzik" activeNav="muzik">
  <main class="main-content yt-page">
  <div class="yt-layout">

  <!-- ── Sol sütun ── -->
  <div class="yt-left">

    <!-- ══════════════════════════════════════════
         PLAYER  (YouTube video player look)
    ══════════════════════════════════════════ -->
    <div class="yt-player-wrap">
      <!-- 16:9 video area -->
      <div class="yt-video-area">
        <img id="cover-img" class="yt-cover"
          src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 9'%3E%3Crect width='16' height='9' fill='%230f0f0f'/%3E%3C/svg%3E"
          alt="kapak" />

        <!-- Center play overlay (shows when paused) -->
        <div class="yt-center-play" id="center-play-overlay">
          <div class="yt-center-play-btn" id="center-play-btn">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="#fff"><polygon points="5 3 19 12 5 21"/></svg>
          </div>
        </div>

        <!-- Bottom gradient + controls bar -->
        <div class="yt-controls-bar">
          <!-- Progress -->
          <div class="yt-progress" id="progress-track">
            <div class="yt-progress-played" id="progress-fill"></div>
            <div class="yt-progress-dot"    id="progress-thumb"></div>
          </div>

          <div class="yt-bar-bottom">
            <div class="yt-bar-left">
              <!-- Play / Pause -->
              <button class="yt-bar-btn" id="btn-play" title="Oynat/Duraklat">
                <svg id="icon-play" viewBox="0 0 24 24" width="22" height="22" fill="#fff"><polygon points="5 3 19 12 5 21"/></svg>
                <svg id="icon-pause" viewBox="0 0 24 24" width="22" height="22" fill="#fff" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
              </button>
              <!-- Next -->
              <button class="yt-bar-btn" id="btn-next" title="Sonraki">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="#fff"><polygon points="5 4 15 12 5 20"/><rect x="19" y="4" width="2" height="16" fill="#fff"/></svg>
              </button>
              <!-- Time -->
              <div class="yt-time">
                <span id="time-current">0:00</span>
                <span> / </span>
                <span id="time-total">0:00</span>
              </div>
            </div>

            <div class="yt-bar-right">
              <!-- Volume -->
              <button class="yt-bar-btn" id="btn-mute" title="Sessiz">
                <svg id="icon-vol" viewBox="0 0 24 24" width="22" height="22" fill="#fff"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14" stroke="#fff" stroke-width="2" fill="none"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07" stroke="#fff" stroke-width="2" fill="none"/></svg>
                <svg id="icon-mute" viewBox="0 0 24 24" width="22" height="22" fill="#fff" style="display:none"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19"/><line x1="23" y1="9" x2="17" y2="15" stroke="#fff" stroke-width="2"/><line x1="17" y1="9" x2="23" y2="15" stroke="#fff" stroke-width="2"/></svg>
              </button>
              <input type="range" id="volume-slider" class="yt-vol-slider" min="0" max="100" value="80" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         VIDEO INFO  (below player like YouTube)
    ══════════════════════════════════════════ -->
    <div class="yt-info-section">
      <!-- Title -->
      <div id="song-title" class="yt-video-title">Şarkı seçilmedi</div>

      <!-- Views row -->
      <div class="yt-views-row">
        <span id="song-artist" class="yt-views-text">Çalma listesinden bir şarkı seç</span>
      </div>

      <!-- Action buttons (like YouTube's like/share/save row) -->
      <div class="yt-action-row">
        <button class="yt-action-pill" id="btn-prev" title="Önceki">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><polygon points="19 20 9 12 19 4"/><rect x="5" y="4" width="2" height="16"/></svg>
          Önceki
        </button>

        <button class="yt-action-pill yt-play-pill" id="btn-play-pill" title="Oynat">
          <svg id="pill-play" viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
          <svg id="pill-pause" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          <span id="pill-label">Oynat</span>
        </button>

        <button class="yt-action-pill" id="btn-next-pill" title="Sonraki">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><polygon points="5 4 15 12 5 20"/><rect x="19" y="4" width="2" height="16"/></svg>
          Sonraki
        </button>

        <button class="yt-action-pill" id="btn-shuffle" title="Karıştır">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"/><path d="m18 2 4 4-4 4"/><path d="M2 6h1.9c1.5 0 2.9.9 3.5 2.2"/><path d="M22 18h-5.9c-1.3 0-2.6-.7-3.3-1.7l-.5-.8"/><path d="m18 14 4 4-4 4"/></svg>
          Karıştır
        </button>

        <button class="yt-action-pill" id="btn-repeat" title="Tekrar">
          <svg id="repeat-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m17 2 4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          <span id="repeat-label">Tekrar Yok</span>
        </button>
      </div>

      <div class="yt-divider"></div>

      <!-- Channel row -->
      <div class="yt-channel-row">
        <div class="yt-ch-avatar" id="ch-avatar">B</div>
        <div class="yt-ch-info">
          <div class="yt-ch-name">Basements</div>
          <div class="yt-ch-sub">Müzik Çalar</div>
        </div>
      </div>

      <div class="yt-divider"></div>
    </div>

    <!-- ══════════════════════════════════════════
         ADD SONG
    ══════════════════════════════════════════ -->
    <div class="yt-add-section">
      <div class="yt-add-inner">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#606060" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input id="url-input" class="yt-add-input" type="text"
          placeholder="YouTube URL yapıştır (youtube.com/watch?v=...)" autocomplete="off" />
        <button id="btn-add" class="yt-add-btn">
          <span id="add-label">Ekle</span>
        </button>
      </div>
      <div id="add-error" class="yt-add-error" style="display:none;"></div>
    </div>

    <!-- ══════════════════════════════════════════
         SPOTIFY PLAYLİSTLERİ
    ══════════════════════════════════════════ -->
    <div class="sp-section">
      <div class="sp-header-row">
        <div class="sp-title-wrap">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="#1db954"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.622.622 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 0 1-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 0 1 .207.857zm1.223-2.722a.78.78 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.517.781.781 0 0 1 .518-.973c3.632-1.102 8.147-.568 11.234 1.328a.78.78 0 0 1 .258 1.071zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 1 1-.543-1.793c3.532-1.072 9.404-.865 13.115 1.338a.937.937 0 0 1-.955 1.612z"/></svg>
          <span>Spotify Playlistleri</span>
        </div>
        {currentUser && (
          <button class="sp-add-btn" id="sp-toggle-add">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
            Playlist Ekle
          </button>
        )}
      </div>

      {currentUser && (
        <div class="sp-add-form" id="sp-add-form" style="display:none">
          <div class="sp-add-inner">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="#1db954"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.622.622 0 0 1-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 0 1-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 0 1 .207.857zm1.223-2.722a.78.78 0 0 1-1.072.257c-2.687-1.652-6.785-2.131-9.965-1.166a.78.78 0 0 1-.973-.517.781.781 0 0 1 .518-.973c3.632-1.102 8.147-.568 11.234 1.328a.78.78 0 0 1 .258 1.071zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71a.937.937 0 1 1-.543-1.793c3.532-1.072 9.404-.865 13.115 1.338a.937.937 0 0 1-.955 1.612z"/></svg>
            <input
              id="sp-url-input"
              class="sp-url-input"
              type="text"
              placeholder="Spotify playlist URL yapıştır…"
              autocomplete="off"
            />
            <button id="sp-submit-btn" class="sp-submit-btn">Ekle</button>
          </div>
          <div id="sp-error" class="sp-error" style="display:none"></div>
        </div>
      )}

      <div class="sp-list" id="sp-list">
        {spotifyPlaylists.length === 0 ? (
          <div class="sp-empty">
            <span>Henüz playlist eklenmedi.</span>
            {currentUser
              ? <span> Yukarıdan ilk playlistini ekle!</span>
              : <span> Eklemek için <a href="/login">giriş yap</a>.</span>
            }
          </div>
        ) : (
          spotifyPlaylists.map(pl => (
            <div class="sp-card" data-id={pl.id} data-playlist-id={pl.playlist_id}>
              <div class="sp-card-header">
                <a href={`/u/${pl.username}`} class="sp-avatar" style={`background:${avatarBg(pl.username)}`}>
                  {(pl.display_name[0] ?? '?').toUpperCase()}
                </a>
                <div class="sp-card-meta">
                  <a href={`/u/${pl.username}`} class="sp-card-user">{pl.display_name}</a>
                  <span class="sp-card-title">{pl.title}</span>
                </div>
                <div class="sp-card-actions">
                  <button class="sp-toggle-btn" data-playlist-id={pl.playlist_id} title="Oynat / Gizle">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>
                  </button>
                  {currentUser?.id === pl.user_id && (
                    <button class="sp-delete-btn" data-id={pl.id} title="Kaldır">
                      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                  )}
                </div>
              </div>
              <div class="sp-embed-wrap" id={`sp-embed-${pl.playlist_id}`} style="display:none">
                <iframe
                  src={`https://open.spotify.com/embed/playlist/${pl.playlist_id}?utm_source=generator&theme=0`}
                  width="100%"
                  height="352"
                  frameborder="0"
                  allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          ))
        )}
      </div>
    </div>

  </div><!-- /yt-left -->

  <!-- ── Sağ sütun: playlist ── -->
  <div class="yt-right">
    <div class="yt-upnext-section">
      <div class="yt-upnext-header">
        <span class="yt-upnext-title">Sıradaki</span>
        <span id="playlist-count" class="yt-upnext-count"></span>
      </div>

      <div id="playlist-items"></div>
    </div>
  </div><!-- /yt-right -->

  </div><!-- /yt-layout -->
  </main>

  <!-- Hidden YouTube Player -->
  <div id="yt-player" style="position:fixed;left:-9999px;top:-9999px;width:1px;height:1px;pointer-events:none;"></div>
</BaseLayout>

<style is:global>
/* ═══════════════════════════════════════════
   PAGE BASE
═══════════════════════════════════════════ */
.yt-page {
  background: #f9f9f9;
  min-height: 100vh;
}

/* İki sütunlu layout */
.yt-layout {
  display: flex;
  align-items: flex-start;
  min-height: 100vh;
}

.yt-left {
  flex: 1;
  min-width: 0;
}

.yt-right {
  width: 380px;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  background: linear-gradient(160deg, #0f0c29, #302b63, #24243e);
}

/* ═══════════════════════════════════════════
   PLAYER WRAP
═══════════════════════════════════════════ */
.yt-player-wrap {
  background: #0f0f0f;
  position: sticky;
  top: 0;
  z-index: 20;
}

.yt-video-area {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  background: #0f0f0f;
  overflow: hidden;
  cursor: pointer;
}

.yt-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Center play overlay */
.yt-center-play {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.3);
  opacity: 0;
  transition: opacity 0.2s;
}

.yt-video-area:hover .yt-center-play,
.yt-center-play.visible { opacity: 1; }

.yt-center-play-btn {
  width: 72px;
  height: 72px;
  background: rgba(0,0,0,0.7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

/* Controls bar (bottom of video) */
.yt-controls-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.75));
  padding: 32px 12px 8px;
  opacity: 0;
  transition: opacity 0.2s;
}

.yt-video-area:hover .yt-controls-bar { opacity: 1; }

/* Progress bar */
.yt-progress {
  position: relative;
  height: 3px;
  background: rgba(255,255,255,0.3);
  border-radius: 2px;
  cursor: pointer;
  margin-bottom: 8px;
  transition: height 0.15s;
}

.yt-progress:hover { height: 5px; }

.yt-progress-played {
  height: 100%;
  background: #3b82f6;
  border-radius: 2px;
  width: 0%;
  pointer-events: none;
}

.yt-progress-dot {
  position: absolute;
  top: 50%;
  left: 0%;
  transform: translate(-50%, -50%);
  width: 13px;
  height: 13px;
  background: #3b82f6;
  border-radius: 50%;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s;
}

.yt-progress:hover .yt-progress-dot { opacity: 1; }

.yt-bar-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.yt-bar-left,
.yt-bar-right {
  display: flex;
  align-items: center;
  gap: 4px;
}

.yt-bar-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  color: #fff;
  transition: background 0.15s;
}
.yt-bar-btn:hover { background: rgba(255,255,255,0.12); }

.yt-time {
  font-size: 0.78rem;
  color: #fff;
  font-variant-numeric: tabular-nums;
  margin-left: 4px;
  white-space: nowrap;
}

/* Volume slider in bar */
.yt-vol-slider {
  width: 72px;
  -webkit-appearance: none;
  height: 3px;
  background: rgba(255,255,255,0.5);
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}
.yt-vol-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 12px; height: 12px;
  background: #fff;
  border-radius: 50%;
  cursor: pointer;
}

/* ═══════════════════════════════════════════
   VIDEO INFO SECTION
═══════════════════════════════════════════ */
.yt-info-section {
  background: #fff;
  padding: 12px 16px 0;
}

.yt-video-title {
  font-size: 1.1rem;
  font-weight: 600;
  line-height: 1.4;
  color: #0f0f0f;
  margin-bottom: 6px;
}

.yt-views-row {
  margin-bottom: 12px;
}

.yt-views-text {
  font-size: 0.85rem;
  color: #606060;
}

/* Action pills row */
.yt-action-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}

.yt-action-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  background: #f2f2f2;
  border: none;
  border-radius: 9999px;
  padding: 8px 14px;
  font-size: 0.82rem;
  font-weight: 500;
  cursor: pointer;
  color: #0f0f0f;
  transition: background 0.15s;
  white-space: nowrap;
}

.yt-action-pill:hover { background: #e5e5e5; }
.yt-action-pill.active { background: #0f0f0f; color: #fff; }

.yt-play-pill {
  background: #0f0f0f;
  color: #fff;
}
.yt-play-pill:hover { background: #272727; }

.yt-divider {
  height: 1px;
  background: #e5e5e5;
  margin: 12px 0;
}

/* Channel row */
.yt-channel-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-bottom: 4px;
}

.yt-ch-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.yt-ch-name {
  font-size: 0.9rem;
  font-weight: 600;
  color: #0f0f0f;
}

.yt-ch-sub {
  font-size: 0.78rem;
  color: #606060;
}

/* ═══════════════════════════════════════════
   ADD SONG
═══════════════════════════════════════════ */
.yt-add-section {
  background: #fff;
  padding: 12px 16px;
  border-top: 1px solid #e5e5e5;
  border-bottom: 1px solid #e5e5e5;
  margin-top: 8px;
}

.yt-add-inner {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #f2f2f2;
  border-radius: 9999px;
  padding: 8px 14px;
}

.yt-add-input {
  flex: 1;
  border: none;
  background: transparent;
  outline: none;
  font-size: 0.88rem;
  color: #0f0f0f;
  font-family: inherit;
}

.yt-add-input::placeholder { color: #909090; }

.yt-add-btn {
  background: #3b82f6;
  color: #fff;
  border: none;
  border-radius: 9999px;
  padding: 6px 16px;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.15s;
}
.yt-add-btn:hover { background: #2563eb; }
.yt-add-btn:disabled { opacity: 0.6; cursor: not-allowed; }

.yt-add-error {
  font-size: 0.8rem;
  color: #cc0000;
  margin-top: 8px;
  padding-left: 4px;
}

/* ═══════════════════════════════════════════
   UP NEXT / PLAYLIST
═══════════════════════════════════════════ */
.yt-upnext-section {
  padding-bottom: 40px;
}

.yt-upnext-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 14px 10px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

