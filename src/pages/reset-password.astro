---
// Bu sayfa hash fragment içindeki token'ı client-side JS ile işler.
// Supabase recovery linki: /reset-password#access_token=...&type=recovery
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yeni Şifre Belirle" activeNav="">
  <main class="main-content" style="display:flex; align-items:center; justify-content:center; min-height:100vh; background:#f0f2f5;">
    <div style="background:white; border-radius:20px; padding:40px; width:100%; max-width:420px; box-shadow:0 4px 24px rgba(0,0,0,0.08);">

      <div style="text-align:center; margin-bottom:28px;">
        <div style="font-size:2rem; font-weight:800; color:#3b82f6; margin-bottom:4px;">Basements</div>
        <div style="color:#536471; font-size:0.9rem;">Yeni şifre belirle</div>
      </div>

      <!-- Yükleniyor durumu -->
      <div id="rp-loading" style="text-align:center; padding:20px; color:#536471; font-size:0.9rem;">
        Doğrulanıyor…
      </div>

      <!-- Geçersiz/süresi dolmuş link -->
      <div id="rp-invalid" style="display:none; text-align:center; color:#dc2626; font-size:0.88rem; padding:12px 0;">
        <p style="margin-bottom:12px;">Bu bağlantı geçersiz veya süresi dolmuş.</p>
        <a href="/forgot-password" style="color:#3b82f6; font-weight:600; text-decoration:none;">Yeni bağlantı iste</a>
      </div>

      <!-- Şifre güncelleme formu -->
      <div id="rp-form" style="display:none;">
        <div id="rp-error" style="display:none; background:#fee2e2; color:#dc2626; padding:10px 14px; border-radius:10px; font-size:0.85rem; margin-bottom:16px;"></div>
        <div id="rp-success" style="display:none; background:#dcfce7; color:#166534; padding:12px 14px; border-radius:10px; font-size:0.88rem; margin-bottom:16px; text-align:center;">
          Şifren güncellendi! Yönlendiriliyorsun…
        </div>

        <div style="display:flex; flex-direction:column; gap:14px;">
          <div>
            <label style="display:block; font-size:0.85rem; font-weight:600; color:#374151; margin-bottom:4px;">Yeni Şifre</label>
            <input
              id="rp-password"
              type="password"
              minlength="6"
              placeholder="En az 6 karakter"
              style="width:100%; padding:10px 14px; border:1.5px solid #e2e8f0; border-radius:10px; font-size:0.95rem; outline:none; transition:border-color 0.15s;"
              onfocus="this.style.borderColor='#3b82f6'"
              onblur="this.style.borderColor='#e2e8f0'"
            />
          </div>
          <div>
            <label style="display:block; font-size:0.85rem; font-weight:600; color:#374151; margin-bottom:4px;">Şifre Tekrar</label>
            <input
              id="rp-confirm"
              type="password"
              minlength="6"
              placeholder="Şifreyi tekrar gir"
              style="width:100%; padding:10px 14px; border:1.5px solid #e2e8f0; border-radius:10px; font-size:0.95rem; outline:none; transition:border-color 0.15s;"
              onfocus="this.style.borderColor='#3b82f6'"
              onblur="this.style.borderColor='#e2e8f0'"
            />
          </div>
          <button
            id="rp-submit"
            type="button"
            style="background:#3b82f6; color:white; font-weight:700; font-size:1rem; padding:12px; border:none; border-radius:10px; cursor:pointer; transition:background 0.15s; margin-top:4px;"
            onmouseover="this.style.background='#2563eb'"
            onmouseout="this.style.background='#3b82f6'"
          >
            Şifreyi Güncelle
          </button>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
import { supa } from '../lib/supabase-browser';

const loadingEl = document.getElementById('rp-loading')!;
const invalidEl = document.getElementById('rp-invalid')!;
const formEl    = document.getElementById('rp-form')!;
const errorEl   = document.getElementById('rp-error')!;
const successEl = document.getElementById('rp-success')!;
const submitBtn = document.getElementById('rp-submit') as HTMLButtonElement;
const pwInput   = document.getElementById('rp-password') as HTMLInputElement;
const cfInput   = document.getElementById('rp-confirm')  as HTMLInputElement;

function showInvalid(msg?: string) {
  loadingEl.style.display = 'none';
  invalidEl.style.display = 'block';
  if (msg) {
    const p = invalidEl.querySelector('p');
    if (p) p.textContent = msg;
  }
}

function showForm() {
  loadingEl.style.display = 'none';
  formEl.style.display = 'block';
}

function showError(msg: string) {
  errorEl.textContent = msg;
  errorEl.style.display = 'block';
}

async function init() {
  // 1. Hash'te hata var mı? (/#error=access_denied...)
  const hash = new URLSearchParams(window.location.hash.slice(1));
  if (hash.get('error')) {
    const code = hash.get('error_code') ?? '';
    showInvalid(
      code === 'otp_expired'
        ? 'Bu bağlantının süresi dolmuş. Lütfen yeni bir bağlantı iste.'
        : (hash.get('error_description')?.replace(/\+/g, ' ') ?? 'Geçersiz bağlantı.')
    );
    return;
  }

  // 2. PKCE flow: URL'de ?code= parametresi var mı?
  const params = new URLSearchParams(window.location.search);
  const code   = params.get('code');

  if (code) {
    // URL'i temizle (kodu bir kez kullan)
    window.history.replaceState({}, '', '/reset-password');

    const { error } = await supa.auth.exchangeCodeForSession(code);
    if (error) {
      showInvalid(
        error.message.includes('expired') || error.message.includes('invalid')
          ? 'Bu bağlantının süresi dolmuş. Lütfen yeni bir bağlantı iste.'
          : error.message
      );
      return;
    }

    showForm();
    return;
  }

  // 3. Implicit flow (eski): hash'te access_token var mı?
  if (hash.get('access_token') && hash.get('type') === 'recovery') {
    await new Promise(r => setTimeout(r, 300));
    const { data: { session } } = await supa.auth.getSession();
    if (session) { showForm(); return; }
  }

  // 4. Hiçbiri yoksa — geçersiz sayfa girişi
  showInvalid();
}

init();

submitBtn.addEventListener('click', async () => {
  const password = pwInput.value;
  const confirm  = cfInput.value;

  errorEl.style.display = 'none';

  if (!password || password.length < 6) {
    showError('Şifre en az 6 karakter olmalı.');
    return;
  }
  if (password !== confirm) {
    showError('Şifreler eşleşmiyor.');
    return;
  }

  submitBtn.disabled = true;
  submitBtn.textContent = 'Güncelleniyor…';

  const { error } = await supa.auth.updateUser({ password });

  if (error) {
    showError(error.message);
    submitBtn.disabled = false;
    submitBtn.textContent = 'Şifreyi Güncelle';
    return;
  }

  successEl.style.display = 'block';
  formEl.querySelectorAll('input, label').forEach(el => {
    (el as HTMLElement).style.display = 'none';
  });
  submitBtn.style.display = 'none';

  setTimeout(() => { window.location.href = '/'; }, 2000);
});
</script>
