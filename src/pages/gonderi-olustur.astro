---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createAuthClient } from '../lib/supabase';

const authHeaders = new Headers();
const authClient = createAuthClient(Astro.request, authHeaders);
const { data: { user: authUser } } = await authClient.auth.getUser();
if (!authUser) return Astro.redirect('/login');

const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Gönderi Oluştur" activeNav="">
  <main class="main-content" style="min-height:100vh; background:#fafafa; display:flex; flex-direction:column;">

    <!-- Header -->
    <div class="feed-header" style="display:flex; align-items:center; gap:12px;">
      <a href="/" class="back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <span>Yeni Gönderi</span>
    </div>

    <div class="gc-wrap">
      {error && (
        <div class="gc-error">{decodeURIComponent(error)}</div>
      )}

      <form id="gc-form" method="POST" action="/api/gonderi/olustur" enctype="multipart/form-data">

        <!-- Medya seçim alanı -->
        <div id="gc-dropzone" class="gc-dropzone">
          <input type="file" id="gc-file" name="media"
            accept="image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm,video/ogg"
            hidden required />

          <!-- Placeholder -->
          <div id="gc-placeholder" class="gc-placeholder">
            <div class="gc-placeholder-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c7d2fe" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
            <p class="gc-placeholder-title">Fotoğraf veya video seç</p>
            <p class="gc-placeholder-sub">Tıkla veya sürükle bırak</p>
            <p class="gc-placeholder-types">JPG · PNG · WEBP · GIF · MP4 · WEBM · max 100 MB</p>
          </div>

          <!-- Önizleme -->
          <div id="gc-preview" style="display:none; width:100%; height:100%; position:relative;">
            <img id="gc-preview-img" src="" alt="" style="display:none; width:100%; height:100%; object-fit:contain;" />
            <video id="gc-preview-vid" src="" muted controls style="display:none; width:100%; height:100%; object-fit:contain;"></video>
            <button type="button" id="gc-clear" class="gc-clear-btn" title="Kaldır">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
        </div>

        <!-- Açıklama -->
        <div class="gc-caption-wrap">
          <textarea
            id="gc-caption"
            name="caption"
            class="gc-caption"
            placeholder="Açıklama yaz..."
            maxlength="300"
            required
          ></textarea>
          <div id="gc-char" class="gc-char">0 / 300</div>
        </div>

        <!-- Paylaş butonu -->
        <button type="submit" id="gc-submit" class="gc-submit">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
          <span id="gc-submit-label">Paylaş</span>
        </button>

      </form>
    </div>

  </main>
</BaseLayout>

<style>
.gc-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 16px 40px;
  gap: 16px;
  max-width: 540px;
  margin: 0 auto;
  width: 100%;
}

.gc-error {
  width: 100%;
  background: #fee2e2;
  color: #dc2626;
  padding: 10px 14px;
  border-radius: 12px;
  font-size: 0.88rem;
}

/* Dropzone */
.gc-dropzone {
  width: 100%;
  aspect-ratio: 1;
  border: 2px dashed #c7d2fe;
  border-radius: 20px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  overflow: hidden;
  transition: border-color 0.15s, background 0.15s;
  position: relative;
}
.gc-dropzone:hover,
.gc-dropzone.drag-over {
  border-color: #6366f1;
  background: #eef2ff;
}

/* Placeholder */
.gc-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 24px;
  text-align: center;
  pointer-events: none;
}
.gc-placeholder-icon { margin-bottom: 8px; }
.gc-placeholder-title {
  font-size: 1rem;
  font-weight: 700;
  color: #374151;
}
.gc-placeholder-sub {
  font-size: 0.85rem;
  color: #6b7280;
}
.gc-placeholder-types {
  font-size: 0.75rem;
  color: #9ca3af;
  margin-top: 4px;
}

/* Clear butonu */
.gc-clear-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  background: rgba(0,0,0,0.55);
  border: none;
  color: #fff;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  backdrop-filter: blur(4px);
  transition: background 0.15s;
}
.gc-clear-btn:hover { background: rgba(239,68,68,0.8); }

/* Caption */
.gc-caption-wrap {
  width: 100%;
  position: relative;
}
.gc-caption {
  width: 100%;
  min-height: 100px;
  border: 1.5px solid #e5e7eb;
  border-radius: 14px;
  padding: 12px 14px 28px;
  font-size: 0.95rem;
  font-family: inherit;
  resize: none;
  outline: none;
  background: #fff;
  color: #111827;
  transition: border-color 0.15s;
  box-sizing: border-box;
}
.gc-caption:focus { border-color: #6366f1; }
.gc-char {
  position: absolute;
  bottom: 10px;
  right: 12px;
  font-size: 0.75rem;
  color: #9ca3af;
}

/* Submit */
.gc-submit {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  padding: 14px;
  border: none;
  border-radius: 14px;
  cursor: pointer;
  transition: opacity 0.15s, transform 0.15s;
}
.gc-submit:hover { opacity: 0.9; transform: translateY(-1px); }
.gc-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
</style>

<script>
const dropzone   = document.getElementById('gc-dropzone')!;
const fileInput  = document.getElementById('gc-file') as HTMLInputElement;
const placeholder = document.getElementById('gc-placeholder')!;
const preview    = document.getElementById('gc-preview')!;
const previewImg = document.getElementById('gc-preview-img') as HTMLImageElement;
const previewVid = document.getElementById('gc-preview-vid') as HTMLVideoElement;
const clearBtn   = document.getElementById('gc-clear')!;
const caption    = document.getElementById('gc-caption') as HTMLTextAreaElement;
const charCount  = document.getElementById('gc-char')!;
const form       = document.getElementById('gc-form') as HTMLFormElement;
const submitBtn  = document.getElementById('gc-submit') as HTMLButtonElement;
const submitLabel = document.getElementById('gc-submit-label')!;

// Dropzone tıklama
dropzone.addEventListener('click', e => {
  if ((e.target as HTMLElement).closest('#gc-clear')) return;
  fileInput.click();
});

// Sürükle bırak
dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag-over'); });
dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-over'));
dropzone.addEventListener('drop', e => {
  e.preventDefault();
  dropzone.classList.remove('drag-over');
  const file = e.dataTransfer?.files[0];
  if (file) applyFile(file);
});

// Dosya seçimi
fileInput.addEventListener('change', () => {
  if (fileInput.files?.[0]) applyFile(fileInput.files[0]);
});

function applyFile(file: File) {
  const url = URL.createObjectURL(file);
  const isVideo = file.type.startsWith('video/');
  previewImg.style.display = isVideo ? 'none' : 'block';
  previewVid.style.display = isVideo ? 'block' : 'none';
  if (isVideo) { previewVid.src = url; } else { previewImg.src = url; }
  placeholder.style.display = 'none';
  preview.style.display = 'block';
}

// Temizle
clearBtn.addEventListener('click', e => {
  e.stopPropagation();
  previewImg.src = '';
  previewVid.src = '';
  fileInput.value = '';
  preview.style.display = 'none';
  placeholder.style.display = 'flex';
});

// Karakter sayacı
caption.addEventListener('input', () => {
  const len = caption.value.length;
  charCount.textContent = `${len} / 300`;
  charCount.style.color = len > 270 ? '#ef4444' : '#9ca3af';
});

// Submit
form.addEventListener('submit', () => {
  submitBtn.disabled = true;
  submitLabel.textContent = 'Yükleniyor...';
});
</script>
