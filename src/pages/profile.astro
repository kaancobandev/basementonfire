---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase, createAuthClient, type DbUser } from '../lib/supabase';

const authHeaders = new Headers();
const authClient = createAuthClient(Astro.request, authHeaders);
const { data: { user: authUser } } = await authClient.auth.getUser();
if (!authUser) return Astro.redirect('/login');

const { data: userData } = await supabase
  .from('users').select('*').eq('auth_id', authUser.id).single();
if (!userData) return Astro.redirect('/login');
const user = userData as DbUser;

const error   = Astro.url.searchParams.get('error');

const [followersRes, followingRes, mediaRes] = await Promise.all([
  supabase.from('follows').select('*', { count: 'exact', head: true }).eq('following_id', user.id),
  supabase.from('follows').select('*', { count: 'exact', head: true }).eq('follower_id', user.id),
  supabase.from('quick_facts').select('id, media_url, media_type, caption, likes, created_at')
    .eq('user_id', user.id).order('created_at', { ascending: false }),
]);

const followersCount = followersRes.count ?? 0;
const followingCount = followingRes.count ?? 0;
const mediaPosts     = mediaRes.data ?? [];

function avatarBg(u: string): string {
  const gs = [
    'linear-gradient(135deg,#6366f1,#8b5cf6)',
    'linear-gradient(135deg,#ec4899,#8b5cf6)',
    'linear-gradient(135deg,#f97316,#ef4444)',
    'linear-gradient(135deg,#10b981,#3b82f6)',
    'linear-gradient(135deg,#f59e0b,#f97316)',
    'linear-gradient(135deg,#14b8a6,#06b6d4)',
    'linear-gradient(135deg,#3b82f6,#6366f1)',
    'linear-gradient(135deg,#ef4444,#f97316)',
  ];
  let h = 0;
  for (const c of u) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return gs[Math.abs(h) % gs.length];
}

const bg = avatarBg(user.username);
const hasPhoto = !!user.avatar && user.avatar !== '/avatars/default.png';

function calcAge(bd: string | null): number | null {
  if (!bd) return null;
  const d = new Date(bd), t = new Date();
  let a = t.getFullYear() - d.getFullYear();
  const m = t.getMonth() - d.getMonth();
  if (m < 0 || (m === 0 && t.getDate() < d.getDate())) a--;
  return a;
}
const age = calcAge(user.birthdate ?? null);

const GENDER_LABEL: Record<string, string> = { erkek: 'Erkek', kadin: 'Kadın', diger: 'Diğer' };
---

<BaseLayout title="Profil" activeNav="profile">
<main class="main-content">

  <!-- Error -->
  {error && (
    <div class="pf-error">{decodeURIComponent(error)}</div>
  )}

  <div id="pf-user-meta" data-uid={user.id} hidden></div>

  <!-- Banner -->
  <div class="pf-banner" style={`background:${bg}`}></div>

  <!-- Profile header -->
  <div class="pf-header">
    <div class="pf-avatar-row">
      <div class="pf-avatar" style={hasPhoto ? '' : `background:${bg}`}>
        {hasPhoto
          ? <img src={user.avatar} alt={user.display_name} class="pf-avatar-img" />
          : user.display_name[0].toUpperCase()
        }
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <a href="/settings" class="pf-settings-btn" title="Ayarlar">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
        </a>
        <button id="open-edit" class="pf-edit-btn">Profili Düzenle</button>
      </div>
    </div>

    <h1 class="pf-name">{user.display_name}</h1>
    <p class="pf-handle">@{user.username}</p>
    {user.bio && <p class="pf-bio">{user.bio}</p>}
    {!user.bio && <p class="pf-bio pf-bio--empty">Bio eklemek için profili düzenle</p>}

    <!-- Meta satırı: konum, website, yaş, cinsiyet -->
    <div class="pf-meta-row">
      {user.location && (
        <span class="pf-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          {user.location}
        </span>
      )}
      {user.website && (
        <a class="pf-meta-item pf-meta-link" href={user.website} target="_blank" rel="noopener noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          {user.website.replace(/^https?:\/\//, '')}
        </a>
      )}
      {age !== null && (
        <span class="pf-meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {age} yaş
        </span>
      )}
      {user.gender && (
        <span class="pf-meta-item">
          {GENDER_LABEL[user.gender] ?? ''}
        </span>
      )}
    </div>

    <!-- İlgi alanları -->
    {user.interests && user.interests.length > 0 && (
      <div class="pf-interests">
        {user.interests.map(tag => (
          <span class="pf-interest-chip">{tag}</span>
        ))}
      </div>
    )}

    <div class="pf-stats">
      <span><strong>{mediaPosts.length}</strong> Gönderi</span>
      <span><strong>{followersCount}</strong> Takipçi</span>
      <span><strong>{followingCount}</strong> Takip</span>
    </div>
  </div>

  <!-- Media grid -->
  {mediaPosts.length === 0 ? (
    <div class="pf-empty">
      <div style="font-size:2.5rem;margin-bottom:12px">📷</div>
      <p style="font-weight:700;margin-bottom:4px">Henüz gönderi yok</p>
      <p style="font-size:0.85rem;color:var(--color-text-muted)">
        <a href="/gonderi-olustur" style="color:var(--color-primary)">İlk gönderini paylaş</a>
      </p>
    </div>
  ) : (
    <div class="pf-grid">
      {mediaPosts.map(post => (
        <button
          class="pf-cell"
          data-id={post.id}
          data-type={post.media_type}
          data-src={post.media_url}
          data-caption={post.caption}
          data-likes={post.likes}
          aria-label={post.caption}
        >
          {post.media_type === 'image' ? (
            <img src={post.media_url} alt={post.caption} loading="lazy" />
          ) : (
            <video src={post.media_url} muted preload="metadata" />
          )}
          <div class="pf-cell-overlay">
            <span class="pf-cell-likes">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              {post.likes}
            </span>
          </div>
        </button>
      ))}
    </div>
  )}
</main>

<!-- ── Edit Profile Modal ── -->
<div id="edit-modal" class="pf-modal-bg" style="display:none">
  <div class="pf-modal-box">
    <div class="pf-modal-header">
      <span>Profili Düzenle</span>
      <button id="close-edit" class="pf-icon-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <form method="POST" action="/api/profile/edit" class="pf-edit-form">
      <div class="pf-edit-avatar" id="edit-avatar-wrap" style={hasPhoto ? '' : `background:${bg}`}>
        {hasPhoto
          ? <img src={user.avatar} alt="" class="pf-avatar-img" id="edit-avatar-img" />
          : <span id="edit-avatar-letter">{user.display_name[0].toUpperCase()}</span>
        }
        <div class="pf-edit-avatar-overlay">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
        </div>
        <input type="file" id="avatar-file-input" accept="image/jpeg,image/png,image/webp,image/gif" style="display:none" />
      </div>

      <div class="pf-field">
        <label for="edit-name">Ad Soyad</label>
        <input
          id="edit-name"
          name="display_name"
          type="text"
          value={user.display_name}
          maxlength="50"
          required
          class="pf-input"
        />
      </div>

      <div class="pf-field">
        <label for="edit-bio">Bio</label>
        <textarea
          id="edit-bio"
          name="bio"
          maxlength="160"
          class="pf-textarea"
          placeholder="Kendinizden bahsedin..."
        >{user.bio}</textarea>
        <div id="bio-count" class="pf-char-count">{(user.bio ?? '').length} / 160</div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="pf-field">
          <label for="edit-location">Şehir / Konum</label>
          <input id="edit-location" name="location" type="text" value={user.location ?? ''} maxlength="60" class="pf-input" placeholder="İstanbul" />
        </div>
        <div class="pf-field">
          <label for="edit-gender">Cinsiyet</label>
          <select id="edit-gender" name="gender" class="pf-input">
            <option value="" selected={!user.gender}>Belirtmek istemiyorum</option>
            <option value="erkek" selected={user.gender === 'erkek'}>Erkek</option>
            <option value="kadin" selected={user.gender === 'kadin'}>Kadın</option>
            <option value="diger" selected={user.gender === 'diger'}>Diğer</option>
          </select>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div class="pf-field">
          <label for="edit-website">Website</label>
          <input id="edit-website" name="website" type="text" value={user.website ?? ''} maxlength="100" class="pf-input" placeholder="basementonfire.com" />
        </div>
        <div class="pf-field">
          <label for="edit-birthdate">Doğum Tarihi</label>
          <input id="edit-birthdate" name="birthdate" type="date" value={user.birthdate ?? ''} class="pf-input" />
        </div>
      </div>

      <!-- İlgi alanları tag input -->
      <div class="pf-field">
        <label>İlgi Alanları <span style="font-weight:400;color:var(--color-text-muted)">(en fazla 10)</span></label>
        <input type="hidden" name="interests" id="interests-value" value={(user.interests ?? []).join(',')} />
        <div class="pf-tag-input-wrap" id="tag-wrap">
          {(user.interests ?? []).map(tag => (
            <span class="pf-tag-chip" data-tag={tag}>{tag}<button type="button" class="pf-tag-remove">×</button></span>
          ))}
          <input id="tag-input" class="pf-tag-text" type="text" placeholder="Ekle ve Enter'a bas…" maxlength="24" autocomplete="off" />
        </div>
        <div class="pf-interests-presets">
          {['Müzik','Film','Spor','Seyahat','Yemek','Teknoloji','Sanat','Bilim','Tarih','Oyun','Kitap','Doğa','Fotoğraf','Dans','Moda'].map(p => (
            <button type="button" class="pf-preset-chip" data-preset={p}>{p}</button>
          ))}
        </div>
      </div>

      <button type="submit" class="post-btn" style="margin-top:8px">Kaydet</button>
    </form>
  </div>
</div>

<!-- ── Lightbox ── -->
<div id="pf-lightbox" class="pf-lightbox-bg" style="display:none">
  <div class="pf-lightbox-box">
    <button id="pf-close" class="pf-close-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <div class="pf-lightbox-media">
      <img id="pf-lb-img" src="" alt="" style="display:none" />
      <video id="pf-lb-vid" src="" controls style="display:none"></video>
    </div>
    <div class="pf-lightbox-info">
      <div class="pf-lb-user">
        <div class="pf-lb-avatar" style={`background:${bg}`}>{user.display_name[0].toUpperCase()}</div>
        <div>
          <div class="pf-lb-name">{user.display_name}</div>
          <div class="pf-lb-handle">@{user.username}</div>
        </div>
        <div class="pf-lb-likes" style="margin-left:auto">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#ef4444"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          <span id="pf-lb-likes">0</span>
        </div>
      </div>
      <p id="pf-lb-caption" class="pf-lb-caption"></p>
      <div id="pf-cm-list" class="cm-list" style="flex:1;min-height:80px;border-top:1px solid var(--color-border)"></div>
      <form id="pf-cm-form" class="cm-form">
        <div class="cm-form-avatar" style={`background:${bg}`}>{user.display_name[0].toUpperCase()}</div>
        <input id="pf-cm-input" class="cm-input" placeholder="Yorum ekle…" maxlength="300" autocomplete="off" />
        <button type="submit" class="cm-send-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
        </button>
      </form>
    </div>
  </div>
</div>
</BaseLayout>

<style>
.pf-error {
  background: #fee2e2; color: #dc2626;
  padding: 10px 20px; font-size: 0.85rem;
  border-bottom: 1px solid #fecaca;
}

.pf-banner { height: 160px; width: 100%; }

.pf-header {
  padding: 0 20px 16px;
  border-bottom: 1px solid var(--color-border);
}

.pf-avatar-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: -40px;
  margin-bottom: 12px;
}

.pf-avatar {
  width: 80px; height: 80px;
  border-radius: 50%;
  border: 4px solid white;
  box-shadow: 0 2px 12px rgba(0,0,0,0.12);
  display: flex; align-items: center; justify-content: center;
  color: white; font-size: 2rem; font-weight: 800;
  overflow: hidden;
}

.pf-avatar-img {
  width: 100%; height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

.pf-edit-btn {
  padding: 9px 22px;
  border-radius: 9999px;
  border: 2px solid var(--color-border);
  background: white;
  font-size: 0.9rem; font-weight: 700;
  cursor: pointer;
  transition: background 0.15s;
}
.pf-edit-btn:hover { background: #f0f2f5; }

.pf-settings-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 2px solid var(--color-border);
  background: white;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: background 0.15s, color 0.15s;
}
.pf-settings-btn:hover { background: #f0f2f5; color: var(--color-text); }

.pf-name { font-size: 1.25rem; font-weight: 800; margin: 0 0 2px; }
.pf-handle { color: var(--color-text-muted); font-size: 0.9rem; margin: 0 0 8px; }
.pf-bio { font-size: 0.9rem; line-height: 1.5; margin: 0 0 12px; }
.pf-bio--empty { color: var(--color-text-muted); font-style: italic; }

/* Profile meta row */
.pf-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin: 0 0 10px;
}
.pf-meta-item {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.82rem;
  color: var(--color-text-muted);
}
.pf-meta-link {
  color: var(--color-primary);
  text-decoration: none;
}
.pf-meta-link:hover { text-decoration: underline; }

/* Interests display */
.pf-interests {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 0 0 12px;
}
.pf-interest-chip {
  background: rgba(212,165,100,0.12);
  color: #c4954e;
  border: 1px solid rgba(212,165,100,0.35);
  border-radius: 9999px;
  padding: 3px 12px;
  font-size: 0.78rem;
  font-weight: 600;
}

/* Tag input in edit modal */
.pf-tag-input-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
  min-height: 44px;
  border: 1.5px solid var(--color-border);
  border-radius: 10px;
  padding: 6px 10px;
  cursor: text;
  background: var(--color-bg);
  transition: border-color 0.15s;
}
.pf-tag-input-wrap:focus-within { border-color: var(--color-primary); }
.pf-tag-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: rgba(212,165,100,0.15);
  color: #c4954e;
  border-radius: 9999px;
  padding: 2px 10px 2px 10px;
  font-size: 0.8rem;
  font-weight: 600;
}
.pf-tag-remove {
  background: none;
  border: none;
  cursor: pointer;
  color: #c4954e;
  font-size: 1rem;
  line-height: 1;
  padding: 0 0 0 2px;
  opacity: 0.7;
}
.pf-tag-remove:hover { opacity: 1; }
.pf-tag-text {
  border: none;
  outline: none;
  background: transparent;
  font-size: 0.85rem;
  color: var(--color-text);
  font-family: inherit;
  flex: 1;
  min-width: 80px;
}
.pf-tag-text::placeholder { color: var(--color-text-muted); }
.pf-interests-presets {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}
.pf-preset-chip {
  background: var(--color-border);
  color: var(--color-text-muted);
  border: none;
  border-radius: 9999px;
  padding: 3px 12px;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  font-family: inherit;
}
.pf-preset-chip:hover { background: rgba(212,165,100,0.2); color: #c4954e; }
.pf-preset-chip.active { background: rgba(212,165,100,0.2); color: #c4954e; }

.pf-stats {
  display: flex; gap: 20px;
  font-size: 0.85rem; color: var(--color-text-muted);
}
.pf-stats strong { color: var(--color-text); }

.pf-empty {
  text-align: center; padding: 80px 20px;
  color: var(--color-text-muted);
}

.pf-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3px; padding: 3px;
}
.pf-cell {
  aspect-ratio: 1; overflow: hidden;
  background: var(--color-border);
  border: none; padding: 0; cursor: pointer; position: relative;
}
.pf-cell img, .pf-cell video {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform 0.2s;
}
.pf-cell:hover img, .pf-cell:hover video { transform: scale(1.05); }
.pf-cell-overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.32);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.15s;
}
.pf-cell:hover .pf-cell-overlay { opacity: 1; }
.pf-cell-likes {
  color: white; font-weight: 700; font-size: 0.9rem;
  display: flex; align-items: center; gap: 4px;
}

/* Edit Modal */
.pf-modal-bg {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(4px);
  z-index: 200;
  display: flex; align-items: center; justify-content: center;
  padding: 16px;
}
.pf-modal-box {
  background: var(--color-surface);
  border-radius: 20px;
  width: 100%; max-width: 480px;
  padding: 20px;
  max-height: 90vh; overflow-y: auto;
}
.pf-modal-header {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 1rem; font-weight: 700;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}
.pf-icon-btn {
  background: none; border: none; cursor: pointer;
  color: var(--color-text-muted);
  display: flex; padding: 6px; border-radius: 50%;
  transition: background 0.15s;
}
.pf-icon-btn:hover { background: var(--color-border); }

.pf-edit-form { display: flex; flex-direction: column; gap: 16px; }
.pf-edit-avatar {
  width: 72px; height: 72px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: white; font-size: 1.8rem; font-weight: 800;
  margin-bottom: 4px;
  position: relative; overflow: hidden; cursor: pointer;
  flex-shrink: 0;
}
.pf-edit-avatar-overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.15s;
  border-radius: 50%;
}
.pf-edit-avatar:hover .pf-edit-avatar-overlay { opacity: 1; }
.pf-field { display: flex; flex-direction: column; gap: 6px; }
.pf-field label { font-size: 0.8rem; font-weight: 700; color: var(--color-text-muted); }
.pf-input, .pf-textarea {
  width: 100%;
  border: 1.5px solid var(--color-border);
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 0.95rem;
  font-family: inherit;
  outline: none;
  background: var(--color-bg);
  color: var(--color-text);
  transition: border-color 0.15s;
  box-sizing: border-box;
}
.pf-input:focus, .pf-textarea:focus { border-color: var(--color-primary); }
.pf-textarea { min-height: 80px; resize: vertical; }
.pf-char-count { font-size: 0.75rem; color: var(--color-text-muted); text-align: right; margin-top: 2px; }

/* Lightbox */
.pf-lightbox-bg {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.8); backdrop-filter: blur(4px);
  z-index: 200;
  display: flex; align-items: center; justify-content: center;
  padding: 16px;
}
.pf-lightbox-box {
  background: var(--color-surface); border-radius: 16px;
  display: flex; max-width: 860px; width: 100%;
  max-height: 90vh; overflow: hidden; position: relative;
}
.pf-close-btn {
  position: absolute; top: 10px; right: 10px; z-index: 1;
  background: rgba(0,0,0,0.4); border: none; color: white;
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; cursor: pointer;
}
.pf-lightbox-media {
  flex: 1; background: #000;
  display: flex; align-items: center; justify-content: center;
  min-height: 360px; max-height: 90vh;
}
.pf-lightbox-media img, .pf-lightbox-media video {
  max-width: 100%; max-height: 90vh; object-fit: contain;
}
.pf-lightbox-info {
  width: 280px; flex-shrink: 0;
  border-left: 1px solid var(--color-border);
  display: flex; flex-direction: column;
  padding: 16px; gap: 12px;
}
.pf-lb-user { display: flex; align-items: center; gap: 10px; }
.pf-lb-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: white; font-weight: 700; font-size: 0.85rem; flex-shrink: 0;
}
.pf-lb-name { font-weight: 700; font-size: 0.9rem; }
.pf-lb-handle { color: var(--color-text-muted); font-size: 0.8rem; }
.pf-lb-caption { font-size: 0.9rem; line-height: 1.6; flex: 1; margin: 0; }
.pf-lb-likes { display: flex; align-items: center; gap: 6px; font-weight: 700; color: #ef4444; }

.cm-list { overflow-y:auto; padding:4px 0; display:flex; flex-direction:column; }
.cm-loading,.cm-empty { text-align:center; padding:16px; font-size:0.8rem; color:var(--color-text-muted); }
.cm-item { display:flex; align-items:flex-start; gap:8px; padding:6px 12px; }
.cm-item:hover { background:#f9fafb; }
.cm-avatar { width:24px;height:24px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:white;font-size:0.65rem;font-weight:700;text-decoration:none; }
.cm-body { flex:1;min-width:0; }
.cm-author { font-weight:700;font-size:0.78rem;margin-right:4px; }
.cm-text { font-size:0.8rem;color:var(--color-text);line-height:1.4;word-break:break-word; }
.cm-time { font-size:0.68rem;color:var(--color-text-muted);margin-top:1px; }
.cm-delete { background:none;border:none;cursor:pointer;color:var(--color-text-muted);font-size:1rem;padding:2px 4px;border-radius:4px;flex-shrink:0;line-height:1;opacity:0;transition:opacity 0.15s,color 0.15s; }
.cm-item:hover .cm-delete { opacity:1; }
.cm-delete:hover { color:#ef4444; }
.cm-form { display:flex;align-items:center;gap:8px;padding:8px 12px;border-top:1px solid var(--color-border);flex-shrink:0; }
.cm-form-avatar { width:24px;height:24px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:white;font-size:0.65rem;font-weight:700; }
.cm-input { flex:1;border:none;outline:none;background:transparent;font-size:0.82rem;font-family:inherit;color:var(--color-text);min-width:0; }
.cm-input::placeholder { color:var(--color-text-muted); }
.cm-send-btn { background:none;border:none;cursor:pointer;color:var(--color-primary);padding:4px;display:flex;align-items:center;flex-shrink:0;opacity:0.4;transition:opacity 0.15s; }
.cm-send-btn:hover { opacity:1; }

@media (max-width: 640px) {
  .pf-lightbox-box { flex-direction: column; border-radius: 20px 20px 0 0; align-self: flex-end; max-width: 100%; }
  .pf-lightbox-info { width: 100%; border-left: none; border-top: 1px solid var(--color-border); }
  .pf-lightbox-media { min-height: 240px; max-height: 45vh; }
  .pf-lightbox-bg { padding: 0; align-items: flex-end; }
}
</style>

<script>
import { renderCaption } from '../lib/caption';

// ── Edit modal
const editModal  = document.getElementById('edit-modal')!;
const openEdit   = document.getElementById('open-edit')!;
const closeEdit  = document.getElementById('close-edit')!;
const bioTextarea = document.getElementById('edit-bio') as HTMLTextAreaElement;
const bioCount   = document.getElementById('bio-count')!;

openEdit.addEventListener('click',  () => { editModal.style.display = 'flex'; });
closeEdit.addEventListener('click', () => { editModal.style.display = 'none'; });
editModal.addEventListener('click', e => { if (e.target === editModal) editModal.style.display = 'none'; });

bioTextarea.addEventListener('input', () => {
  const l = bioTextarea.value.length;
  bioCount.textContent = `${l} / 160`;
  bioCount.style.color = l > 145 ? '#ef4444' : 'var(--color-text-muted)';
});

// ── İlgi alanları tag input
const tagWrap    = document.getElementById('tag-wrap')!;
const tagInput   = document.getElementById('tag-input') as HTMLInputElement;
const tagHidden  = document.getElementById('interests-value') as HTMLInputElement;

function getTags(): string[] {
  return tagHidden.value ? tagHidden.value.split(',').filter(Boolean) : [];
}
function syncHidden() {
  tagHidden.value = getTags().join(',');
}
function addTag(val: string) {
  const tag = val.trim().replace(/,/g, '');
  if (!tag || tag.length > 24) return;
  const tags = getTags();
  if (tags.length >= 10 || tags.includes(tag)) return;
  tags.push(tag);
  tagHidden.value = tags.join(',');
  renderTags();
}
function removeTag(tag: string) {
  tagHidden.value = getTags().filter(t => t !== tag).join(',');
  renderTags();
}
function renderTags() {
  tagWrap.querySelectorAll('.pf-tag-chip').forEach(el => el.remove());
  getTags().forEach(tag => {
    const chip = document.createElement('span');
    chip.className = 'pf-tag-chip';
    chip.dataset.tag = tag;
    chip.innerHTML = `${tag}<button type="button" class="pf-tag-remove">×</button>`;
    chip.querySelector('.pf-tag-remove')!.addEventListener('click', () => removeTag(tag));
    tagWrap.insertBefore(chip, tagInput);
  });
  // preset butonları güncelle
  document.querySelectorAll<HTMLButtonElement>('.pf-preset-chip').forEach(btn => {
    btn.classList.toggle('active', getTags().includes(btn.dataset.preset!));
  });
}

tagInput.addEventListener('keydown', e => {
  if (e.key === 'Enter' || e.key === ',') {
    e.preventDefault();
    addTag(tagInput.value);
    tagInput.value = '';
  } else if (e.key === 'Backspace' && !tagInput.value) {
    const tags = getTags();
    if (tags.length) removeTag(tags[tags.length - 1]);
  }
});
tagInput.addEventListener('blur', () => {
  if (tagInput.value.trim()) { addTag(tagInput.value); tagInput.value = ''; }
});
tagWrap.addEventListener('click', () => tagInput.focus());

document.querySelectorAll<HTMLButtonElement>('.pf-preset-chip').forEach(btn => {
  btn.addEventListener('click', () => {
    const preset = btn.dataset.preset!;
    const tags = getTags();
    if (tags.includes(preset)) { removeTag(preset); }
    else { addTag(preset); }
  });
});

// Mevcut chip'lere remove listener ekle
tagWrap.querySelectorAll<HTMLSpanElement>('.pf-tag-chip').forEach(chip => {
  chip.querySelector('.pf-tag-remove')?.addEventListener('click', () => removeTag(chip.dataset.tag!));
});
// preset durumlarını başlangıçta senkronize et
document.querySelectorAll<HTMLButtonElement>('.pf-preset-chip').forEach(btn => {
  btn.classList.toggle('active', getTags().includes(btn.dataset.preset!));
});

// ── Yardımcılar
function avatarBg(u: string): string {
  const gs = ['linear-gradient(135deg,#6366f1,#8b5cf6)','linear-gradient(135deg,#ec4899,#8b5cf6)',
    'linear-gradient(135deg,#f97316,#ef4444)','linear-gradient(135deg,#10b981,#3b82f6)',
    'linear-gradient(135deg,#f59e0b,#f97316)','linear-gradient(135deg,#14b8a6,#06b6d4)',
    'linear-gradient(135deg,#3b82f6,#6366f1)','linear-gradient(135deg,#ef4444,#f97316)'];
  let h = 0; for (const c of u) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return gs[Math.abs(h) % gs.length];
}
function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function tAgo(iso: string) {
  const s = Math.floor((Date.now()-new Date(iso).getTime())/1000);
  return s<60?`${s}sn`:s<3600?`${Math.floor(s/60)}dk`:s<86400?`${Math.floor(s/3600)}sa`:`${Math.floor(s/86400)}g`;
}

// ── Lightbox
const lightbox  = document.getElementById('pf-lightbox')!;
const lbImg     = document.getElementById('pf-lb-img') as HTMLImageElement;
const lbVid     = document.getElementById('pf-lb-vid') as HTMLVideoElement;
const lbCap     = document.getElementById('pf-lb-caption')!;
const lbLikes   = document.getElementById('pf-lb-likes')!;
const closeBtn  = document.getElementById('pf-close')!;
const cmList    = document.getElementById('pf-cm-list')!;
const cmForm    = document.getElementById('pf-cm-form') as HTMLFormElement;
const cmInput   = document.getElementById('pf-cm-input') as HTMLInputElement;
const myUserId  = parseInt(document.getElementById('pf-user-meta')?.dataset.uid ?? '0') || null;

let lbPostId: number | null = null;
let replyToId: number | null = null;

interface Cm { id:number; parent_id:number|null; user_id:number; content:string; created_at:string; display_name:string; username:string; }

function renderCm(c: Cm, isReply = false): string {
  const bg  = avatarBg(c.username);
  const own = (c.user_id === myUserId);
  const replyBtn = !isReply ? `<button class="cm-reply-btn" data-cm-id="${c.id}" data-username="${esc(c.username)}">Yanıtla</button>` : '';
  return `<div class="cm-item${isReply?' cm-reply':''}" data-cid="${c.id}"><a href="/u/${esc(c.username)}" class="cm-avatar" style="background:${bg}">${c.display_name[0].toUpperCase()}</a><div class="cm-body"><span class="cm-author">${esc(c.display_name)}</span><span class="cm-text">${esc(c.content)}</span><div class="cm-time-row"><span class="cm-time">${tAgo(c.created_at)}</span>${replyBtn}</div></div>${own?`<button class="cm-delete" data-id="${c.id}">×</button>`:''}</div>`;
}
function renderAllCm(list: Cm[]): string {
  const top = list.filter(c=>!c.parent_id);
  const rMap = new Map<number,Cm[]>();
  for(const c of list) if(c.parent_id){ if(!rMap.has(c.parent_id))rMap.set(c.parent_id,[]); rMap.get(c.parent_id)!.push(c); }
  let html=''; for(const c of top){ html+=renderCm(c,false); for(const r of rMap.get(c.id)??[]) html+=renderCm(r,true); }
  return html;
}
function bindDeletes() {
  cmList.querySelectorAll<HTMLButtonElement>('.cm-delete').forEach(b=>{
    b.addEventListener('click',async()=>{
      const res=await fetch(`/api/comments/${b.dataset.id}`,{method:'DELETE'});
      if(res.ok) b.closest('.cm-item')?.remove();
    });
  });
}
function bindReplies() {
  cmList.querySelectorAll<HTMLButtonElement>('.cm-reply-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      replyToId = Number(btn.dataset.cmId);
      cmInput.value=`@${btn.dataset.username} `;
      cmInput.focus();
      let hint=cmForm.querySelector('.cm-reply-hint');
      if(!hint){hint=document.createElement('span');hint.className='cm-reply-hint';cmForm.insertBefore(hint,cmInput);}
      hint.textContent='↩ yanıtlanıyor';
    });
  });
}
async function loadCm(postId: number) {
  cmList.innerHTML='<div class="cm-loading">Yükleniyor…</div>';
  try {
    const d = await fetch(`/api/quick-facts/${postId}/comments`).then(r=>r.json()) as {comments:Cm[]};
    cmList.innerHTML = d.comments.length ? renderAllCm(d.comments) : '<div class="cm-empty">Henüz yorum yok</div>';
    bindDeletes(); bindReplies();
    cmList.scrollTop = cmList.scrollHeight;
  } catch { cmList.innerHTML='<div class="cm-empty">Yüklenemedi.</div>'; }
}

cmForm.addEventListener('submit',async e=>{
  e.preventDefault();
  const content=cmInput.value.trim();
  if(!content||!lbPostId)return;
  const parentId=replyToId; replyToId=null;
  cmInput.value=''; cmForm.querySelector('.cm-reply-hint')?.remove();
  const body: Record<string,unknown>={content}; if(parentId) body.parent_id=parentId;
  const res=await fetch(`/api/quick-facts/${lbPostId}/comment`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  const d=await res.json() as {comment:Cm};
  if(d.comment){
    const cm=d.comment;
    cmList.querySelector('.cm-empty,.cm-loading')?.remove();
    if(cm.parent_id){
      let ins: Element=cmList.querySelector<HTMLElement>(`[data-cid="${cm.parent_id}"]`)??cmList.lastElementChild!;
      let nx=ins.nextElementSibling; while(nx?.classList.contains('cm-reply')){ins=nx;nx=nx.nextElementSibling;}
      ins.insertAdjacentHTML('afterend',renderCm(cm,true));
    } else { cmList.insertAdjacentHTML('beforeend',renderCm(cm,false)); }
    bindDeletes(); bindReplies();
    cmList.scrollTop=cmList.scrollHeight;
  }
});

document.querySelectorAll<HTMLButtonElement>('.pf-cell').forEach(cell => {
  cell.addEventListener('click', () => {
    const { id, type, src, caption, likes } = cell.dataset as Record<string, string>;
    lbPostId = Number(id);
    if (type === 'video') {
      lbImg.style.display = 'none'; lbVid.style.display = 'block'; lbVid.src = src;
    } else {
      lbVid.style.display = 'none'; lbImg.style.display = 'block'; lbImg.src = src;
    }
    lbCap.innerHTML     = renderCaption(caption);
    lbLikes.textContent = likes;
    loadCm(lbPostId);
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  });
});

function closeLb() {
  lightbox.style.display = 'none';
  lbVid.pause(); lbVid.src = '';
  document.body.style.overflow = '';
  lbPostId = null; cmInput.value = '';
}
closeBtn.addEventListener('click', closeLb);
lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLb(); });
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (lightbox.style.display !== 'none') closeLb();
    if (editModal.style.display !== 'none') editModal.style.display = 'none';
  }
});

// ── Profil fotoğrafı değiştirme ──────────────────────────────────────────────
const editAvatarWrap  = document.getElementById('edit-avatar-wrap') as HTMLElement | null;
const avatarFileInput = document.getElementById('avatar-file-input') as HTMLInputElement | null;

editAvatarWrap?.addEventListener('click', () => avatarFileInput?.click());

avatarFileInput?.addEventListener('change', async () => {
  const file = avatarFileInput.files?.[0];
  if (!file) return;

  const overlay = editAvatarWrap?.querySelector<HTMLElement>('.pf-edit-avatar-overlay');
  if (overlay) { overlay.style.opacity = '1'; overlay.innerHTML = '<span style="color:white;font-size:0.75rem">…</span>'; }

  try {
    const fd = new FormData();
    fd.append('file', file);
    const res  = await fetch('/api/profile/avatar', { method: 'POST', body: fd });
    const data = await res.json() as { avatar_url?: string; error?: string };

    if (data.avatar_url) {
      // Tüm avatar görselleri güncelle
      document.querySelectorAll<HTMLImageElement>('.pf-avatar-img').forEach(img => {
        img.src = data.avatar_url!;
      });

      // Header avatar – harften fotoğrafa geç
      const headerAvatar = document.querySelector<HTMLElement>('.pf-avatar');
      if (headerAvatar && !headerAvatar.querySelector('.pf-avatar-img')) {
        headerAvatar.textContent = '';
        headerAvatar.style.background = '';
        const img = document.createElement('img');
        img.className = 'pf-avatar-img';
        img.alt = '';
        img.src = data.avatar_url;
        headerAvatar.appendChild(img);
      } else if (headerAvatar) {
        headerAvatar.style.background = '';
      }

      // Edit modal avatar – harften fotoğrafa geç
      if (editAvatarWrap && !editAvatarWrap.querySelector('.pf-avatar-img')) {
        editAvatarWrap.querySelector('#edit-avatar-letter')?.remove();
        editAvatarWrap.style.background = '';
        const img = document.createElement('img');
        img.className = 'pf-avatar-img';
        img.id = 'edit-avatar-img';
        img.alt = '';
        img.src = data.avatar_url;
        editAvatarWrap.insertBefore(img, editAvatarWrap.firstChild);
      } else if (editAvatarWrap) {
        editAvatarWrap.style.background = '';
      }
    } else {
      alert(data.error ?? 'Yükleme başarısız');
    }
  } catch {
    alert('Yükleme başarısız');
  } finally {
    if (overlay) {
      overlay.style.opacity = '';
      overlay.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>`;
    }
  }
});
</script>
