---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase, createAuthClient, type DbUser } from '../lib/supabase';

// Giriş kontrolü
const authHeaders = new Headers();
const authClient = createAuthClient(Astro.request, authHeaders);
const { data: { user: authUser } } = await authClient.auth.getUser();
if (!authUser) return Astro.redirect('/login');

// Auth id ile users tablosundan profili getir
const { data: userData } = await supabase
  .from('users')
  .select('*')
  .eq('auth_id', authUser.id)
  .single();

if (!userData) return Astro.redirect('/login');
const user = userData as DbUser;

const { data: postsData } = await supabase
  .from('posts')
  .select('id, content, category, likes, created_at')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

const posts = (postsData ?? []) as Array<{ id: number; content: string; category: string; likes: number; created_at: string }>;
---

<BaseLayout title="Profil" activeNav="profile">
  <main class="main-content">
    <!-- Profile header -->
    <div style="background:linear-gradient(135deg, #3b82f6, #8b5cf6); height:160px; position:relative;">
      <a href="/" class="back-btn" style="position:absolute; top:12px; left:12px; color:white; background:rgba(0,0,0,0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
    </div>

    <div style="padding:0 20px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-top:-40px; margin-bottom:16px;">
        <div class="avatar" style="width:80px; height:80px; font-size:2rem; border:4px solid white; box-shadow:0 2px 8px rgba(0,0,0,0.15);">
          {user.display_name[0]}
        </div>
        <button style="padding:8px 20px; border:2px solid #e2e8f0; border-radius:9999px; background:white; font-weight:700; font-size:0.9rem; cursor:pointer; transition:background 0.15s;" onmouseover="this.style.background='#f0f2f5'" onmouseout="this.style.background='white'">
          Profili Duzenle
        </button>
      </div>

      <h1 style="font-size:1.3rem; font-weight:800; margin:0 0 2px;">{user.display_name}</h1>
      <p style="color:#536471; font-size:0.9rem; margin:0 0 8px;">@{user.username}</p>
      <p style="font-size:0.9rem; line-height:1.6; margin-bottom:12px;">{user.bio}</p>

      <div style="display:flex; gap:20px; color:#536471; font-size:0.85rem; padding-bottom:16px; border-bottom:1px solid #e2e8f0;">
        <span><strong style="color:#0f1419;">{posts.length}</strong> Gonderi</span>
        <span><strong style="color:#0f1419;">0</strong> Takipci</span>
        <span><strong style="color:#0f1419;">0</strong> Takip</span>
      </div>
    </div>

    <!-- User posts -->
    {posts.map(post => (
      <article class="post-card">
        <div class="post-header">
          <div class="avatar">{user.display_name[0]}</div>
          <div class="post-meta">
            <span class="post-author">{user.display_name}</span>
            <span class="post-handle"> @{user.username}</span>
          </div>
        </div>
        <div class="post-content">
          <span class={`category-badge category-${post.category}`}>
            {post.category === 'science' ? 'Bilim' : post.category === 'history' ? 'Tarih' : 'Genel'}
          </span>
          <br />
          {post.content}
        </div>
        <div class="post-actions">
          <span class="action-btn">❤️ {post.likes}</span>
        </div>
      </article>
    ))}
  </main>
</BaseLayout>
