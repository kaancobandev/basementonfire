---
import BaseLayout from '../layouts/BaseLayout.astro';

const tabs = ['Hayvanlar', 'Manzara', 'Sanat'];

const images = {
  Hayvanlar: [
    { src: '/gallery/animal1.jpg', alt: 'Kirmizi Panda', label: 'Kirmizi Panda' },
    { src: '/gallery/animal2.jpg', alt: 'Kurt', label: 'Kurt' },
    { src: '/gallery/animal3.jpg', alt: 'Kartal', label: 'Kartal' },
    { src: '/gallery/animal4.jpg', alt: 'Aslan', label: 'Aslan' },
  ],
  Manzara: [
    { src: '/gallery/landscape1.jpg', alt: 'Dag', label: 'Daglar' },
    { src: '/gallery/landscape2.jpg', alt: 'Okyanus', label: 'Okyanus' },
    { src: '/gallery/landscape3.jpg', alt: 'Orman', label: 'Orman' },
  ],
  Sanat: [
    { src: '/gallery/art1.jpg', alt: 'Dijital Sanat', label: 'Dijital Sanat' },
    { src: '/gallery/art2.jpg', alt: 'Fotograf', label: 'Fotograf Sanat' },
  ],
};
---

<BaseLayout title="Galeri" activeNav="gallery">
  <main class="main-content" style="max-width:600px;">
    <div class="page-header">
      <a href="/" class="back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      Galeri
    </div>

    <!-- Tabs -->
    <div id="gallery-tabs" style="display:flex; border-bottom:1px solid #e2e8f0; padding:0 20px;">
      {tabs.map((tab, i) => (
        <button
          class={`gallery-tab${i === 0 ? ' active' : ''}`}
          data-tab={tab}
          style={`padding:12px 20px; border:none; background:none; font-size:0.9rem; font-weight:${i === 0 ? '700' : '500'}; cursor:pointer; border-bottom:2px solid ${i === 0 ? '#3b82f6' : 'transparent'}; color:${i === 0 ? '#3b82f6' : '#536471'}; transition:all 0.15s;`}
        >
          {tab}
        </button>
      ))}
    </div>

    <!-- Gallery grids -->
    {tabs.map((tab, i) => (
      <div id={`gallery-${tab}`} style={`display:${i === 0 ? 'grid' : 'none'}; grid-template-columns:repeat(2,1fr); gap:2px; padding:2px;`}>
        {images[tab as keyof typeof images].map((img, idx) => (
          <div
            class="gallery-item"
            data-src={img.src}
            data-label={img.label}
            style="aspect-ratio:1; overflow:hidden; cursor:pointer; position:relative; background:#f0f2f5;"
            onmouseover="this.querySelector('.gallery-overlay').style.opacity='1'"
            onmouseout="this.querySelector('.gallery-overlay').style.opacity='0'"
          >
            <img
              src={img.src}
              alt={img.alt}
              style="width:100%; height:100%; object-fit:cover; transition:transform 0.3s;"
              onerror={`this.style.display='none'; this.parentElement.innerHTML='<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f0f2f5;color:#888;font-size:0.8rem;padding:8px;text-align:center;">${img.label}<br/>(Resim yüklenemedi)</div>'`}
            />
            <div class="gallery-overlay" style="position:absolute;inset:0;background:rgba(0,0,0,0.4);display:flex;align-items:flex-end;padding:12px;opacity:0;transition:opacity 0.2s;">
              <span style="color:white;font-weight:600;font-size:0.85rem;">{img.label}</span>
            </div>
          </div>
        ))}
      </div>
    ))}

    <!-- Lightbox -->
    <div id="lightbox" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:1000; align-items:center; justify-content:center; flex-direction:column;">
      <button id="lb-close" style="position:absolute; top:16px; right:16px; background:rgba(255,255,255,0.1); border:none; color:white; font-size:1.5rem; cursor:pointer; padding:8px 16px; border-radius:8px;">✕</button>
      <img id="lb-img" src="" alt="" style="max-width:90vw; max-height:80vh; object-fit:contain; border-radius:8px;" />
      <p id="lb-label" style="color:white; margin-top:16px; font-size:0.9rem;"></p>
    </div>
  </main>
</BaseLayout>

<script>
  // Tab switching
  document.querySelectorAll('.gallery-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const name = (tab as HTMLElement).dataset.tab!;
      document.querySelectorAll('.gallery-tab').forEach(t => {
        (t as HTMLElement).style.fontWeight = '500';
        (t as HTMLElement).style.borderBottom = '2px solid transparent';
        (t as HTMLElement).style.color = '#536471';
      });
      (tab as HTMLElement).style.fontWeight = '700';
      (tab as HTMLElement).style.borderBottom = '2px solid #3b82f6';
      (tab as HTMLElement).style.color = '#3b82f6';

      document.querySelectorAll('[id^="gallery-"]').forEach(el => {
        (el as HTMLElement).style.display = 'none';
      });
      const grid = document.getElementById(`gallery-${name}`)!;
      grid.style.display = 'grid';
    });
  });

  // Lightbox
  const lb = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbLabel = document.getElementById('lb-label')!;

  document.querySelectorAll('.gallery-item').forEach(item => {
    item.addEventListener('click', () => {
      const src = (item as HTMLElement).dataset.src!;
      const label = (item as HTMLElement).dataset.label!;
      lbImg.src = src;
      lbLabel.textContent = label;
      lb.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    });
  });

  document.getElementById('lb-close')!.addEventListener('click', () => {
    lb.style.display = 'none';
    document.body.style.overflow = '';
  });
  lb.addEventListener('click', e => {
    if (e.target === lb) { lb.style.display = 'none'; document.body.style.overflow = ''; }
  });
</script>
