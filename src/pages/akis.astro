---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase, createAuthClient, flattenFacts, type QuickFact } from '../lib/supabase';
import { thumbUrl } from '../lib/image';

const authHeaders = new Headers();
const authClient  = createAuthClient(Astro.request, authHeaders);
const { data: { user: authUser } } = await authClient.auth.getUser();

let currentDbUser: { id: number; display_name: string; username: string } | null = null;
if (authUser) {
  const { data } = await supabase
    .from('users').select('id, display_name, username').eq('auth_id', authUser.id).single();
  currentDbUser = data;
}

// ── Stories ──────────────────────────────────────────────────────────────────
interface StoryItem { id: number; mediaUrl: string; mediaType: string; createdAt: string; }
interface StoryUser { userId: number; username: string; displayName: string; avatar: string | null; stories: StoryItem[]; }

const now = new Date().toISOString();
const { data: storiesRaw } = await supabase
  .from('stories')
  .select('id, media_url, media_type, created_at, user_id, users(id, username, display_name, avatar)')
  .gt('expires_at', now)
  .order('created_at', { ascending: false });

const storyMap = new Map<number, StoryUser>();
for (const s of (storiesRaw ?? []) as any[]) {
  const u = s.users;
  const uid: number = s.user_id;
  if (!storyMap.has(uid)) {
    storyMap.set(uid, { userId: uid, username: u.username, displayName: u.display_name, avatar: u.avatar ?? null, stories: [] });
  }
  storyMap.get(uid)!.stories.push({ id: s.id, mediaUrl: s.media_url, mediaType: s.media_type, createdAt: s.created_at });
}
const ownStoryUser: StoryUser | null = currentDbUser ? (storyMap.get(currentDbUser.id) ?? null) : null;
if (currentDbUser) storyMap.delete(currentDbUser.id);
const otherStoryUsers: StoryUser[] = [...storyMap.values()];

// Avatar renk yardımcısı (server-side)
const avatarColorsArr = ['linear-gradient(135deg,#667eea,#764ba2)','linear-gradient(135deg,#f093fb,#f5576c)','linear-gradient(135deg,#4facfe,#00f2fe)','linear-gradient(135deg,#43e97b,#38f9d7)','linear-gradient(135deg,#fa709a,#fee140)','linear-gradient(135deg,#a18cd1,#fbc2eb)','linear-gradient(135deg,#fda085,#f6d365)','linear-gradient(135deg,#96fbc4,#f9f586)'];
function avatarBgServer(username: string) {
  let h = 0;
  for (let i = 0; i < username.length; i++) h = (h * 31 + username.charCodeAt(i)) & 0xffffffff;
  return avatarColorsArr[Math.abs(h) % avatarColorsArr.length];
}

const PAGE_SIZE = 12;

const { data: raw } = await supabase
  .from('quick_facts')
  .select('*, users(display_name, username)')
  .order('created_at', { ascending: false })
  .order('id', { ascending: false })
  .limit(PAGE_SIZE + 1);

const allFetched: QuickFact[] = flattenFacts(raw ?? []);
const hasMore  = allFetched.length > PAGE_SIZE;
const posts: QuickFact[] = hasMore ? allFetched.slice(0, PAGE_SIZE) : allFetched;
const initialNextCursor  = hasMore ? posts[posts.length - 1].id : null;

function timeAgo(d: string) {
  const s = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
  if (s < 60)   return `${s}s`;
  if (s < 3600) return `${Math.floor(s/60)}d`;
  if (s < 86400) return `${Math.floor(s/3600)}sa`;
  return `${Math.floor(s/86400)}g`;
}
---

<BaseLayout title="Akış" activeNav="akis">
  <main class="main-content" style="position:relative;">
    <div id="page-meta"
      data-user-id={currentDbUser?.id ?? ''}
      data-display-name={currentDbUser?.display_name ?? ''}
      data-username={currentDbUser?.username ?? ''}
      hidden
    ></div>

    <!-- Story verisi JS'e aktarım -->
    <script id="story-data" type="application/json" set:text={JSON.stringify({
      ownStoryUser,
      otherStoryUsers,
      myId: currentDbUser?.id ?? null,
    })} />

    <!-- Başlık + yükleme butonu -->
    <div class="feed-header" style="display:flex; justify-content:space-between; align-items:center;">
      <span>Akış</span>
      <button id="open-upload" class="hb-upload-trigger">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        Yeni Paylaş
      </button>
    </div>

    <!-- ── Story Bar ──────────────────────────────────────────────────────── -->
    <div class="story-bar" id="story-bar">
      <!-- Kendi hikayesi -->
      {currentDbUser && (
        <button class="story-item" id="story-own-btn" data-has-story={ownStoryUser ? 'true' : 'false'}>
          <div class={`story-ring ${ownStoryUser ? 'has-story' : 'add-story'}`}>
            {currentDbUser ? (
              <div class="story-av" style={`background:${avatarBgServer(currentDbUser.username)}`}>
                {currentDbUser.display_name[0].toUpperCase()}
              </div>
            ) : null}
            {!ownStoryUser && (
              <span class="story-plus">+</span>
            )}
          </div>
          <span class="story-label">{ownStoryUser ? 'Hikayem' : 'Ekle'}</span>
        </button>
      )}

      <!-- Diğer kullanıcıların hikayeleri -->
      {otherStoryUsers.map((u, i) => (
        <button class="story-item" data-story-idx={i} aria-label={`${u.displayName} hikayesi`}>
          <div class="story-ring has-story">
            {u.avatar
              ? <img src={u.avatar} alt="" class="story-av" />
              : <div class="story-av" style={`background:${avatarBgServer(u.username)}`}>{u.displayName[0].toUpperCase()}</div>
            }
          </div>
          <span class="story-label">{u.username}</span>
        </button>
      ))}

      {!currentDbUser && otherStoryUsers.length === 0 && (
        <p class="story-empty">Henüz hikaye yok</p>
      )}
    </div>

    <!-- Story oluşturma modal -->
    <div id="story-create-modal" class="sv-overlay" style="display:none;">
      <div class="story-create-box">
        <div class="story-create-header">
          <span>Yeni Hikaye</span>
          <button class="sv-icon-btn" id="story-create-close">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <div id="story-drop" class="story-drop">
          <input type="file" id="story-file" accept="image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm" hidden />
          <div id="story-drop-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:12px;color:#888"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            <p style="font-weight:600;margin-bottom:4px;">Fotoğraf veya video seç</p>
            <p style="font-size:0.8rem;color:#888;">Tıkla veya sürükle · Max 50MB</p>
          </div>
          <div id="story-drop-preview" style="display:none;width:100%;height:100%;position:relative;">
            <img id="story-prev-img" style="width:100%;height:100%;object-fit:contain;display:none;" alt="" />
            <video id="story-prev-vid" style="width:100%;height:100%;object-fit:contain;display:none;" muted controls></video>
          </div>
        </div>
        <p id="story-error" style="color:#ef4444;font-size:0.85rem;display:none;margin:8px 0 0;"></p>
        <button id="story-submit-btn" class="story-submit-btn" disabled>Hikayeyi Paylaş</button>
      </div>
    </div>

    <!-- Story Viewer Modal -->
    <div id="story-viewer" class="sv-overlay" style="display:none;" role="dialog" aria-modal="true">
      <!-- Bulanık arka plan -->
      <div class="sv-bg" id="sv-bg"></div>

      <div class="sv-shell">
        <!-- Üst: progress bar + kullanıcı bilgisi -->
        <div class="sv-top">
          <div class="sv-bars" id="sv-bars"></div>
          <div class="sv-meta">
            <div class="sv-meta-av" id="sv-meta-av"></div>
            <div>
              <div class="sv-meta-name" id="sv-meta-name"></div>
              <div class="sv-meta-time" id="sv-meta-time"></div>
            </div>
            <button class="sv-icon-btn" id="sv-close" style="margin-left:auto;">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
        </div>

        <!-- Medya -->
        <div class="sv-media-wrap">
          <img id="sv-img" class="sv-media" style="display:none;" alt="" />
          <video id="sv-vid" class="sv-media" style="display:none;" muted playsinline></video>
        </div>

        <!-- Dokunma bölgeleri -->
        <div class="sv-zone sv-zone-prev" id="sv-prev"></div>
        <div class="sv-zone sv-zone-next" id="sv-next"></div>
      </div>
    </div>

    <!-- Yeni gönderi banner -->
    <div id="new-posts-bar" class="new-posts-bar" hidden>
      <button id="new-posts-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
        <span id="new-posts-label">Yeni gönderiler var</span>
      </button>
    </div>

    <!-- Instagram grid -->
    {posts.length === 0 ? (
      <div class="hb-empty">
        <div style="font-size:3rem; margin-bottom:16px;">📸</div>
        <p style="font-weight:700; font-size:1.1rem; margin-bottom:8px;">Henüz içerik yok</p>
        <p style="color:var(--color-text-muted); font-size:0.9rem;">İlk hızlı bilgini paylaşmak için "Yeni Paylaş" butonuna bas.</p>
      </div>
    ) : (
      <div class="hb-grid" id="hb-grid">
        {posts.map((post, i) => (
          <button
            class="hb-cell"
            data-id={post.id}
            data-type={post.media_type}
            data-src={post.media_url}
            data-caption={post.caption}
            data-author={post.display_name}
            data-handle={post.username}
            data-likes={post.likes}
            data-time={timeAgo(post.created_at)}
            aria-label={post.caption}
          >
            {post.media_type === 'image' ? (
              <img
                src={thumbUrl(post.media_url, 600, 75)}
                alt={post.caption}
                loading={i < 6 ? 'eager' : 'lazy'}
                decoding="async"
                fetchpriority={i < 3 ? 'high' : 'auto'}
                class="cell-img"
              />
            ) : (
              <video
                src={post.media_url}
                muted
                preload="none"
                class="cell-vid"
                data-src={post.media_url}
              />
            )}
            <div class="hb-cell-overlay">
              <span class="hb-cell-likes">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                {post.likes}
              </span>
              {post.media_type === 'video' && (
                <span class="hb-cell-video-badge">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </span>
              )}
            </div>
          </button>
        ))}
      </div>
    )}

    <!-- Infinite scroll sentinel -->
    <div id="feed-sentinel" data-next-cursor={initialNextCursor ?? ''} data-has-more={hasMore ? 'true' : 'false'}>
      <div id="feed-loader" class="feed-loader" hidden>
        <div class="feed-spinner"></div>
      </div>
      <p id="feed-end" class="feed-end" hidden>Tüm gönderiler yüklendi</p>
    </div>

  </main>

  <!-- ── Upload Modal ─────────────────────────────── -->
  <div id="upload-modal" class="hb-modal-bg" style="display:none;">
    <div class="hb-modal-box">
      <div class="hb-modal-header">
        <span style="font-weight:700; font-size:1rem;">Yeni Paylaşım</span>
        <button id="close-upload" class="hb-icon-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <form id="upload-form" method="POST" action="/api/upload" enctype="multipart/form-data">

        <!-- Dosya seçim alanı -->
        <div id="drop-zone" class="hb-dropzone">
          <input type="file" id="media-input" name="media" accept="image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm,video/ogg" hidden required />
          <div id="drop-placeholder">
            <div style="font-size:2.5rem; margin-bottom:12px;">🖼️</div>
            <p style="font-weight:600; margin-bottom:4px;">Resim veya video seç</p>
            <p style="font-size:0.82rem; color:var(--color-text-muted);">Tıkla veya sürükle bırak · JPG PNG WEBP GIF MP4 WEBM · Max 100 MB</p>
          </div>
          <div id="drop-preview" style="display:none; width:100%; height:100%; position:relative;">
            <img id="preview-img" src="" alt="önizleme" style="width:100%; height:100%; object-fit:contain; display:none;" />
            <video id="preview-vid" src="" controls style="width:100%; height:100%; object-fit:contain; display:none;"></video>
            <button type="button" id="clear-file" class="hb-icon-btn" style="position:absolute; top:8px; right:8px; background:rgba(0,0,0,0.5); color:white;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
        </div>

        <!-- Hata mesajı -->
        <p id="upload-error" style="display:none; color:#ef4444; font-size:0.85rem; margin:8px 0 0;"></p>

        <!-- Açıklama -->
        <div style="margin-top:16px;">
          <textarea
            name="caption"
            id="caption-input"
            class="hb-textarea"
            placeholder="Hızlı bir bilgi yaz... (max 300 karakter)"
            maxlength="300"
            required
          ></textarea>
          <div id="char-count" style="text-align:right; font-size:0.78rem; color:var(--color-text-muted); margin-top:4px;">0 / 300</div>
        </div>

        <button type="submit" id="submit-btn" class="post-btn" style="margin-top:16px; width:100%;">
          Paylaş
        </button>
      </form>
    </div>
  </div>

  <!-- ── Post Detay Modal ───────────────────────────── -->
  <div id="detail-modal" class="hb-modal-bg" style="display:none;">
    <div class="hb-detail-box">
      <!-- Kapat -->
      <button id="close-detail" class="hb-icon-btn" style="position:absolute; top:12px; right:12px; background:rgba(0,0,0,0.4); color:white; z-index:1;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>

      <!-- Sol: medya -->
      <div class="hb-detail-media">
        <img id="detail-img" src="" alt="" style="display:none; width:100%; height:100%; object-fit:contain;" />
        <video id="detail-vid" src="" controls style="display:none; width:100%; height:100%; object-fit:contain;"></video>
      </div>

      <!-- Sağ: bilgiler -->
      <div class="hb-detail-info">
        <!-- Yazar satırı -->
        <div class="hb-di-header">
          <a id="detail-avatar-link" href="/" class="hb-di-avatar">B</a>
          <div>
            <div class="hb-di-author" id="detail-author"></div>
            <div class="hb-di-handle" id="detail-handle"></div>
          </div>
          <div class="hb-di-time" id="detail-time"></div>
        </div>

        <!-- Açıklama -->
        <div class="hb-di-cap">
          <p id="detail-caption"></p>
        </div>

        <!-- Yorumlar -->
        <div id="comments-list" class="cm-list">
          <div class="cm-loading">Yorumlar yükleniyor…</div>
        </div>

        <!-- Yorum girişi -->
        <form id="comment-form" class="cm-form">
          <div id="cm-my-avatar" class="cm-form-avatar">?</div>
          <input id="comment-input" class="cm-input" placeholder="Yorum ekle…" maxlength="300" autocomplete="off" />
          <button type="submit" class="cm-send-btn" title="Gönder">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          </button>
        </form>

        <!-- Like + bookmark + yorum sayısı -->
        <div class="hb-di-footer">
          <button id="detail-like-btn" class="action-btn" style="font-size:1rem; gap:8px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="like-icon"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            <span id="detail-likes">0</span>
          </button>
          <button id="detail-bookmark-btn" class="action-btn bookmark-btn" title="Kaydet">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="bookmark-icon"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
          </button>
          <span id="cm-count" class="cm-count-badge">0 yorum</span>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── Story Bar ─────────────────────────────────────── */
  .story-bar {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    scrollbar-width: none;
  }
  .story-bar::-webkit-scrollbar { display: none; }

  .story-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    padding: 2px;
  }

  .story-ring {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    padding: 2.5px;
    position: relative;
    transition: transform 0.15s;
  }
  .story-item:hover .story-ring { transform: scale(1.06); }

  .story-ring.has-story {
    background: linear-gradient(135deg, #f58529, #dd2a7b, #8134af, #515bd4);
  }
  .story-ring.add-story {
    background: rgba(255,255,255,0.12);
    border: 2px dashed rgba(255,255,255,0.25);
  }

  .story-av {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.25rem;
    color: #fff;
    background: #1e1a14;
    border: 2px solid #0f0e0d;
  }

  .story-plus {
    position: absolute;
    bottom: -1px;
    right: -1px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #d4a564;
    color: #0f0e0d;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #0f0e0d;
    line-height: 1;
  }

  .story-label {
    font-size: 0.7rem;
    color: #aaa;
    max-width: 64px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
  }
  .story-empty { color: #666; font-size: 0.85rem; align-self: center; padding: 0 8px; }

  /* ── Story Create Modal ─────────────────────────────── */
  .story-create-box {
    background: #1a1510;
    border-radius: 20px;
    width: 100%;
    max-width: 400px;
    padding: 20px;
    position: relative;
    z-index: 1;
  }
  .story-create-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    font-weight: 700;
    font-size: 1rem;
    color: #e8e0d8;
  }
  .story-drop {
    border: 2px dashed rgba(255,255,255,0.15);
    border-radius: 16px;
    height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-align: center;
    overflow: hidden;
    position: relative;
    transition: border-color 0.2s, background 0.2s;
    color: #ccc;
  }
  .story-drop:hover, .story-drop.drag-over {
    border-color: #d4a564;
    background: rgba(212,165,100,0.05);
  }
  .story-submit-btn {
    width: 100%;
    margin-top: 14px;
    padding: 12px;
    border: none;
    border-radius: 9999px;
    background: #d4a564;
    color: #0f0e0d;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s, opacity 0.15s;
  }
  .story-submit-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .story-submit-btn:not(:disabled):hover { background: #c4954e; }

  /* ── Story Viewer ────────────────────────────────────── */
  .sv-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sv-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(30px) brightness(0.3);
    transform: scale(1.1);
    transition: background-image 0.3s;
  }
  .sv-shell {
    position: relative;
    z-index: 1;
    width: 100%;
