---
import BaseLayout from '../layouts/BaseLayout.astro';
import { supabase, createAuthClient, flattenFacts, type QuickFact } from '../lib/supabase';
import { thumbUrl } from '../lib/image';

const authHeaders = new Headers();
const authClient  = createAuthClient(Astro.request, authHeaders);
const { data: { user: authUser } } = await authClient.auth.getUser();

let currentDbUser: { id: number; display_name: string; username: string } | null = null;
if (authUser) {
  const { data } = await supabase
    .from('users').select('id, display_name, username').eq('auth_id', authUser.id).single();
  currentDbUser = data;
}

const PAGE_SIZE = 12;

const { data: raw } = await supabase
  .from('quick_facts')
  .select('*, users(display_name, username)')
  .order('created_at', { ascending: false })
  .order('id', { ascending: false })
  .limit(PAGE_SIZE + 1);

const allFetched: QuickFact[] = flattenFacts(raw ?? []);
const hasMore  = allFetched.length > PAGE_SIZE;
const posts: QuickFact[] = hasMore ? allFetched.slice(0, PAGE_SIZE) : allFetched;
const initialNextCursor  = hasMore ? posts[posts.length - 1].id : null;

function timeAgo(d: string) {
  const s = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
  if (s < 60)   return `${s}s`;
  if (s < 3600) return `${Math.floor(s/60)}d`;
  if (s < 86400) return `${Math.floor(s/3600)}sa`;
  return `${Math.floor(s/86400)}g`;
}
---

<BaseLayout title="Akış" activeNav="akis">
  <main class="main-content" style="position:relative;">
    <div id="page-meta"
      data-user-id={currentDbUser?.id ?? ''}
      data-display-name={currentDbUser?.display_name ?? ''}
      data-username={currentDbUser?.username ?? ''}
      hidden
    ></div>

    <!-- Başlık + yükleme butonu -->
    <div class="feed-header" style="display:flex; justify-content:space-between; align-items:center;">
      <span>Akış</span>
      <button id="open-upload" class="hb-upload-trigger">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
        Yeni Paylaş
      </button>
    </div>

    <!-- Yeni gönderi banner -->
    <div id="new-posts-bar" class="new-posts-bar" hidden>
      <button id="new-posts-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
        <span id="new-posts-label">Yeni gönderiler var</span>
      </button>
    </div>

    <!-- Instagram grid -->
    {posts.length === 0 ? (
      <div class="hb-empty">
        <div style="font-size:3rem; margin-bottom:16px;">📸</div>
        <p style="font-weight:700; font-size:1.1rem; margin-bottom:8px;">Henüz içerik yok</p>
        <p style="color:var(--color-text-muted); font-size:0.9rem;">İlk hızlı bilgini paylaşmak için "Yeni Paylaş" butonuna bas.</p>
      </div>
    ) : (
      <div class="hb-grid" id="hb-grid">
        {posts.map((post, i) => (
          <button
            class="hb-cell"
            data-id={post.id}
            data-type={post.media_type}
            data-src={post.media_url}
            data-caption={post.caption}
            data-author={post.display_name}
            data-handle={post.username}
            data-likes={post.likes}
            data-time={timeAgo(post.created_at)}
            aria-label={post.caption}
          >
            {post.media_type === 'image' ? (
              <img
                src={thumbUrl(post.media_url, 600, 75)}
                alt={post.caption}
                loading={i < 6 ? 'eager' : 'lazy'}
                decoding="async"
                fetchpriority={i < 3 ? 'high' : 'auto'}
                class="cell-img"
              />
            ) : (
              <video
                src={post.media_url}
                muted
                preload="none"
                class="cell-vid"
                data-src={post.media_url}
              />
            )}
            <div class="hb-cell-overlay">
              <span class="hb-cell-likes">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                {post.likes}
              </span>
              {post.media_type === 'video' && (
                <span class="hb-cell-video-badge">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </span>
              )}
            </div>
          </button>
        ))}
      </div>
    )}

    <!-- Infinite scroll sentinel -->
    <div id="feed-sentinel" data-next-cursor={initialNextCursor ?? ''} data-has-more={hasMore ? 'true' : 'false'}>
      <div id="feed-loader" class="feed-loader" hidden>
        <div class="feed-spinner"></div>
      </div>
      <p id="feed-end" class="feed-end" hidden>Tüm gönderiler yüklendi</p>
    </div>

  </main>

  <!-- ── Upload Modal ─────────────────────────────── -->
  <div id="upload-modal" class="hb-modal-bg" style="display:none;">
    <div class="hb-modal-box">
      <div class="hb-modal-header">
        <span style="font-weight:700; font-size:1rem;">Yeni Paylaşım</span>
        <button id="close-upload" class="hb-icon-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <form id="upload-form" method="POST" action="/api/upload" enctype="multipart/form-data">

        <!-- Dosya seçim alanı -->
        <div id="drop-zone" class="hb-dropzone">
          <input type="file" id="media-input" name="media" accept="image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm,video/ogg" hidden required />
          <div id="drop-placeholder">
            <div style="font-size:2.5rem; margin-bottom:12px;">🖼️</div>
            <p style="font-weight:600; margin-bottom:4px;">Resim veya video seç</p>
            <p style="font-size:0.82rem; color:var(--color-text-muted);">Tıkla veya sürükle bırak · JPG PNG WEBP GIF MP4 WEBM · Max 100 MB</p>
          </div>
          <div id="drop-preview" style="display:none; width:100%; height:100%; position:relative;">
            <img id="preview-img" src="" alt="önizleme" style="width:100%; height:100%; object-fit:contain; display:none;" />
            <video id="preview-vid" src="" controls style="width:100%; height:100%; object-fit:contain; display:none;"></video>
            <button type="button" id="clear-file" class="hb-icon-btn" style="position:absolute; top:8px; right:8px; background:rgba(0,0,0,0.5); color:white;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          </div>
        </div>

        <!-- Hata mesajı -->
        <p id="upload-error" style="display:none; color:#ef4444; font-size:0.85rem; margin:8px 0 0;"></p>

        <!-- Açıklama -->
        <div style="margin-top:16px;">
          <textarea
            name="caption"
            id="caption-input"
            class="hb-textarea"
            placeholder="Hızlı bir bilgi yaz... (max 300 karakter)"
            maxlength="300"
            required
          ></textarea>
          <div id="char-count" style="text-align:right; font-size:0.78rem; color:var(--color-text-muted); margin-top:4px;">0 / 300</div>
        </div>

        <button type="submit" id="submit-btn" class="post-btn" style="margin-top:16px; width:100%;">
          Paylaş
        </button>
      </form>
    </div>
  </div>

  <!-- ── Post Detay Modal ───────────────────────────── -->
  <div id="detail-modal" class="hb-modal-bg" style="display:none;">
    <div class="hb-detail-box">
      <!-- Kapat -->
      <button id="close-detail" class="hb-icon-btn" style="position:absolute; top:12px; right:12px; background:rgba(0,0,0,0.4); color:white; z-index:1;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>

      <!-- Sol: medya -->
      <div class="hb-detail-media">
        <img id="detail-img" src="" alt="" style="display:none; width:100%; height:100%; object-fit:contain;" />
        <video id="detail-vid" src="" controls style="display:none; width:100%; height:100%; object-fit:contain;"></video>
      </div>

      <!-- Sağ: bilgiler -->
      <div class="hb-detail-info">
        <!-- Yazar satırı -->
        <div class="hb-di-header">
          <a id="detail-avatar-link" href="/" class="hb-di-avatar">B</a>
          <div>
            <div class="hb-di-author" id="detail-author"></div>
            <div class="hb-di-handle" id="detail-handle"></div>
          </div>
          <div class="hb-di-time" id="detail-time"></div>
        </div>

        <!-- Açıklama -->
        <div class="hb-di-cap">
          <p id="detail-caption"></p>
        </div>

        <!-- Yorumlar -->
        <div id="comments-list" class="cm-list">
          <div class="cm-loading">Yorumlar yükleniyor…</div>
        </div>

        <!-- Yorum girişi -->
        <form id="comment-form" class="cm-form">
          <div id="cm-my-avatar" class="cm-form-avatar">?</div>
          <input id="comment-input" class="cm-input" placeholder="Yorum ekle…" maxlength="300" autocomplete="off" />
          <button type="submit" class="cm-send-btn" title="Gönder">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          </button>
        </form>

        <!-- Like + bookmark + yorum sayısı -->
        <div class="hb-di-footer">
          <button id="detail-like-btn" class="action-btn" style="font-size:1rem; gap:8px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="like-icon"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            <span id="detail-likes">0</span>
          </button>
          <button id="detail-bookmark-btn" class="action-btn bookmark-btn" title="Kaydet">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="bookmark-icon"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
          </button>
          <span id="cm-count" class="cm-count-badge">0 yorum</span>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  /* Yeni gönderi banner */
  .new-posts-bar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding: 8px;
    background: var(--bg, #0f0e0d);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  #new-posts-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #d4a564;
    color: #0f0e0d;
    border: none;
    border-radius: 9999px;
    padding: 8px 20px;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(212,165,100,0.35);
    animation: bar-in 0.3s ease;
    transition: background 0.15s, transform 0.15s;
  }
  #new-posts-btn:hover { background: #c4954e; transform: scale(1.03); }
  @keyframes bar-in { from { opacity:0; transform:translateY(-8px); } to { opacity:1; transform:translateY(0); } }

  /* Upload butonu */
  .hb-upload-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 9999px;
    padding: 8px 16px;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
  }
  .hb-upload-trigger:hover { background: var(--color-primary-hover); }

  /* Boş durum */
  .hb-empty {
    text-align: center;
    padding: 80px 24px;
    color: var(--color-text-muted);
  }

  /* Instagram grid — 3 sütun, kare */
  .hb-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    padding: 3px;
  }
  .hb-cell {
    aspect-ratio: 1;
    position: relative;
    overflow: hidden;
    background: var(--color-border);
    border: none;
    padding: 0;
    cursor: pointer;
    display: block;
  }
  /* Skeleton shimmer */
  .hb-cell {
    background: #1e1a14;
  }
  .hb-cell::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.04) 50%, transparent 100%);
    transform: translateX(-100%);
    animation: cell-shimmer 1.4s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  .hb-cell.media-loaded::after { display: none; }
  @keyframes cell-shimmer {
    to { transform: translateX(100%); }
  }

  /* Blur-up */
  .hb-cell img,
  .hb-cell video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s, opacity 0.4s;
    opacity: 0;
  }
  .hb-cell img.loaded,
  .hb-cell video.loaded { opacity: 1; }
  .hb-cell:hover img,
  .hb-cell:hover video { transform: scale(1.04); }

  /* Hücre hover overlay */
  .hb-cell-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .hb-cell:hover .hb-cell-overlay { opacity: 1; }
  .hb-cell-likes {
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .hb-cell-video-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0,0,0,0.5);
    border-radius: 4px;
    padding: 2px 4px;
    display: flex;
  }

  /* Modal arkaplan */
  .hb-modal-bg {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(4px);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  /* Upload modal kutusu */
  .hb-modal-box {
    background: var(--color-surface);
    border-radius: 20px;
    width: 100%;
    max-width: 480px;
    padding: 20px;
    max-height: 90vh;
    overflow-y: auto;
  }
  .hb-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 12px;
  }
  .hb-icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    border-radius: 50%;
    transition: background 0.15s, color 0.15s;
  }
  .hb-icon-btn:hover { background: var(--color-border); color: var(--color-text); }

  /* Dosya sürükle-bırak alanı */
  .hb-dropzone {
    border: 2px dashed var(--color-border);
    border-radius: 16px;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    text-align: center;
    overflow: hidden;
    position: relative;
  }
  .hb-dropzone:hover,
  .hb-dropzone.drag-over {
    border-color: var(--color-primary);
    background: #eff6ff;
  }

  /* Açıklama textarea */
  .hb-textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 0.95rem;
    font-family: inherit;
    resize: vertical;
    min-height: 88px;
    max-height: 180px;
    outline: none;
    background: var(--color-bg);
    transition: border-color 0.15s;
    color: var(--color-text);
  }
  .hb-textarea:focus { border-color: var(--color-primary); }

  /* Detay modal — Instagram post görünümü */
  .hb-detail-box {
    background: var(--color-surface);
    border-radius: 16px;
    display: flex;
    width: 100%;
    max-width: 860px;
    max-height: 90vh;
    overflow: hidden;
    position: relative;
  }
  .hb-detail-media {
    flex: 1;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    max-height: 90vh;
  }
  .hb-detail-info {
    width: 300px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--color-border);
    max-height: 90vh;
  }

  /* Detail info yeniden yapılandırılmış */
  .hb-di-header {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .hb-di-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    background: linear-gradient(135deg,#6366f1,#8b5cf6);
    display: flex; align-items: center; justify-content: center;
    color: white; font-weight: 700; font-size: 0.85rem;
    flex-shrink: 0; text-decoration: none;
  }
  .hb-di-author { font-weight: 700; font-size: 0.9rem; }
  .hb-di-handle { color: var(--color-text-muted); font-size: 0.78rem; }
  .hb-di-time   { margin-left: auto; font-size: 0.75rem; color: var(--color-text-muted); }
  .hb-di-cap {
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .hb-di-cap p { font-size: 0.9rem; line-height: 1.6; margin: 0; white-space: pre-wrap; }
  .hb-di-footer {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 16px;
    border-top: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .cm-count-badge { font-size: 0.8rem; color: var(--color-text-muted); margin-left: auto; }

  .bookmark-btn { color: var(--color-text-muted); transition: color 0.15s; }
  .bookmark-btn.bookmarked { color: #d4a564; }
  .bookmark-btn.bookmarked #bookmark-icon { fill: #d4a564; stroke: #d4a564; }

  /* Yorumlar listesi */
  .cm-list {
    flex: 1; overflow-y: auto;
    padding: 4px 0;
    display: flex; flex-direction: column;
  }
  .cm-loading, .cm-empty {
    text-align: center;
    padding: 24px 16px;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }
  .cm-item {
    display: flex; align-items: flex-start; gap: 8px;
    padding: 7px 16px;
    transition: background 0.1s;
  }
  .cm-item:hover { background: #f9fafb; }
  .cm-avatar {
    width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 0.7rem; font-weight: 700;
    text-decoration: none;
  }
  .cm-body { flex: 1; min-width: 0; }
  .cm-author { font-weight: 700; font-size: 0.8rem; margin-right: 4px; }
  .cm-text   { font-size: 0.82rem; color: var(--color-text); line-height: 1.4; word-break: break-word; }
  .cm-time   { font-size: 0.7rem; color: var(--color-text-muted); margin-top: 2px; }
  .cm-delete {
    background: none; border: none; cursor: pointer;
    color: var(--color-text-muted); font-size: 1rem;
    padding: 2px 4px; border-radius: 4px; flex-shrink: 0;
    line-height: 1; opacity: 0; transition: opacity 0.15s, color 0.15s;
  }
  .cm-item:hover .cm-delete { opacity: 1; }
  .cm-delete:hover { color: #ef4444; }

  /* Yorum girişi */
  .cm-form {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px;
    border-top: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .cm-form-avatar {
    width: 26px; height: 26px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 0.7rem; font-weight: 700;
    background: linear-gradient(135deg,#6366f1,#8b5cf6);
  }
  .cm-input {
    flex: 1; border: none; outline: none; background: transparent;
    font-size: 0.85rem; font-family: inherit; color: var(--color-text);
    min-width: 0;
  }
  .cm-input::placeholder { color: var(--color-text-muted); }
  .cm-send-btn {
    background: none; border: none; cursor: pointer;
    color: var(--color-primary); padding: 4px;
    display: flex; align-items: center; flex-shrink: 0;
    opacity: 0.4; transition: opacity 0.15s;
  }
  .cm-send-btn:hover { opacity: 1; }

  /* Infinite scroll */
  #feed-sentinel { padding: 24px 0 48px; display: flex; flex-direction: column; align-items: center; }
  .feed-loader { display: flex; justify-content: center; padding: 16px; }
  .feed-spinner {
    width: 28px; height: 28px;
    border: 3px solid rgba(212,165,100,0.2);
    border-top-color: #d4a564;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .feed-end { font-size: 0.82rem; color: #666; margin: 0; text-align: center; }

  /* Mobil: yığılmış layout */
  @media (max-width: 640px) {
    .hb-detail-box  { flex-direction: column; max-width: 100%; border-radius: 20px 20px 0 0; align-self: flex-end; }
    .hb-detail-info { width: 100%; border-left: none; border-top: 1px solid var(--color-border); }
    .hb-detail-media { min-height: 280px; max-height: 50vh; }
    .hb-grid { grid-template-columns: repeat(3, 1fr); }
    .hb-modal-bg { padding: 0; align-items: flex-end; }
    .hb-modal-box { border-radius: 20px 20px 0 0; max-height: 92vh; }
  }
</style>

<script>
import { renderCaption } from '../lib/caption';
import { supa } from '../lib/supabase-browser';

function initAkis() {
  const uploadModal = document.getElementById('upload-modal');
  if (!uploadModal) return;
  const openUploadBtn  = document.getElementById('open-upload')!;
  const closeUploadBtn = document.getElementById('close-upload')!;

openUploadBtn.addEventListener('click',  () => { uploadModal.style.display = 'flex'; });
closeUploadBtn.addEventListener('click', () => closeUpload());
uploadModal.addEventListener('click', e => { if (e.target === uploadModal) closeUpload(); });

if (new URLSearchParams(window.location.search).get('create') === '1') {
  uploadModal.style.display = 'flex';
}

function closeUpload() {
  uploadModal.style.display = 'none';
  clearFile();
  (document.getElementById('upload-error') as HTMLElement).style.display = 'none';
  (document.getElementById('caption-input') as HTMLTextAreaElement).value = '';
  (document.getElementById('char-count') as HTMLElement).textContent = '0 / 300';
}

// ── Dosya seçimi / sürükle-bırak ────────────────────────────────────────────
const dropZone     = document.getElementById('drop-zone')!;
const mediaInput   = document.getElementById('media-input') as HTMLInputElement;
const placeholder  = document.getElementById('drop-placeholder')!;
const previewDiv   = document.getElementById('drop-preview')!;
const previewImg   = document.getElementById('preview-img') as HTMLImageElement;
const previewVid   = document.getElementById('preview-vid') as HTMLVideoElement;
const clearFileBtn = document.getElementById('clear-file')!;

dropZone.addEventListener('click', e => {
  if ((e.target as HTMLElement).closest('#clear-file')) return;
  mediaInput.click();
});

dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const file = e.dataTransfer?.files[0];
  if (file) applyFile(file);
});

mediaInput.addEventListener('change', () => {
  if (mediaInput.files?.[0]) applyFile(mediaInput.files[0]);
});

clearFileBtn.addEventListener('click', e => { e.stopPropagation(); clearFile(); });

function applyFile(file: File) {
  const url = URL.createObjectURL(file);
  const isVideo = file.type.startsWith('video/');

  previewImg.style.display = isVideo ? 'none' : 'block';
  previewVid.style.display = isVideo ? 'block' : 'none';

  if (isVideo) { previewVid.src = url; }
  else         { previewImg.src = url; }

  placeholder.style.display = 'none';
  previewDiv.style.display  = 'block';
}

function clearFile() {
  previewImg.src = '';
  previewVid.src = '';
  mediaInput.value = '';
  previewDiv.style.display = 'none';
  placeholder.style.display = 'flex';
}

// ── Karakter sayacı ──────────────────────────────────────────────────────────
const captionInput = document.getElementById('caption-input') as HTMLTextAreaElement;
const charCount    = document.getElementById('char-count')!;

captionInput.addEventListener('input', () => {
  const len = captionInput.value.length;
  charCount.textContent = `${len} / 300`;
  charCount.style.color = len > 270 ? '#ef4444' : 'var(--color-text-muted)';
});

// ── Upload form submit (client-side validation + yükleme göstergesi) ─────────
const uploadForm  = document.getElementById('upload-form') as HTMLFormElement;
const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;
const uploadError = document.getElementById('upload-error')!;

uploadForm.addEventListener('submit', e => {
  uploadError.style.display = 'none';

  if (!mediaInput.files?.[0]) {
    e.preventDefault();
    showError('Lütfen bir resim veya video seç.');
    return;
  }
  if (!captionInput.value.trim()) {
    e.preventDefault();
    showError('Açıklama boş olamaz.');
    return;
  }

  submitBtn.disabled = true;
  submitBtn.textContent = 'Yükleniyor...';
});

function showError(msg: string) {
  uploadError.textContent = msg;
  uploadError.style.display = 'block';
}

// ── Sayfa meta (mevcut kullanıcı)
const meta = document.getElementById('page-meta') as HTMLElement;
const currentUserId   = meta?.dataset.userId     ? parseInt(meta.dataset.userId) : null;
const currentUserName = meta?.dataset.displayName ?? '';
const currentUsername = meta?.dataset.username    ?? '';

// ── Detay modal
const detailModal    = document.getElementById('detail-modal')!;
const closeDetailBtn = document.getElementById('close-detail')!;
const detailImg      = document.getElementById('detail-img') as HTMLImageElement;
const detailVid      = document.getElementById('detail-vid') as HTMLVideoElement;
const detailCaption  = document.getElementById('detail-caption')!;
const detailAuthor   = document.getElementById('detail-author')!;
const detailHandle   = document.getElementById('detail-handle')!;
const detailTime     = document.getElementById('detail-time')!;
const detailAvLink   = document.getElementById('detail-avatar-link') as HTMLAnchorElement;
const detailLikes    = document.getElementById('detail-likes')!;
const detailLikeBtn  = document.getElementById('detail-like-btn')!;
const likeIcon       = document.getElementById('like-icon')!;
const commentsList   = document.getElementById('comments-list')!;
const commentForm    = document.getElementById('comment-form') as HTMLFormElement;
const commentInput   = document.getElementById('comment-input') as HTMLInputElement;
const cmMyAvatar     = document.getElementById('cm-my-avatar')!;
const cmCount        = document.getElementById('cm-count')!;

let currentPostId: number | null = null;
let liked      = false;
let bookmarked = false;

const detailBookmarkBtn = document.getElementById('detail-bookmark-btn')!;
const bookmarkIcon      = document.getElementById('bookmark-icon')!;

// Realtime hook'ları — alt kısımdaki realtime bloğu bunları doldurur
let onPostOpen:  ((postId: number) => void) | null = null;
let onPostClose: (() => void) | null = null;

// Avatar renk yardımcısı
function avatarBg(u: string): string {
  const gs = [
    'linear-gradient(135deg,#6366f1,#8b5cf6)','linear-gradient(135deg,#ec4899,#8b5cf6)',
    'linear-gradient(135deg,#f97316,#ef4444)','linear-gradient(135deg,#10b981,#3b82f6)',
    'linear-gradient(135deg,#f59e0b,#f97316)','linear-gradient(135deg,#14b8a6,#06b6d4)',
    'linear-gradient(135deg,#3b82f6,#6366f1)','linear-gradient(135deg,#ef4444,#f97316)',
  ];
  let h = 0;
  for (const c of u) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return gs[Math.abs(h) % gs.length];
}
function escHtml(s: string) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function timeAgoMs(iso: string) {
  const s = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
  if (s < 60)    return `${s}sn`;
  if (s < 3600)  return `${Math.floor(s/60)}dk`;
  if (s < 86400) return `${Math.floor(s/3600)}sa`;
  return `${Math.floor(s/86400)}g`;
}

// Mevcut kullanıcı avatar'ı
if (currentUserId && currentUserName) {
  cmMyAvatar.textContent = currentUserName[0].toUpperCase();
  cmMyAvatar.style.background = avatarBg(currentUsername);
}

// ── Yorum fonksiyonları
interface Comment { id: number; parent_id: number | null; user_id: number; content: string; created_at: string; display_name: string; username: string; }

let replyToId: number | null = null;

function renderComment(c: Comment, isReply = false): string {
  const bg    = avatarBg(c.username);
  const isOwn = currentUserId === c.user_id;
  const replyBtn = !isReply
    ? `<button class="cm-reply-btn" data-cm-id="${c.id}" data-username="${escHtml(c.username)}">Yanıtla</button>`
    : '';
  return `<div class="cm-item${isReply ? ' cm-reply' : ''}" data-cid="${c.id}">
    <a href="/u/${escHtml(c.username)}" class="cm-avatar" style="background:${bg}">${c.display_name[0].toUpperCase()}</a>
    <div class="cm-body">
      <span class="cm-author">${escHtml(c.display_name)}</span>
      <span class="cm-text">${escHtml(c.content)}</span>
      <div class="cm-time-row"><span class="cm-time">${timeAgoMs(c.created_at)}</span>${replyBtn}</div>
    </div>
    ${isOwn ? `<button class="cm-delete" data-id="${c.id}" title="Sil">×</button>` : ''}
  </div>`;
}

function renderAllComments(comments: Comment[]): string {
  const top = comments.filter(c => !c.parent_id);
  const repMap = new Map<number, Comment[]>();
  for (const c of comments) {
    if (c.parent_id) {
      if (!repMap.has(c.parent_id)) repMap.set(c.parent_id, []);
      repMap.get(c.parent_id)!.push(c);
    }
  }
  let html = '';
  for (const c of top) {
    html += renderComment(c, false);
    for (const r of repMap.get(c.id) ?? []) html += renderComment(r, true);
  }
  return html;
}

function attachDeleteListeners() {
  commentsList.querySelectorAll<HTMLButtonElement>('.cm-delete').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id!;
      const res = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
      if (res.ok) {
        btn.closest('.cm-item')?.remove();
        updateCommentCount(-1);
      }
    });
  });
}

function attachReplyListeners() {
  commentsList.querySelectorAll<HTMLButtonElement>('.cm-reply-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      replyToId = Number(btn.dataset.cmId);
      commentInput.value = `@${btn.dataset.username} `;
      commentInput.focus();
      // ipucu göster
      let hint = commentForm.querySelector('.cm-reply-hint');
      if (!hint) {
        hint = document.createElement('span');
        hint.className = 'cm-reply-hint';
        commentForm.insertBefore(hint, commentInput);
      }
      hint.textContent = `↩ yanıtlanıyor`;
    });
  });
}

function updateCommentCount(delta: number) {
  const cur = parseInt(cmCount.textContent ?? '0') || 0;
  const next = Math.max(0, cur + delta);
  cmCount.textContent = `${next} yorum`;
}

async function loadComments(postId: number) {
  commentsList.innerHTML = '<div class="cm-loading">Yükleniyor…</div>';
  try {
    const res  = await fetch(`/api/quick-facts/${postId}/comments`);
    const data = await res.json() as { comments: Comment[] };
    if (!data.comments.length) {
      commentsList.innerHTML = '<div class="cm-empty">Henüz yorum yok — ilk yorumu yaz!</div>';
    } else {
      commentsList.innerHTML = renderAllComments(data.comments);
      attachDeleteListeners();
      attachReplyListeners();
    }
    cmCount.textContent = `${data.comments.length} yorum`;
    setTimeout(() => { commentsList.scrollTop = commentsList.scrollHeight; }, 50);
  } catch {
    commentsList.innerHTML = '<div class="cm-empty">Yorumlar yüklenemedi.</div>';
  }
}

// Yorum gönder
commentForm.addEventListener('submit', async e => {
  e.preventDefault();
  if (!currentUserId) { window.location.href = '/login'; return; }
  const content = commentInput.value.trim();
  if (!content || !currentPostId) return;

  const parentId = replyToId;
  replyToId = null;
  commentInput.value = '';
  commentForm.querySelector('.cm-reply-hint')?.remove();

  try {
    const body: Record<string, unknown> = { content };
    if (parentId) body.parent_id = parentId;
    const res  = await fetch(`/api/quick-facts/${currentPostId}/comment`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json() as { comment: Comment };
    if (data.comment) {
      const cm = data.comment;
      commentsList.querySelector('.cm-empty, .cm-loading')?.remove();

      if (cm.parent_id) {
        const parentEl = commentsList.querySelector<HTMLElement>(`[data-cid="${cm.parent_id}"]`);
        let insertAfter: Element = parentEl ?? commentsList.lastElementChild!;
        let next = insertAfter?.nextElementSibling;
        while (next?.classList.contains('cm-reply')) { insertAfter = next; next = next.nextElementSibling; }
        insertAfter.insertAdjacentHTML('afterend', renderComment(cm, true));
      } else {
        commentsList.insertAdjacentHTML('beforeend', renderComment(cm, false));
      }

      attachDeleteListeners();
      attachReplyListeners();
      updateCommentCount(1);
      commentsList.scrollTop = commentsList.scrollHeight;
    }
  } catch { commentInput.value = content; }
});

// Modal aç — named so infinite-scroll can reuse it
function openPost(data: Record<string, string>) {
  const { id, type, src, caption, author, handle, likes, time } = data;
  currentPostId = Number(id);
  liked = false;

  if (type === 'video') {
    detailImg.style.display = 'none';
    detailVid.style.display = 'block';
    detailVid.src = src; detailVid.load();
  } else {
    detailVid.style.display = 'none'; detailVid.src = '';
    detailImg.style.display = 'block'; detailImg.src = src;
  }

  detailCaption.innerHTML = renderCaption(caption);
  detailAuthor.textContent  = author;
  detailHandle.textContent  = `@${handle}`;
  detailTime.textContent    = time;
  detailAvLink.textContent  = author[0].toUpperCase();
  detailAvLink.style.background = avatarBg(handle);
  detailAvLink.href         = `/u/${handle}`;
  detailLikes.textContent   = likes;
  likeIcon.setAttribute('fill', 'none');
  likeIcon.style.stroke = 'currentColor';
  detailLikeBtn.style.color = '';

  // Reset bookmark state
  bookmarked = false;
  detailBookmarkBtn.classList.remove('bookmarked');
  bookmarkIcon.setAttribute('fill', 'none');
  bookmarkIcon.setAttribute('stroke', 'currentColor');

  // Load bookmark state asynchronously (only if logged in)
  if (currentUserId) {
    fetch(`/api/quick-facts/${currentPostId}/bookmark`)
      .then(r => r.json())
      .then((d: { bookmarked: boolean }) => {
        bookmarked = d.bookmarked;
        if (bookmarked) {
          detailBookmarkBtn.classList.add('bookmarked');
          bookmarkIcon.setAttribute('fill', '#d4a564');
          bookmarkIcon.setAttribute('stroke', '#d4a564');
        }
      })
      .catch(() => {});
  }

  loadComments(currentPostId);
  onPostOpen?.(currentPostId);
  detailModal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function bindCell(cell: HTMLButtonElement) {
  cell.addEventListener('click', () => openPost(cell.dataset as Record<string, string>));
}

document.querySelectorAll<HTMLButtonElement>('.hb-cell').forEach(bindCell);

function closeDetail() {
  detailModal.style.display = 'none';
  detailVid.pause(); detailVid.src = '';
  document.body.style.overflow = '';
  onPostClose?.();
  currentPostId = null;
  commentInput.value = '';
}

closeDetailBtn.addEventListener('click', closeDetail);
detailModal.addEventListener('click', e => { if (e.target === detailModal) closeDetail(); });

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (detailModal.style.display !== 'none') closeDetail();
    if (uploadModal.style.display !== 'none') closeUpload();
  }
});

// Beğeni
detailLikeBtn.addEventListener('click', async () => {
  if (!currentPostId || liked) return;
  liked = true;
  likeIcon.setAttribute('fill', '#ef4444');
  likeIcon.style.stroke = '#ef4444';
  detailLikeBtn.style.color = '#ef4444';
  try {
    const res = await fetch(`/api/quick-facts/${currentPostId}/like`, { method: 'POST' });
    if (res.ok) {
      const data = await res.json() as { likes: number };
      detailLikes.textContent = String(data.likes);
      const cell = document.querySelector<HTMLButtonElement>(`.hb-cell[data-id="${currentPostId}"]`);
      if (cell) {
        cell.dataset.likes = String(data.likes);
        const likeEl = cell.querySelector('.hb-cell-likes');
        if (likeEl) likeEl.lastChild!.textContent = ' ' + data.likes;
      }
    }
  } catch { liked = false; }
});

// Bookmark
detailBookmarkBtn.addEventListener('click', async () => {
  if (!currentPostId) return;
  if (!currentUserId) { window.location.href = '/login'; return; }

  // Optimistic toggle
  bookmarked = !bookmarked;
  detailBookmarkBtn.classList.toggle('bookmarked', bookmarked);
  bookmarkIcon.setAttribute('fill', bookmarked ? '#d4a564' : 'none');
  bookmarkIcon.setAttribute('stroke', bookmarked ? '#d4a564' : 'currentColor');

  try {
    const res  = await fetch(`/api/quick-facts/${currentPostId}/bookmark`, { method: 'POST' });
    const data = await res.json() as { bookmarked: boolean };
    // Reconcile with server
    bookmarked = data.bookmarked;
    detailBookmarkBtn.classList.toggle('bookmarked', bookmarked);
    bookmarkIcon.setAttribute('fill', bookmarked ? '#d4a564' : 'none');
    bookmarkIcon.setAttribute('stroke', bookmarked ? '#d4a564' : 'currentColor');
  } catch {
    // Revert
    bookmarked = !bookmarked;
    detailBookmarkBtn.classList.toggle('bookmarked', bookmarked);
    bookmarkIcon.setAttribute('fill', bookmarked ? '#d4a564' : 'none');
    bookmarkIcon.setAttribute('stroke', bookmarked ? '#d4a564' : 'currentColor');
  }
});

// ── Infinite Scroll ──────────────────────────────────────────────────────────
const sentinel   = document.getElementById('feed-sentinel')!;
const feedLoader = document.getElementById('feed-loader') as HTMLElement;
const feedEnd    = document.getElementById('feed-end') as HTMLElement;
const hbGrid     = document.getElementById('hb-grid') as HTMLElement | null;

let nextCursor: string | null = sentinel.dataset.nextCursor || null;
let hasMore = sentinel.dataset.hasMore === 'true';
let loading = false;

function timeAgoMs2(iso: string) {
  const s = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
  if (s < 60)    return `${s}s`;
  if (s < 3600)  return `${Math.floor(s/60)}d`;
  if (s < 86400) return `${Math.floor(s/3600)}sa`;
  return `${Math.floor(s/86400)}g`;
}

function thumbUrlJs(url: string, w = 600, q = 75): string {
  if (!url || !url.includes('/object/public/')) return url;
  return url.replace('/object/public/', '/render/image/public/') + `?width=${w}&quality=${q}&format=webp`;
}

function makeCellHtml(post: any): string {
  const time = timeAgoMs2(post.created_at);
  const media = post.media_type === 'image'
    ? `<img src="${escHtml(thumbUrlJs(post.media_url))}" alt="${escHtml(post.caption)}" loading="lazy" decoding="async" class="cell-img">`
    : `<video muted preload="none" class="cell-vid" data-src="${escHtml(post.media_url)}"></video>`;
  const videoBadge = post.media_type === 'video'
    ? `<span class="hb-cell-video-badge"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg></span>`
    : '';
  return `<button
    class="hb-cell"
    data-id="${post.id}"
    data-type="${escHtml(post.media_type)}"
    data-src="${escHtml(post.media_url)}"
    data-caption="${escHtml(post.caption)}"
    data-author="${escHtml(post.display_name ?? '')}"
    data-handle="${escHtml(post.username ?? '')}"
    data-likes="${post.likes ?? 0}"
    data-time="${time}"
    aria-label="${escHtml(post.caption)}"
  >
    ${media}
    <div class="hb-cell-overlay">
      <span class="hb-cell-likes">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        ${post.likes ?? 0}
      </span>
      ${videoBadge}
    </div>
  </button>`;
}

async function loadMore() {
  if (loading || !hasMore || !hbGrid || !nextCursor) return;
  loading = true;
  feedLoader.hidden = false;

  try {
    const res  = await fetch(`/api/feed?cursor=${encodeURIComponent(nextCursor)}&limit=12`);
    const data = await res.json() as { posts: any[]; nextCursor: string | null; hasMore: boolean };

    if (data.posts.length) {
      const frag = document.createDocumentFragment();
      const tmp  = document.createElement('div');
      tmp.innerHTML = data.posts.map(makeCellHtml).join('');
      tmp.querySelectorAll<HTMLButtonElement>('.hb-cell').forEach(cell => {
        bindCell(cell);
        frag.appendChild(cell);
      });
      hbGrid.appendChild(frag);
      initBlurUp(hbGrid);
      initVideoLazy(hbGrid);
    }

    nextCursor = data.nextCursor;
    hasMore    = data.hasMore;

    if (!hasMore) {
      feedEnd.hidden = false;
      observer.disconnect();
    }
  } catch {
    // silent fail — user can scroll again to retry
  } finally {
    loading = false;
    feedLoader.hidden = true;
  }
}

const observer = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) loadMore();
}, { rootMargin: '200px' });

if (hasMore && hbGrid) {
  observer.observe(sentinel);
} else {
  feedEnd.hidden = false;
}

// ── Görsel optimizasyon ──────────────────────────────────────────────────────

// Blur-up: img yüklenince .loaded + .media-loaded ekle
function initBlurUp(root: ParentNode = document) {
  root.querySelectorAll<HTMLImageElement>('.cell-img').forEach(img => {
    if (img.complete && img.naturalWidth > 0) {
      img.classList.add('loaded');
      img.closest('.hb-cell')?.classList.add('media-loaded');
    } else {
      img.addEventListener('load', () => {
        img.classList.add('loaded');
        img.closest('.hb-cell')?.classList.add('media-loaded');
      }, { once: true });
      img.addEventListener('error', () => {
        img.closest('.hb-cell')?.classList.add('media-loaded');
      }, { once: true });
    }
  });
}

// Video lazy: viewport'a girince preload="metadata" + src ata
const videoObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    const video = entry.target as HTMLVideoElement;
    if (entry.isIntersecting) {
      if (!video.src && video.dataset.src) {
        video.src = video.dataset.src;
        video.preload = 'metadata';
      }
      video.classList.add('loaded');
      video.closest('.hb-cell')?.classList.add('media-loaded');
    }
  });
}, { rootMargin: '200px' });

function initVideoLazy(root: ParentNode = document) {
  root.querySelectorAll<HTMLVideoElement>('.cell-vid').forEach(v => videoObserver.observe(v));
}

initBlurUp();
initVideoLazy();

// ── Realtime ─────────────────────────────────────────────────────────────────
const newPostsBar   = document.getElementById('new-posts-bar') as HTMLElement;
const newPostsBtn   = document.getElementById('new-posts-btn') as HTMLButtonElement;
const newPostsLabel = document.getElementById('new-posts-label') as HTMLElement;
let pendingNewPosts = 0;

// 1. Yeni gönderi — INSERT
supa
  .channel('feed-new-posts')
  .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'quick_facts' }, () => {
    pendingNewPosts++;
    newPostsLabel.textContent =
      pendingNewPosts === 1 ? 'Yeni gönderi var' : `${pendingNewPosts} yeni gönderi var`;
    newPostsBar.hidden = false;
  })
  .subscribe();

// Banner'a tıklayınca feed'i baştan yükle
newPostsBtn.addEventListener('click', async () => {
  newPostsBar.hidden = true;
  pendingNewPosts = 0;
  feedLoader.hidden = false;
  try {
    const res  = await fetch('/api/feed?limit=12');
    const data = await res.json() as { posts: any[]; nextCursor: string | null; hasMore: boolean };
    if (hbGrid && data.posts.length) {
      hbGrid.innerHTML = data.posts.map(makeCellHtml).join('');
      hbGrid.querySelectorAll<HTMLButtonElement>('.hb-cell').forEach(bindCell);
    }
    nextCursor = data.nextCursor;
    hasMore    = data.hasMore;
    feedEnd.hidden = hasMore;
    if (hasMore) observer.observe(sentinel); else observer.disconnect();
  } finally {
    feedLoader.hidden = true;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
});

// 2. Beğeni sayısı — quick_facts UPDATE
supa
  .channel('feed-likes')
  .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'quick_facts' }, (payload: any) => {
    const { id, likes } = payload.new as { id: number; likes: number };
    const cell = document.querySelector<HTMLButtonElement>(`.hb-cell[data-id="${id}"]`);
    if (!cell) return;
    cell.dataset.likes = String(likes);
    const likeEl = cell.querySelector('.hb-cell-likes');
    if (likeEl) likeEl.childNodes[likeEl.childNodes.length - 1].textContent = ' ' + likes;
    // Açık modal da güncelle
    if (currentPostId === id) detailLikes.textContent = String(likes);
  })
  .subscribe();

// 3. Canlı yorumlar — açık post için comments INSERT
let commentChannel: ReturnType<typeof supa.channel> | null = null;

onPostOpen = (postId: number) => {
  commentChannel?.unsubscribe();
  commentChannel = supa
    .channel(`comments-post-${postId}`)
    .on(
      'postgres_changes',
      { event: 'INSERT', schema: 'public', table: 'comments', filter: `post_id=eq.${postId}` },
      (payload: any) => {
        const c = payload.new as { id: number; user_id: number };
        if (c.user_id === currentUserId) return; // form submit zaten ekledi
        // display_name payload'da yok, tüm listeyi güncelle
        fetch(`/api/quick-facts/${postId}/comments`)
          .then(r => r.json())
          .then((data: { comments: Comment[] }) => {
            const found = data.comments.find(x => x.id === c.id);
            if (!found) return;
            const empty = commentsList.querySelector('.cm-empty, .cm-loading');
            if (empty) empty.remove();
            commentsList.insertAdjacentHTML('beforeend', renderComment(found));
            attachDeleteListeners();
            updateCommentCount(1);
            commentsList.scrollTop = commentsList.scrollHeight;
          });
      }
    )
    .subscribe();
};

onPostClose = () => {
  commentChannel?.unsubscribe();
  commentChannel = null;
};
} // end initAkis

document.addEventListener('astro:page-load', initAkis);
</script>
