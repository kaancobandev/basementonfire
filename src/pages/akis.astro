// Bookmark
detailBookmarkBtn.addEventListener('click', async () => {
  if (!currentPostId) return;
  if (!currentUserId) { window.location.href = '/login'; return; }

  // Optimistic toggle
  bookmarked = !bookmarked;
  detailBookmarkBtn.classList.toggle('bookmarked', bookmarked);
  bookmarkIcon.setAttribute('fill', bookmarked ? '#d4a564' : 'none');
  bookmarkIcon.setAttribute('stroke', bookmarked ? '#d4a564' : 'currentColor');

  try {
    const res  = await fetch(`/api/quick-facts/${currentPostId}/bookmark`, { method: 'POST' });
    const data = await res.json() as { bookmarked: boolean };
    // Reconcile with server
    bookmarked = data.bookmarked;
    detailBookmarkBtn.classList.toggle('bookmarked', bookmarked);
    bookmarkIcon.setAttribute('fill', bookmarked ? '#d4a564' : 'none');
    bookmarkIcon.setAttribute('stroke', bookmarked ? '#d4a564' : 'currentColor');
  } catch {
    // Revert
    bookmarked = !bookmarked;
    detailBookmarkBtn.classList.toggle('bookmarked', bookmarked);
    bookmarkIcon.setAttribute('fill', bookmarked ? '#d4a564' : 'none');
    bookmarkIcon.setAttribute('stroke', bookmarked ? '#d4a564' : 'currentColor');
  }
});

// ── Infinite Scroll ──────────────────────────────────────────────────────────
const sentinel   = document.getElementById('feed-sentinel')!;
const feedLoader = document.getElementById('feed-loader') as HTMLElement;
const feedEnd    = document.getElementById('feed-end') as HTMLElement;
const hbGrid     = document.getElementById('hb-grid') as HTMLElement | null;

let nextCursor: string | null = sentinel.dataset.nextCursor || null;
let hasMore = sentinel.dataset.hasMore === 'true';
let loading = false;

function timeAgoMs2(iso: string) {
  const s = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
  if (s < 60)    return `${s}s`;
  if (s < 3600)  return `${Math.floor(s/60)}d`;
  if (s < 86400) return `${Math.floor(s/3600)}sa`;
  return `${Math.floor(s/86400)}g`;
}

function thumbUrlJs(url: string, w = 600, q = 75): string {
  if (!url || !url.includes('/object/public/')) return url;
  return url.replace('/object/public/', '/render/image/public/') + `?width=${w}&quality=${q}&format=webp`;
}

function makeCellHtml(post: any): string {
  const time = timeAgoMs2(post.created_at);
  const media = post.media_type === 'image'
    ? `<img src="${escHtml(thumbUrlJs(post.media_url))}" alt="${escHtml(post.caption)}" loading="lazy" decoding="async" class="cell-img">`
    : `<video muted preload="none" class="cell-vid" data-src="${escHtml(post.media_url)}"></video>`;
  const videoBadge = post.media_type === 'video'
    ? `<span class="hb-cell-video-badge"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg></span>`
    : '';
  return `<button
    class="hb-cell"
    data-id="${post.id}"
    data-type="${escHtml(post.media_type)}"
    data-src="${escHtml(post.media_url)}"
    data-caption="${escHtml(post.caption)}"
    data-author="${escHtml(post.display_name ?? '')}"
    data-handle="${escHtml(post.username ?? '')}"
    data-likes="${post.likes ?? 0}"
    data-time="${time}"
    aria-label="${escHtml(post.caption)}"
  >
    ${media}
    <div class="hb-cell-overlay">
      <span class="hb-cell-likes">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        ${post.likes ?? 0}
      </span>
      ${videoBadge}
    </div>
  </button>`;
}

async function loadMore() {
  if (loading || !hasMore || !hbGrid || !nextCursor) return;
  loading = true;
  feedLoader.hidden = false;

  try {
    const res  = await fetch(`/api/feed?cursor=${encodeURIComponent(nextCursor)}&limit=12`);
    const data = await res.json() as { posts: any[]; nextCursor: string | null; hasMore: boolean };

    if (data.posts.length) {
      const frag = document.createDocumentFragment();
      const tmp  = document.createElement('div');
      tmp.innerHTML = data.posts.map(makeCellHtml).join('');
      tmp.querySelectorAll<HTMLButtonElement>('.hb-cell').forEach(cell => {
        bindCell(cell);
        frag.appendChild(cell);
      });
      hbGrid.appendChild(frag);
      initBlurUp(hbGrid);
      initVideoLazy(hbGrid);
    }

    nextCursor = data.nextCursor;
    hasMore    = data.hasMore;

    if (!hasMore) {
      feedEnd.hidden = false;
      observer.disconnect();
    }
  } catch {
    // silent fail — user can scroll again to retry
  } finally {
    loading = false;
    feedLoader.hidden = true;
  }
}

const observer = new IntersectionObserver(entries => {
  if (entries[0].isIntersecting) loadMore();
}, { rootMargin: '200px' });

if (hasMore && hbGrid) {
  observer.observe(sentinel);
} else {
  feedEnd.hidden = false;
}

// ── Görsel optimizasyon ──────────────────────────────────────────────────────

// Blur-up: img yüklenince .loaded + .media-loaded ekle
function initBlurUp(root: ParentNode = document) {
  root.querySelectorAll<HTMLImageElement>('.cell-img').forEach(img => {
    if (img.complete && img.naturalWidth > 0) {
      img.classList.add('loaded');
      img.closest('.hb-cell')?.classList.add('media-loaded');
    } else {
      img.addEventListener('load', () => {
        img.classList.add('loaded');
        img.closest('.hb-cell')?.classList.add('media-loaded');
      }, { once: true });
      img.addEventListener('error', () => {
        img.closest('.hb-cell')?.classList.add('media-loaded');
      }, { once: true });
    }
  });
}

// Video lazy: viewport'a girince preload="metadata" + src ata
const videoObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    const video = entry.target as HTMLVideoElement;
    if (entry.isIntersecting) {
      if (!video.src && video.dataset.src) {
        video.src = video.dataset.src;
        video.preload = 'metadata';
      }
      video.classList.add('loaded');
      video.closest('.hb-cell')?.classList.add('media-loaded');
    }
  });
}, { rootMargin: '200px' });

function initVideoLazy(root: ParentNode = document) {
  root.querySelectorAll<HTMLVideoElement>('.cell-vid').forEach(v => videoObserver.observe(v));
}

initBlurUp();
initVideoLazy();

// ── Realtime ─────────────────────────────────────────────────────────────────
import { supa } from '../lib/supabase-browser';

const newPostsBar   = document.getElementById('new-posts-bar') as HTMLElement;
const newPostsBtn   = document.getElementById('new-posts-btn') as HTMLButtonElement;
const newPostsLabel = document.getElementById('new-posts-label') as HTMLElement;
let pendingNewPosts = 0;

// 1. Yeni gönderi — INSERT
supa
  .channel('feed-new-posts')
  .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'quick_facts' }, () => {
    pendingNewPosts++;
    newPostsLabel.textContent =
      pendingNewPosts === 1 ? 'Yeni gönderi var' : `${pendingNewPosts} yeni gönderi var`;
    newPostsBar.hidden = false;
  })
  .subscribe();

// Banner'a tıklayınca feed'i baştan yükle
newPostsBtn.addEventListener('click', async () => {
  newPostsBar.hidden = true;
  pendingNewPosts = 0;
  feedLoader.hidden = false;
  try {
    const res  = await fetch('/api/feed?limit=12');
    const data = await res.json() as { posts: any[]; nextCursor: string | null; hasMore: boolean };
    if (hbGrid && data.posts.length) {
      hbGrid.innerHTML = data.posts.map(makeCellHtml).join('');
      hbGrid.querySelectorAll<HTMLButtonElement>('.hb-cell').forEach(bindCell);
    }
    nextCursor = data.nextCursor;
    hasMore    = data.hasMore;
    feedEnd.hidden = hasMore;
    if (hasMore) observer.observe(sentinel); else observer.disconnect();
  } finally {
    feedLoader.hidden = true;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
});

// 2. Beğeni sayısı — quick_facts UPDATE
supa
  .channel('feed-likes')
  .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'quick_facts' }, (payload: any) => {
    const { id, likes } = payload.new as { id: number; likes: number };
    const cell = document.querySelector<HTMLButtonElement>(`.hb-cell[data-id="${id}"]`);
    if (!cell) return;
    cell.dataset.likes = String(likes);
    const likeEl = cell.querySelector('.hb-cell-likes');
    if (likeEl) likeEl.childNodes[likeEl.childNodes.length - 1].textContent = ' ' + likes;
    // Açık modal da güncelle
    if (currentPostId === id) detailLikes.textContent = String(likes);
  })
  .subscribe();

// 3. Canlı yorumlar — açık post için comments INSERT
let commentChannel: ReturnType<typeof supa.channel> | null = null;

onPostOpen = (postId: number) => {
  commentChannel?.unsubscribe();
  commentChannel = supa
    .channel(`comments-post-${postId}`)
    .on(
      'postgres_changes',
      { event: 'INSERT', schema: 'public', table: 'comments', filter: `post_id=eq.${postId}` },
      (payload: any) => {
        const c = payload.new as { id: number; user_id: number };
        if (c.user_id === currentUserId) return; // form submit zaten ekledi
        // display_name payload'da yok, tüm listeyi güncelle
        fetch(`/api/quick-facts/${postId}/comments`)
          .then(r => r.json())
          .then((data: { comments: Comment[] }) => {
            const found = data.comments.find(x => x.id === c.id);
            if (!found) return;
            const empty = commentsList.querySelector('.cm-empty, .cm-loading');
            if (empty) empty.remove();
            commentsList.insertAdjacentHTML('beforeend', renderComment(found));
            attachDeleteListeners();
            updateCommentCount(1);
            commentsList.scrollTop = commentsList.scrollHeight;
          });
      }
    )
    .subscribe();
};

onPostClose = () => {
  commentChannel?.unsubscribe();
  commentChannel = null;
};

// ── Stories ───────────────────────────────────────────────────────────────────
const storyDataEl = document.getElementById('story-data');
const storyData   = storyDataEl ? JSON.parse(storyDataEl.textContent ?? '{}') : {};
const allStoryUsers: StoryUserJS[] = [
  ...(storyData.ownStoryUser ? [storyData.ownStoryUser] : []),
  ...(storyData.otherStoryUsers ?? []),
];
const myIdStory: number | null = storyData.myId ?? null;

interface StoryItemJS  { id: number; mediaUrl: string; mediaType: string; createdAt: string; }
interface StoryUserJS  { userId: number; username: string; displayName: string; avatar: string | null; stories: StoryItemJS[]; }

// Viewed tracking via localStorage
function getViewed(): Set<number> {
  try { return new Set(JSON.parse(localStorage.getItem('sv_viewed') ?? '[]')); } catch { return new Set(); }
}
function markViewed(id: number) {
  const s = getViewed(); s.add(id);
  localStorage.setItem('sv_viewed', JSON.stringify([...s]));
}

// ── Story Viewer ─────────────────────────────────────────────────────────────
const viewer   = document.getElementById('story-viewer') as HTMLElement;
const svBg     = document.getElementById('sv-bg') as HTMLElement;
const svBars   = document.getElementById('sv-bars') as HTMLElement;
const svMetaAv = document.getElementById('sv-meta-av') as HTMLElement;
const svMetaNm = document.getElementById('sv-meta-name') as HTMLElement;
const svMetaTm = document.getElementById('sv-meta-time') as HTMLElement;
const svImg    = document.getElementById('sv-img') as HTMLImageElement;
const svVid    = document.getElementById('sv-vid') as HTMLVideoElement;
const svClose  = document.getElementById('sv-close') as HTMLButtonElement;
const svPrev   = document.getElementById('sv-prev') as HTMLElement;
const svNext   = document.getElementById('sv-next') as HTMLElement;

let svUserIdx  = 0;
let svStoryIdx = 0;
let svTimer: ReturnType<typeof setTimeout> | null = null;
let svAnimFrame: number | null = null;

function timeAgoStory(iso: string) {
  const s = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
  if (s < 60) return `${s}sn`;
  if (s < 3600) return `${Math.floor(s / 60)}dk`;
  return `${Math.floor(s / 3600)}sa`;
}

function avatarBgJs2(u: string) {
  const gs = ['linear-gradient(135deg,#667eea,#764ba2)','linear-gradient(135deg,#f093fb,#f5576c)','linear-gradient(135deg,#4facfe,#00f2fe)','linear-gradient(135deg,#43e97b,#38f9d7)','linear-gradient(135deg,#fa709a,#fee140)','linear-gradient(135deg,#a18cd1,#fbc2eb)','linear-gradient(135deg,#fda085,#f6d365)','linear-gradient(135deg,#96fbc4,#f9f586)'];
  let h = 0;
  for (const c of u) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return gs[Math.abs(h) % gs.length];
}

function clearSvTimer() {
  if (svTimer) { clearTimeout(svTimer); svTimer = null; }
  if (svAnimFrame) { cancelAnimationFrame(svAnimFrame); svAnimFrame = null; }
}

function showStory(userIdx: number, storyIdx: number) {
  clearSvTimer();
  svUserIdx  = userIdx;
  svStoryIdx = storyIdx;

  const u = allStoryUsers[userIdx];
  const s = u.stories[storyIdx];

  markViewed(s.id);

  // Meta
  if (u.avatar) {
    svMetaAv.innerHTML = `<img src="${escHtml(u.avatar)}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
  } else {
    svMetaAv.style.background = avatarBgJs2(u.username);
    svMetaAv.textContent = u.displayName[0].toUpperCase();
  }
  svMetaNm.textContent = u.displayName;
  svMetaTm.textContent = timeAgoStory(s.createdAt);

  // Background blur
  if (s.mediaType === 'image') svBg.style.backgroundImage = `url(${s.mediaUrl})`;

  // Media
  svImg.style.display = 'none';
  svVid.style.display = 'none';
  svVid.pause();

  if (s.mediaType === 'video') {
    svVid.src = s.mediaUrl;
    svVid.style.display = 'block';
    svVid.load();
    svVid.play().catch(() => {});
  } else {
    svImg.src = s.mediaUrl;
    svImg.style.display = 'block';
  }

  // Progress bars
  svBars.innerHTML = u.stories.map((_, i) => `
    <div class="sv-bar ${i < storyIdx ? 'done' : i === storyIdx ? 'active' : ''}" style="--dur:${s.mediaType === 'video' ? '15s' : '5s'}">
      <div class="sv-bar-fill"></div>
    </div>`).join('');

  // Auto-advance
  const dur = s.mediaType === 'video' ? 15000 : 5000;
  svTimer = setTimeout(() => advanceStory(1), dur);
}

function advanceStory(dir: 1 | -1) {
  const u = allStoryUsers[svUserIdx];
  const nextStory = svStoryIdx + dir;

  if (nextStory >= 0 && nextStory < u.stories.length) {
    showStory(svUserIdx, nextStory);
    return;
  }
  // Next/prev user
  const nextUser = svUserIdx + dir;
  if (nextUser >= 0 && nextUser < allStoryUsers.length) {
    const startStory = dir === 1 ? 0 : allStoryUsers[nextUser].stories.length - 1;
    showStory(nextUser, startStory);
    return;
  }
  // No more stories
  closeViewer();
}

function openViewer(userIdx: number) {
  if (allStoryUsers.length === 0) return;
  viewer.style.display = 'flex';
  document.body.style.overflow = 'hidden';
  showStory(userIdx, 0);
}

function closeViewer() {
  clearSvTimer();
  viewer.style.display = 'none';
  document.body.style.overflow = '';
  svVid.pause(); svVid.src = '';
  svImg.src = '';
}

svClose.addEventListener('click', closeViewer);
svPrev.addEventListener('click', () => advanceStory(-1));
svNext.addEventListener('click', () => advanceStory(1));
viewer.addEventListener('click', e => { if (e.target === viewer) closeViewer(); });

document.addEventListener('keydown', e => {
  if (viewer.style.display === 'none') return;
  if (e.key === 'ArrowRight') advanceStory(1);
  if (e.key === 'ArrowLeft')  advanceStory(-1);
  if (e.key === 'Escape')     closeViewer();
});

// Story bar click — diğer kullanıcılar
document.querySelectorAll<HTMLButtonElement>('.story-item[data-story-idx]').forEach(btn => {
  btn.addEventListener('click', () => {
    const ownOffset = storyData.ownStoryUser ? 1 : 0;
    const idx = parseInt(btn.dataset.storyIdx!) + ownOffset;
    openViewer(idx);
  });
});

// ── Story Create ──────────────────────────────────────────────────────────────
const createModal  = document.getElementById('story-create-modal') as HTMLElement;
const createClose  = document.getElementById('story-create-close') as HTMLButtonElement;
const storyDrop    = document.getElementById('story-drop') as HTMLElement;
const storyFile    = document.getElementById('story-file') as HTMLInputElement;
const storyPrevImg = document.getElementById('story-prev-img') as HTMLImageElement;
const storyPrevVid = document.getElementById('story-prev-vid') as HTMLVideoElement;
const storyDropPh  = document.getElementById('story-drop-placeholder') as HTMLElement;
const storyDropPv  = document.getElementById('story-drop-preview') as HTMLElement;
const storyError   = document.getElementById('story-error') as HTMLElement;
const storySubmit  = document.getElementById('story-submit-btn') as HTMLButtonElement;
const ownBtn       = document.getElementById('story-own-btn') as HTMLButtonElement | null;

ownBtn?.addEventListener('click', () => {
  if (ownBtn.dataset.hasStory === 'true') {
    // kendi hikayesini göster
    openViewer(0);
  } else {
    openCreateModal();
  }
});

function openCreateModal() {
  createModal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeCreateModal() {
  createModal.style.display = 'none';
  document.body.style.overflow = '';
  clearStoryFile();
  storyError.style.display = 'none';
}

createClose.addEventListener('click', closeCreateModal);
createModal.addEventListener('click', e => { if (e.target === createModal) closeCreateModal(); });

storyDrop.addEventListener('click', e => {
  if ((e.target as HTMLElement).closest('video,button')) return;
  storyFile.click();
});
storyDrop.addEventListener('dragover',  e => { e.preventDefault(); storyDrop.classList.add('drag-over'); });
storyDrop.addEventListener('dragleave', () => storyDrop.classList.remove('drag-over'));
storyDrop.addEventListener('drop', e => {
  e.preventDefault(); storyDrop.classList.remove('drag-over');
  const f = e.dataTransfer?.files[0];
  if (f) applyStoryFile(f);
});
storyFile.addEventListener('change', () => { if (storyFile.files?.[0]) applyStoryFile(storyFile.files[0]); });

function applyStoryFile(file: File) {
  const url = URL.createObjectURL(file);
  const isVid = file.type.startsWith('video/');
  storyPrevImg.style.display = isVid ? 'none' : 'block';
  storyPrevVid.style.display = isVid ? 'block' : 'none';
  if (isVid) storyPrevVid.src = url;
  else       storyPrevImg.src = url;
  storyDropPh.style.display = 'none';
  storyDropPv.style.display = 'block';
  storySubmit.disabled = false;
}

function clearStoryFile() {
  storyFile.value = '';
  storyPrevImg.src = '';
  storyPrevVid.src = '';
  storyDropPv.style.display = 'none';
  storyDropPh.style.display = 'flex';
  storySubmit.disabled = true;
}

storySubmit.addEventListener('click', async () => {
  const file = storyFile.files?.[0];
  if (!file) return;

  storySubmit.disabled = true;
  storySubmit.textContent = 'Yükleniyor…';
  storyError.style.display = 'none';

  const fd = new FormData();
  fd.append('media', file);

  try {
    const res  = await fetch('/api/stories/create', { method: 'POST', body: fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error ?? 'Hata');
    closeCreateModal();
    // Ring'i güncelle
    if (ownBtn) {
      ownBtn.dataset.hasStory = 'true';
      const ring = ownBtn.querySelector('.story-ring');
      ring?.classList.remove('add-story');
      ring?.classList.add('has-story');
      const plus = ownBtn.querySelector('.story-plus');
      plus?.remove();
      const label = ownBtn.querySelector('.story-label');
      if (label) label.textContent = 'Hikayem';

      // Yeni hikayeyi allStoryUsers'a ekle
      if (allStoryUsers[0]?.userId === myIdStory) {
        allStoryUsers[0].stories.unshift({ id: data.story.id, mediaUrl: data.story.media_url, mediaType: data.story.media_type, createdAt: data.story.created_at });
      }
    }
  } catch (e: any) {
    storyError.textContent = e.message;
    storyError.style.display = 'block';
    storySubmit.disabled = false;
    storySubmit.textContent = 'Hikayeyi Paylaş';
  }
});
</script>
