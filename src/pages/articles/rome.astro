  .r-figure-role { font-size:0.72rem; color:var(--r-muted); margin-bottom:10px; }
  .r-figure-desc { font-size:0.78rem; color:#8a7a5a; line-height:1.7; }

  /* ── COLOSSEUM CARD ──────────────────────────────────── */
  .r-colosseum {
    border-radius: 16px;
    padding: 28px 24px;
    text-align: center;
  }
  .r-col-arch { font-size: 4rem; animation: r-glow 3s infinite; }
  @keyframes r-glow { 0%,100%{filter:drop-shadow(0 0 0 rgba(197,160,40,0))} 50%{filter:drop-shadow(0 0 12px rgba(197,160,40,0.5))} }
  .r-col-facts { display:flex; flex-direction:column; gap:6px; margin-top:16px; }
  .r-col-facts span { font-size:0.8rem; color:var(--r-muted); }

  /* ── QUİZ ─────────────────────────────────────────────── */
  .r-q-counter { font-family:'Cinzel',serif; font-size:0.78rem; color:var(--r-gold); letter-spacing:2px; }
  .r-qdot { width:10px; height:10px; border-radius:50%; background:rgba(197,160,40,0.2); transition:background 0.3s; }
  .r-qdot.active  { background: var(--r-gold); }
  .r-qdot.correct { background: #22c55e; }
  .r-qdot.wrong   { background: #ef4444; }
  .r-qtext { font-size:1rem; font-weight:600; color:#e8dfc8; margin-bottom:20px; line-height:1.65; }
  .r-qopts { display:flex; flex-direction:column; gap:10px; }
  .r-qopt {
    width: 100%;
    text-align: left;
    padding: 13px 18px;
    border: 1px solid rgba(197,160,40,0.2);
    border-radius: 10px;
    background: rgba(197,160,40,0.03);
    color: #c8b99a;
    cursor: pointer;
    font-size: 0.9rem;
    font-family: inherit;
    transition: background 0.15s, border-color 0.15s, transform 0.1s;
  }
  .r-qopt:hover:not([disabled]) {
    background: rgba(197,160,40,0.1);
    border-color: var(--r-gold);
    transform: translateX(4px);
  }
  .r-qopt[disabled] { cursor: default; }
  .r-qopt.correct { background: rgba(34,197,94,0.15) !important; border-color:#22c55e !important; color:#86efac; }
  .r-qopt.wrong   { background: rgba(239,68,68,0.15) !important; border-color:#ef4444 !important; color:#fca5a5; }

  .r-btn {
    background: var(--r-gold);
    color: #0f0c08;
    border: none;
    border-radius: 24px;
    padding: 10px 28px;
    font-weight: 700;
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    letter-spacing: 1px;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .r-btn:hover { opacity: 0.85; }

  /* ── FOOTER ──────────────────────────────────────────── */
  .r-footer {
    background: #0a0806;
    border-top: 1px solid var(--r-border);
    text-align: center;
    padding: 40px 24px;
    font-family: 'Cinzel', serif;
    color: var(--r-muted);
    font-size: 0.85rem;
  }
  .r-footer-eagle { font-size: 2.5rem; margin-bottom: 8px; opacity: 0.4; }
  .r-footer-spqr { letter-spacing: 6px; font-size: 0.75rem; color: var(--r-gold); margin-bottom: 12px; }

  /* ── REVEAL ──────────────────────────────────────────── */
  .reveal { opacity:0; transform:translateY(30px); transition:opacity 0.7s ease-out, transform 0.7s ease-out; }
  .reveal.visible { opacity:1; transform:translateY(0); }

  /* ── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width:760px) {
    .r-two-col, .r-vs-row   { grid-template-columns: 1fr; }
    .r-figures-grid          { grid-template-columns: repeat(2,1fr); }
    .r-era-nav               { display: none; }
    .r-hero-stats            { gap: 20px; }
    .r-vs-label              { display: none; }
  }
  @media (max-width:480px) {
    .r-figures-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
// ── PARÇACIKLAR ───────────────────────────────────────────────────────────────
const container = document.getElementById('r-particles')!;
for (let i = 0; i < 30; i++) {
  const el = document.createElement('div');
  el.className = 'r-particle';
  const size = Math.random() * 4 + 1;
  el.style.cssText = `
    width:${size}px; height:${size}px;
    left:${Math.random()*100}%;
    top:${Math.random()*100}%;
    --dur:${Math.random()*8+4}s;
    --delay:-${Math.random()*8}s;
  `;
  container.appendChild(el);
}

// ── SAYAÇLAR ─────────────────────────────────────────────────────────────────
function countUp(el: HTMLElement, target: number, dur = 1800) {
  const start = performance.now();
  const update = (now: number) => {
    const t = Math.min((now - start) / dur, 1);
    const ease = 1 - Math.pow(1 - t, 3);
    el.textContent = Math.floor(ease * target).toLocaleString('tr');
    if (t < 1) requestAnimationFrame(update);
  };
  requestAnimationFrame(update);
}

const heroObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      document.querySelectorAll<HTMLElement>('.r-stat-num').forEach(el => {
        countUp(el, parseInt(el.dataset.target!));
      });
      heroObs.disconnect();
    }
  });
}, { threshold: 0.3 });

const heroStats = document.querySelector('.r-hero-stats');
if (heroStats) heroObs.observe(heroStats);

// ── SCROLL REVEAL ─────────────────────────────────────────────────────────────
const revObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal, .r-tablet, .r-cstep').forEach(el => revObs.observe(el));

// ── ERA NAV AKTIF ─────────────────────────────────────────────────────────────
const sections = ['krallik', 'cumhuriyet', 'imparatorluk'].map(id => document.getElementById(id)!);
const eraObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const id = e.target.id;
      document.querySelectorAll('.r-era-btn').forEach(b => {
        (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.section === id);
      });
    }
  });
}, { threshold: 0.4 });
sections.forEach(s => eraObs.observe(s));

// ── TABLET ACCORDION ──────────────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.r-tablet-header').forEach(btn => {
  btn.addEventListener('click', () => {
    const idx = btn.dataset.idx!;
    const body  = document.getElementById(`tablet-body-${idx}`)!;
    const arrow = btn.querySelector('.r-tablet-arrow')!;
    const open  = body.style.display !== 'none';
    body.style.display  = open ? 'none' : 'block';
    arrow.classList.toggle('open', !open);
  });
});

// ── QUİZ ─────────────────────────────────────────────────────────────────────
const CORRECT_R = [1, 2, 2, 2]; // dişi kurt, forum romanum, iç savaş, köleler
const TOTAL_R   = 4;
let rQ = 0, rScore = 0;

function rShowQ(n: number) {
  for (let i = 0; i < TOTAL_R; i++) {
    (document.getElementById(`r-question-${i}`) as HTMLElement).style.display = i === n ? 'block' : 'none';
  }
  (document.getElementById('r-q-counter') as HTMLElement).textContent = `SORU ${n+1} / ${TOTAL_R}`;
  rUpdateDots();
}

function rUpdateDots(idx?: number, ok?: boolean) {
  for (let i = 0; i < TOTAL_R; i++) {
    const dot = document.getElementById(`r-dot-${i}`) as HTMLElement;
    dot.className = 'r-qdot';
    if (i === rQ && idx === undefined) dot.classList.add('active');
    else if (i < rQ) {
      const res = dot.dataset.result;
      if (res) dot.classList.add(res);
    }
  }
  if (idx !== undefined) {
    const dot = document.getElementById(`r-dot-${idx}`) as HTMLElement;
    dot.dataset.result = ok ? 'correct' : 'wrong';
    dot.className = `r-qdot ${ok ? 'correct' : 'wrong'}`;
  }
}

document.querySelectorAll<HTMLButtonElement>('.r-qopt').forEach(btn => {
  btn.addEventListener('click', () => {
    const q = parseInt(btn.dataset.q!);
    if (q !== rQ) return;
    const sel = parseInt(btn.dataset.i!);
    const ok  = sel === CORRECT_R[q];
    if (ok) rScore++;

    document.querySelectorAll<HTMLButtonElement>(`.r-qopt[data-q="${q}"]`).forEach((b, i) => {
      b.setAttribute('disabled', 'true');
      if (i === CORRECT_R[q]) b.classList.add('correct');
      else if (b === btn)     b.classList.add('wrong');
    });
    rUpdateDots(q, ok);

    setTimeout(() => {
      rQ++;
      if (rQ < TOTAL_R) rShowQ(rQ);
      else rShowResult();
    }, 850);
  });
});

function rShowResult() {
  document.getElementById('r-q-progress')!.style.display = 'none';
  for (let i = 0; i < TOTAL_R; i++) (document.getElementById(`r-question-${i}`) as HTMLElement).style.display = 'none';
  document.getElementById('r-result')!.style.display = 'block';

  const data = [
    { icon:'⚔️', title:'Gladyatör Adayı!',   desc:'Henüz Forum Romanum\'a girmek için biraz daha çalışman gerekiyor.' },
    { icon:'🛡️', title:'Lejyon Askeri',       desc:`${TOTAL_R} sorudan ${rScore} doğru. İyi bir başlangıç!` },
    { icon:'🏛️', title:'Roma Vatandaşı',     desc:`${TOTAL_R} sorudan ${rScore} doğru. Senatoya bir adım kaldı!` },
    { icon:'👑', title:'Senato Üyesi!',       desc:'Tebrikler! Roma tarihini avucunun içi gibi biliyorsun.' },
    { icon:'🦅', title:'İmparator Augustus!', desc:'Kusursuz! Roma sana boyun eğiyor, büyük lider.' },
  ][rScore] ?? { icon:'🦅', title:'İmparator!', desc:'Mükemmel.' };

  (document.getElementById('r-result-icon')  as HTMLElement).textContent = data.icon;
  (document.getElementById('r-result-title') as HTMLElement).textContent = data.title;
  (document.getElementById('r-result-desc')  as HTMLElement).textContent = data.desc;
}

document.getElementById('r-restart')!.addEventListener('click', () => {
  rQ = 0; rScore = 0;
  document.querySelectorAll<HTMLButtonElement>('.r-qopt').forEach(b => {
    b.removeAttribute('disabled');
    b.classList.remove('correct', 'wrong');
  });
  for (let i = 0; i < TOTAL_R; i++) {
    const d = document.getElementById(`r-dot-${i}`) as HTMLElement;
    delete d.dataset.result;
  }
  document.getElementById('r-result')!.style.display = 'none';
  document.getElementById('r-q-progress')!.style.display = 'flex';
  rShowQ(0);
});

rShowQ(0);
</script>
