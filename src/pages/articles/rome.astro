<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Quattrocento+Sans:ital,wght@0,400;0,700;1,400&display=swap');

  /* ── TEMA ────────────────────────────────────────────── */
