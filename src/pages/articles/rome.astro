    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(197,160,40,0.03) 60px, rgba(197,160,40,0.03) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(197,160,40,0.03) 60px, rgba(197,160,40,0.03) 61px);
