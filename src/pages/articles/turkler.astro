<script>
(function () {

/* ── Tab switching ── */
document.querySelectorAll('.tp-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    const id = (btn as HTMLElement).dataset.tab;
    document.querySelectorAll('.tp-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tp-tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tp-tab-' + id)?.classList.add('active');
  });
});

/* ── Era detail expand ── */
document.querySelectorAll('.tp-era-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const card = btn.closest('.tp-era-card');
    const detail = card?.querySelector('.tp-era-detail') as HTMLElement | null;
    if (!detail) return;
    const open = !detail.hidden;
    detail.hidden = open;
    btn.textContent = open ? 'Detaylar ↓' : 'Kapat ↑';
  });
});

/* ── Counter animation ── */
function animateCount(el: HTMLElement, target: number, suffix: string, duration = 1800) {
  const start = performance.now();
  function step(now: number) {
    const t = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - t, 3);
    el.textContent = Math.floor(ease * target) + suffix;
    if (t < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

const statObs = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    const el = entry.target as HTMLElement;
    const num = el.querySelector('.tp-stat-num') as HTMLElement;
    if (!num || num.dataset.counted) return;
    num.dataset.counted = '1';
    animateCount(num, parseInt(el.dataset.count!), el.dataset.suffix!);
    statObs.unobserve(el);
  });
}, { threshold: 0.3 });
document.querySelectorAll('.tp-stat').forEach(el => statObs.observe(el));

/* ── Scroll fade-in ── */
document.querySelectorAll<HTMLElement>('.tp-era-card, .tp-bz-card, .tp-war-card, .tp-tengri-card').forEach((el, i) => {
  el.classList.add('tp-fade-in');
  el.style.transitionDelay = `${(i % 4) * 80}ms`;
});
const fadeObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { (e.target as HTMLElement).classList.add('visible'); fadeObs.unobserve(e.target); } });
}, { threshold: 0.15 });
document.querySelectorAll('.tp-fade-in').forEach(el => fadeObs.observe(el));

/* ── Motif SVG preview ── */
type MotifFn = (g: SVGGElement) => void;
const motifs: Record<string, MotifFn> = {
  star8: (g) => {
    g.innerHTML = '';
    const ns = 'http://www.w3.org/2000/svg';
    for (let r = 0; r < 3; r++) for (let c = 0; c < 3; c++) {
      const ox = (c - 1) * 65, oy = (r - 1) * 65;
      const poly = document.createElementNS(ns, 'polygon');
      const pts = [0,-28,7,-10,28,0,10,7,28,28,10,7,0,28,-10,7,-28,28,-7,10,-28,0,-10,-7,-28,-28,-7,-10,0,-28];
      const str = [];
      for (let i = 0; i < pts.length; i += 2) str.push(`${pts[i]+ox},${pts[i+1]+oy}`);
      poly.setAttribute('points', str.join(' '));
      poly.setAttribute('fill', 'none');
      poly.setAttribute('stroke', 'rgba(200,130,40,0.7)');
      poly.setAttribute('stroke-width', '1.2');
      g.appendChild(poly);
    }
  },
  rumi: (g) => {
    g.innerHTML = '';
    const ns = 'http://www.w3.org/2000/svg';
    for (let i = 0; i < 8; i++) {
      const path = document.createElementNS(ns, 'path');
      const angle = i * 45;
      path.setAttribute('d', 'M0,0 Q30,-40 0,-80 Q-30,-40 0,0');
      path.setAttribute('fill', 'rgba(200,80,30,0.4)');
      path.setAttribute('stroke', 'rgba(200,130,40,0.7)');
      path.setAttribute('stroke-width', '0.8');
      path.setAttribute('transform', `rotate(${angle})`);
      g.appendChild(path);
    }
  },
  hatai: (g) => {
    g.innerHTML = '';
    const ns = 'http://www.w3.org/2000/svg';
    for (let i = 0; i < 6; i++) {
      const angle = i * 60;
      const circle = document.createElementNS(ns, 'ellipse');
      circle.setAttribute('cx', String(Math.cos((angle * Math.PI) / 180) * 45));
      circle.setAttribute('cy', String(Math.sin((angle * Math.PI) / 180) * 45));
      circle.setAttribute('rx', '22');
      circle.setAttribute('ry', '12');
      circle.setAttribute('fill', 'rgba(200,80,30,0.25)');
      circle.setAttribute('stroke', 'rgba(200,130,40,0.6)');
      circle.setAttribute('stroke-width', '1');
      circle.setAttribute('transform', `rotate(${angle},${Math.cos((angle*Math.PI)/180)*45},${Math.sin((angle*Math.PI)/180)*45})`);
      g.appendChild(circle);
    }
    const center = document.createElementNS(ns, 'circle');
    center.setAttribute('r', '14');
    center.setAttribute('fill', 'rgba(200,130,40,0.3)');
    center.setAttribute('stroke', 'rgba(200,130,40,0.8)');
    center.setAttribute('stroke-width', '1.5');
    g.appendChild(center);
  },
  geçme: (g) => {
    g.innerHTML = '';
    const ns = 'http://www.w3.org/2000/svg';
    for (let i = 0; i < 4; i++) {
      const rect = document.createElementNS(ns, 'rect');
      rect.setAttribute('x', '-60');
      rect.setAttribute('y', '-8');
      rect.setAttribute('width', '120');
      rect.setAttribute('height', '16');
      rect.setAttribute('rx', '4');
      rect.setAttribute('fill', 'none');
      rect.setAttribute('stroke', 'rgba(200,130,40,0.7)');
      rect.setAttribute('stroke-width', '1.2');
      rect.setAttribute('transform', `rotate(${i * 45})`);
      g.appendChild(rect);
    }
  },
  bulut: (g) => {
    g.innerHTML = '';
    const ns = 'http://www.w3.org/2000/svg';
    const path = document.createElementNS(ns, 'path');
    path.setAttribute('d', 'M-60,0 Q-50,-30 -20,-20 Q-10,-50 20,-40 Q40,-55 50,-30 Q70,-25 60,0 Q70,25 50,30 Q40,55 20,40 Q-10,50 -20,20 Q-50,30 -60,0Z');
    path.setAttribute('fill', 'rgba(80,120,200,0.2)');
    path.setAttribute('stroke', 'rgba(120,160,220,0.6)');
    path.setAttribute('stroke-width', '1');
    g.appendChild(path);
    for (let i = 0; i < 3; i++) {
      const c = document.createElementNS(ns, 'circle');
      const x = (i - 1) * 30, y = 0;
      c.setAttribute('cx', String(x));
      c.setAttribute('cy', String(y));
      c.setAttribute('r', String(8 + i * 2));
      c.setAttribute('fill', 'rgba(120,160,220,0.15)');
      c.setAttribute('stroke', 'rgba(120,160,220,0.5)');
      c.setAttribute('stroke-width', '0.8');
      g.appendChild(c);
    }
  },
  penç: (g) => {
    g.innerHTML = '';
    const ns = 'http://www.w3.org/2000/svg';
    for (let i = 0; i < 5; i++) {
      const angle = i * 72 - 90;
      const path = document.createElementNS(ns, 'path');
      const rad = (angle * Math.PI) / 180;
      const x = Math.cos(rad) * 38, y = Math.sin(rad) * 38;
      path.setAttribute('d', `M0,0 Q${x * 0.5 + Math.cos(rad + 1.4) * 20},${y * 0.5 + Math.sin(rad + 1.4) * 20} ${x},${y} Q${x * 0.5 + Math.cos(rad - 1.4) * 20},${y * 0.5 + Math.sin(rad - 1.4) * 20} 0,0`);
      path.setAttribute('fill', 'rgba(200,80,30,0.3)');
      path.setAttribute('stroke', 'rgba(200,130,40,0.7)');
      path.setAttribute('stroke-width', '1');
      g.appendChild(path);
    }
    const c = document.createElementNS(ns, 'circle');
    c.setAttribute('r', '10');
    c.setAttribute('fill', 'rgba(200,130,40,0.4)');
    g.appendChild(c);
  },
};

const motifGroup = document.getElementById('tp-motif-group') as SVGGElement | null;
if (motifGroup) {
  let activeMotif = 'star8';
  motifs[activeMotif](motifGroup);
  document.querySelectorAll<HTMLElement>('.tp-motif-btn').forEach(btn => {
    if (btn.dataset.motif === activeMotif) btn.classList.add('active');
    btn.addEventListener('click', () => {
      const id = btn.dataset.motif!;
      document.querySelectorAll('.tp-motif-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (motifs[id]) { activeMotif = id; motifs[id](motifGroup); }
    });
  });
}

})();
</script>
