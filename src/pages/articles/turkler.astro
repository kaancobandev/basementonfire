---
import BaseLayout from '../../layouts/BaseLayout.astro';

const eras = [
  {
    id: 'hun', year: 'MÖ 209', title: 'Hun İmparatorluğu', period: 'MÖ 209 – MS 216',
    color: '#c0392b', leader: 'Mete Han', km2: '9.000.000',
    summary: 'Bilinen ilk büyük Türk devleti. Mete Han ondalık ordu sistemi icat etti; Çin\'i yıllık vergi ödemeye zorladı.',
    facts: ['Dünyada ilk ondalık ordu sistemi (10–100–1000–10.000)','Çin İmparatoru\'nun kız kardeşini vergi olarak aldı','Çin Seddi büyük ölçüde Hunlara karşı inşa edildi','400.000 atlı süvariden oluşan ordu'],
    quote: 'Yayını geren her erkeğin atı olsun, okçu süvari olarak hizmet etsin.', quoteBy: 'Mete Han',
  },
  {
    id: 'attila', year: 'MS 434', title: 'Attila & Avrupa Hunları', period: 'MS 370 – 469',
    color: '#8e44ad', leader: 'Attila', km2: '4.000.000',
    summary: 'Tanrı\'nın Kırbacı. Hem Doğu hem Batı Roma\'yı vergi ödemeye mecbur etti; Papa I. Leo ile bizzat görüştü.',
    facts: ['Aynı anda iki Roma imparatorluğundan vergi aldı','Konstantinopolis\'i iki kez kuşattı','Galya\'ya girdi; Katalaunum\'da durdu (451)','Papa I. Leo ile görüşerek İtalya\'dan çekildi'],
    quote: 'Ben Tanrı\'nın kırbacıyım; toprak büyükse kırbaç da büyük olur.', quoteBy: 'Attila',
  },
  {
    id: 'gokturk', year: '552', title: 'Göktürk Kağanlığı', period: '552 – 745',
    color: '#2980b9', leader: 'Bumın Kağan', km2: '6.000.000',
    summary: '"Türk" adını taşıyan ilk devlet. Orhun Yazıtları — dünyanın en eski Türkçe anıtları — bu dönemde taşa kazındı.',
    facts: ['"Türk" kelimesi ilk kez resmi devlet adı oldu','Orhun Yazıtları (720) Türkçenin en eski yazılı anıtıdır','İpek Yolu\'nun tamamını kontrol etti','Kök Böri (Bozkurt) devletin kutsal simgesiydi'],
    quote: 'Türk milletinin adı sanı yok olmasın diye, babam Bumın Kağan hükümdarlık tahtına oturdu.', quoteBy: 'Bilge Kağan — Orhun Yazıtları',
  },
  {
    id: 'seljuk', year: '1037', title: 'Büyük Selçuklu', period: '1037 – 1194',
    color: '#27ae60', leader: 'Tuğrul Bey', km2: '3.900.000',
    summary: 'İslam dünyasının hamisi. Malazgirt Savaşı\'nda (1071) Bizans İmparatoru esir alındı; Anadolu\'nun kapıları açıldı.',
    facts: ['Malazgirt 1071: Bizans İmparatoru bizzat esir alındı','Nizamiye medreseleri dönemin Oxford\'uydu','Kervansaray ağıyla İpek Yolu güvence altına alındı','Selçuklu mimarisi: çift minareli medrese geleneği'],
    quote: 'Ben sultanların sultanıyım; doğuda ve batıda hiçbir kral benimle savaşamaz.', quoteBy: 'Alp Arslan',
  },
  {
    id: 'ottoman', year: '1299', title: 'Osmanlı İmparatorluğu', period: '1299 – 1922',
    color: '#d35400', leader: 'Osman Gazi → Vahdettin', km2: '5.200.000',
    summary: '623 yıl, 3 kıta, 36 sultan. Fatih 21 yaşında İstanbul\'u fethetti. Kanuni döneminde dünyanın en büyük gücüydü.',
    facts: ['Fatih İstanbul\'u 1453\'te 21 yaşında fethetti','Kanuni döneminde Viyana kapılarına dayanıldı','Osmanlı donanması 16. yüzyılda Akdeniz hâkimiydi','Millet sistemi farklı kültürlerin bir arada yaşamasını sağladı'],
    quote: 'Ben Konstantinopolis\'i aldım; bundan böyle fetihlerimde hiçbir engel kalmadı.', quoteBy: 'Fatih Sultan Mehmed',
  },
  {
    id: 'republic', year: '1923', title: 'Türkiye Cumhuriyeti', period: '1923 – Günümüz',
    color: '#e74c3c', leader: 'Mustafa Kemal Atatürk', km2: '783.356',
    summary: 'Osmanlı\'nın küllerinden doğan modern cumhuriyet. Kadınlara oy hakkı Fransa\'dan 10 yıl önce verildi.',
    facts: ['29 Ekim 1923\'te Cumhuriyet ilan edildi','1934\'te kadınlara seçme/seçilme hakkı (Fransa\'dan 10 yıl önce)','Latin alfabesine geçiş yalnızca 3 ayda tamamlandı','NATO\'nun kurucu üyelerinden (1952)'],
    quote: 'Türk milletinin tabiat ve âdetlerine en uygun olan idare, cumhuriyet idaresidir.', quoteBy: 'Mustafa Kemal Atatürk',
  },
];
---

<BaseLayout title="Türkler — Bozkurttan Bugüne" activeNav="">
<main class="tp">

<!-- ═══════ HERO ═══════ -->
<section class="tp-hero">
  <div class="tp-hero-bg" aria-hidden="true">
    <svg class="tp-star-pattern" width="100%" height="100%"><defs><pattern id="tp-star" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse"><g fill="none" stroke="rgba(180,100,30,0.18)" stroke-width="0.8"><polygon points="40,4 46,26 68,20 54,38 72,54 50,50 46,72 40,58 34,72 30,50 8,54 26,38 12,20 34,26"/></g></pattern></defs><rect width="100%" height="100%" fill="url(#tp-star)"/></svg>
    <div class="tp-hero-glow"></div>
  </div>

  <!-- Wolf SVG -->
  <div class="tp-wolf-wrap" aria-hidden="true">
    <svg class="tp-wolf" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 240 300">
      <defs>
        <filter id="wolf-glow"><feGaussianBlur stdDeviation="4" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        <filter id="eye-glow"><feGaussianBlur stdDeviation="6" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        <radialGradient id="wolf-body-grad" cx="50%" cy="40%"><stop offset="0%" stop-color="#c0392b"/><stop offset="100%" stop-color="#7b241c"/></radialGradient>
      </defs>
      <!-- Left ear -->
      <polygon points="28,8 62,88 8,95" fill="#7b241c"/>
      <polygon points="36,28 58,82 18,88" fill="#c0392b"/>
      <!-- Right ear -->
      <polygon points="212,8 178,88 232,95" fill="#7b241c"/>
      <polygon points="204,28 182,82 222,88" fill="#c0392b"/>
      <!-- Head -->
      <polygon points="12,88 228,88 218,185 172,248 120,268 68,248 22,185" fill="url(#wolf-body-grad)"/>
      <!-- Brow shadow -->
      <polygon points="55,88 185,88 175,128 120,122 65,128" fill="#7b241c"/>
      <!-- Forehead stripe -->
      <polygon points="102,122 138,122 133,198 120,214 107,198" fill="#6e1f1f"/>
      <!-- Left eye bg -->
      <ellipse cx="78" cy="138" rx="24" ry="20" fill="#1a0a0a"/>
      <!-- Left eye amber -->
      <ellipse cx="78" cy="138" rx="18" ry="15" fill="#e67e00" filter="url(#eye-glow)"/>
      <ellipse cx="78" cy="138" rx="12" ry="10" fill="#ff9500"/>
      <!-- Left pupil -->
      <ellipse cx="78" cy="139" rx="6" ry="9" fill="#080404"/>
      <circle cx="74" cy="134" r="2.5" fill="rgba(255,255,255,0.7)"/>
      <!-- Right eye bg -->
      <ellipse cx="162" cy="138" rx="24" ry="20" fill="#1a0a0a"/>
      <!-- Right eye amber -->
      <ellipse cx="162" cy="138" rx="18" ry="15" fill="#e67e00" filter="url(#eye-glow)"/>
      <ellipse cx="162" cy="138" rx="12" ry="10" fill="#ff9500"/>
      <!-- Right pupil -->
      <ellipse cx="162" cy="139" rx="6" ry="9" fill="#080404"/>
      <circle cx="158" cy="134" r="2.5" fill="rgba(255,255,255,0.7)"/>
      <!-- Nose bridge -->
      <polygon points="108,162 132,162 128,176 112,176" fill="#6e1f1f"/>
      <!-- Nose -->
      <ellipse cx="120" cy="182" rx="20" ry="13" fill="#150505"/>
      <ellipse cx="115" cy="178" rx="6" ry="4" fill="rgba(255,255,255,0.08)"/>
      <!-- Jaw -->
      <polygon points="38,200 202,200 188,258 120,278 52,258" fill="#9b2a2a"/>
      <!-- Teeth -->
      <polygon points="72,202 87,202 84,228" fill="#f0ece0"/>
      <polygon points="92,202 106,202 103,226" fill="#f0ece0"/>
      <polygon points="134,202 148,202 145,226" fill="#f0ece0"/>
      <polygon points="153,202 168,202 164,228" fill="#f0ece0"/>
      <!-- Gum -->
      <polygon points="58,200 182,200 180,208 60,208" fill="#7b241c"/>
      <!-- Chin -->
      <ellipse cx="120" cy="268" rx="28" ry="12" fill="#7b241c"/>
      <!-- Decorative rune marks on forehead -->
      <line x1="90" y1="100" x2="100" y2="116" stroke="rgba(255,200,100,0.3)" stroke-width="1.5"/>
      <line x1="95" y1="100" x2="100" y2="116" stroke="rgba(255,200,100,0.3)" stroke-width="1.5"/>
      <line x1="140" y1="100" x2="145" y2="116" stroke="rgba(255,200,100,0.3)" stroke-width="1.5"/>
      <line x1="145" y1="100" x2="140" y2="116" stroke="rgba(255,200,100,0.3)" stroke-width="1.5"/>
    </svg>
    <div class="tp-wolf-shadow"></div>
  </div>

  <div class="tp-hero-text">
    <div class="tp-hero-eyebrow">BOZKURTTAN BUGÜNE</div>
    <h1 class="tp-hero-title">TÜRKLER</h1>
    <p class="tp-hero-sub">4.000 yıllık destan · 40'tan fazla devlet · 3 kıtayı değiştiren bir millet</p>
    <div class="tp-runes" aria-label="Göktürk runik yazı">𐱅𐰇𐰼𐰚</div>
  </div>

  <!-- Bottom geometric border -->
  <div class="tp-hero-border" aria-hidden="true">
    <svg viewBox="0 0 1200 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="0,60 1200,60 1200,0 600,50 0,0" fill="#0e0a08"/>
    </svg>
  </div>
</section>

<!-- ═══════ STATS ═══════ -->
<section class="tp-stats">
  <div class="tp-stats-inner">
    <div class="tp-stat" data-count="4000" data-suffix="+ yıl">
      <div class="tp-stat-num">0</div>
      <div class="tp-stat-lbl">Kanıtlanmış Tarih</div>
    </div>
    <div class="tp-stat" data-count="40" data-suffix="+ devlet">
      <div class="tp-stat-num">0</div>
      <div class="tp-stat-lbl">Kurulan İmparatorluk</div>
    </div>
    <div class="tp-stat" data-count="3" data-suffix=" kıta">
      <div class="tp-stat-num">0</div>
      <div class="tp-stat-lbl">Hükmedilen Kıta</div>
    </div>
    <div class="tp-stat" data-count="200" data-suffix="M+ kişi">
      <div class="tp-stat-num">0</div>
      <div class="tp-stat-lbl">Bugünkü Türk Nüfusu</div>
    </div>
  </div>
</section>

<!-- ═══════ TIMELINE ═══════ -->
<section class="tp-timeline-sect">
  <div class="tp-sect-head">
    <div class="tp-sect-line"></div>
    <h2>Büyük Türk Devletleri</h2>
    <div class="tp-sect-line"></div>
  </div>

  <div class="tp-timeline-track">
    <div class="tp-timeline-rail" aria-hidden="true"></div>
    {eras.map((era, i) => (
      <div class="tp-era-card" data-id={era.id} style={`--era-color:${era.color}`}>
        <div class="tp-era-dot" style={`background:${era.color}`}></div>
        <div class="tp-era-year">{era.year}</div>
        <div class="tp-era-body">
          <div class="tp-era-title">{era.title}</div>
          <div class="tp-era-period">{era.period}</div>
          <div class="tp-era-leader">👤 {era.leader}</div>
          <div class="tp-era-km">🗺 {era.km2} km²</div>
          <p class="tp-era-summary">{era.summary}</p>
          <button class="tp-era-btn" data-idx={i}>Detaylar ↓</button>
        </div>
        <div class="tp-era-detail" hidden>
          <ul class="tp-era-facts">
            {era.facts.map(f => <li>{f}</li>)}
          </ul>
          <blockquote class="tp-era-quote">
            <p>"{era.quote}"</p>
            <cite>— {era.quoteBy}</cite>
          </blockquote>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ═══════ BOZKURT ═══════ -->
<section class="tp-bozkurt">
  <div class="tp-bz-bg" aria-hidden="true">
    <svg width="100%" height="100%"><defs><pattern id="bz-pat" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="50" cy="50" r="40" fill="none" stroke="rgba(192,57,43,0.12)" stroke-width="1"/><line x1="10" y1="50" x2="90" y2="50" stroke="rgba(192,57,43,0.08)" stroke-width="0.5"/><line x1="50" y1="10" x2="50" y2="90" stroke="rgba(192,57,43,0.08)" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#bz-pat)"/></svg>
  </div>
  <div class="tp-sect-head tp-sect-head--light">
    <div class="tp-sect-line tp-sect-line--light"></div>
    <h2>🐺 Bozkurt: Kutsal Ata</h2>
    <div class="tp-sect-line tp-sect-line--light"></div>
  </div>
  <div class="tp-bz-grid">
    <div class="tp-bz-card">
      <div class="tp-bz-icon">🏔️</div>
      <h3>Ergenekon Destanı</h3>
      <p>Türkler ağır bir yenilginin ardından dağlarla çevrili Ergenekon vadisinde mahsur kaldı. Nesiller boyu yaşadılar; demirciler dağı eriterek çıkış yolu açtı. Bu kurtuluşa öncülük eden bir Bozkurt'tu — halkını özgürlüğe götürdü.</p>
    </div>
    <div class="tp-bz-card">
      <div class="tp-bz-icon">🐺</div>
      <h3>Asena: Kutsal Dişi Kurt</h3>
      <p>Göktürk yaratılış efsanesinde tüm Türkler düşmanlarca katledilir, yalnızca bir çocuk kalır. Dişi kurt Asena bu çocuğu büyütür. Ondan doğan on oğlun soyu Göktürkleri oluşturur. Asena bugün de Türk sembolizminin merkezindedir.</p>
    </div>
    <div class="tp-bz-card">
      <div class="tp-bz-icon">🚩</div>
      <h3>Sancaktaki Kurt Başı</h3>
      <p>Göktürk kağanlarının otağı önünde altın kurt başlı sancak dikilirdi. Kurt kafası tüğ (tuğ) üzerine takılır; savaşa gidildiğinde öncü birlikler bu sancak arkasında ilerledi. Bozkurt, kağanın gücünü ve meşruiyetini sembolize etti.</p>
    </div>
    <div class="tp-bz-card">
      <div class="tp-bz-icon">⚡</div>
      <h3>Günümüzdeki Miras</h3>
      <p>Bozkurt sembolü bugün hâlâ Türk kültüründe derin anlam taşır. Spor takımlarından askeri birliklere, siyasi hareketlerden şehir armalarına uzanan bu gelenek, 1.500 yıllık kesintisiz bir kültürel belleği yansıtır.</p>
    </div>
  </div>
</section>

<!-- ═══════ CULTURE TABS ═══════ -->
<section class="tp-culture">
  <div class="tp-sect-head">
    <div class="tp-sect-line"></div>
    <h2>Türk Kültürü</h2>
    <div class="tp-sect-line"></div>
  </div>

  <div class="tp-tabs-nav">
    <button class="tp-tab active" data-tab="language">𐰚 Dil & Yazı</button>
    <button class="tp-tab" data-tab="tengri">☀️ Tengricilik</button>
    <button class="tp-tab" data-tab="art">◆ Türk Sanatı</button>
    <button class="tp-tab" data-tab="war">⚔️ Savaş Sanatı</button>
  </div>

  <!-- Language tab -->
  <div class="tp-tab-panel active" id="tp-tab-language">
    <div class="tp-tab-content">
      <div class="tp-tab-text">
        <h3>Orhun Alfabesi: Taşa Kazınan Tarih</h3>
        <p>Göktürkler, Proto-Türk yazısından geliştirdikleri özgün runik bir alfabe kullandı. 38 harfli bu sistem soldan sağa veya sağdan sola yazılabilirdi. Moğolistan'daki Orhun Vadisi'nde taşlara kazınan metinler, 8. yüzyıldan bu yana sağlam durmaktadır.</p>
        <p class="tp-tab-note">💡 Harflerin üzerine gelin — Türkçe karşılıklarını görün</p>
      </div>
      <div class="tp-rune-grid">
        {[
          {r:'𐰀',l:'A',m:'Açık A sesi'},
          {r:'𐰉',l:'B',m:'Dudak B'},
          {r:'𐰚',l:'K',m:'Ön damak K'},
          {r:'𐱃',l:'T',m:'Diş T'},
          {r:'𐰖',l:'Y',m:'Yarı sesli Y'},
          {r:'𐰭',l:'NG',m:'Nazal NG'},
          {r:'𐰞',l:'L',m:'Yan L'},
          {r:'𐰢',l:'M',m:'Dudak M'},
          {r:'𐰣',l:'N',m:'Diş N'},
          {r:'𐰺',l:'R',m:'Titrek R'},
          {r:'𐰽',l:'S',m:'Diş S'},
          {r:'𐱄',l:'D',m:'Arka damak D'},
        ].map(({r,l,m}) => (
          <div class="tp-rune-item" title={m}>
            <div class="tp-rune-sym">{r}</div>
            <div class="tp-rune-lat">{l}</div>
            <div class="tp-rune-tip">{m}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Tengri tab -->
  <div class="tp-tab-panel" id="tp-tab-tengri">
    <div class="tp-tab-content">
      <div class="tp-tab-text">
        <h3>Tengri: Göğün Tanrısı</h3>
        <p>İslam'dan önce Türkler Tengricilik (Gök Tanrı dini) inancını yaşattı. Tengri, sonsuz mavi göğü kişileştiren evrenin efendisiydi. Şamanlar (kam) bu dünya ile ruhlar âlemi arasındaki aracılardı.</p>
        <p class="tp-tab-note">💡 Her kartın üzerine tıklayın</p>
      </div>
      <div class="tp-tengri-grid">
        {[
          {sym:'☀️',name:'Tengri',desc:'Gök Tanrı — sonsuz mavi göğün efendisi, evrenin yaratıcısı'},
          {sym:'🌍',name:'Yer-Sub',desc:'Toprak ve su ruhları — bereket ve ürünün kaynağı'},
          {sym:'🦅',name:'Umay Ana',desc:'Ana tanrıça — doğurganlık, çocuklar ve ocağın koruyucusu'},
          {sym:'🐺',name:'Kök Böri',desc:'Bozkurt — kutsal ata, kılavuz ve savaş simgesi'},
          {sym:'🔥',name:'Od Ana',desc:'Ateş Ana — ocağın, ailenin ve toplumun koruyucusu'},
          {sym:'🌙',name:'Ay Tengri',desc:'Ay Tanrı — gece göğünün hâkimi, takvimin temeli'},
          {sym:'⚡',name:'Yel Tengri',desc:'Rüzgâr Tanrı — doğanın gücünü ve özgürlüğü temsil eder'},
          {sym:'🏔️',name:'Erlik Han',desc:'Yeraltı hâkimi — ölüm, karanlık ve kötülüğün tanrısı'},
        ].map(({sym,name,desc}) => (
          <div class="tp-tengri-card">
            <div class="tp-tengri-sym">{sym}</div>
            <div class="tp-tengri-name">{name}</div>
            <div class="tp-tengri-desc">{desc}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Art tab -->
  <div class="tp-tab-panel" id="tp-tab-art">
    <div class="tp-tab-content">
      <div class="tp-tab-text">
        <h3>Rumi'den Tezhibe: Sonsuz Arabesk</h3>
        <p>Türk sanatı; Orta Asya bozkır geleneğinden Selçuklu taş işçiliğine, Osmanlı çini ve minyatürüne uzanır. Geometri, bitkisel motif ve hat sanatının bütünleşmesiyle eşsiz bir estetik dil doğdu.</p>
      </div>
      <div class="tp-motif-showcase">
        <div class="tp-motif-preview">
          <svg id="tp-motif-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <rect width="200" height="200" fill="#1a0e06"/>
            <g id="tp-motif-group" transform="translate(100,100)"></g>
          </svg>
        </div>
        <div class="tp-motif-list">
          {[
            {id:'rumi',name:'Rumi',desc:'Kıvrımlı yaprak motifi — spiritüel yolculuğu simgeler'},
            {id:'hatai',name:'Hatai',desc:'Stilize çiçek — doğanın sonsuz döngüsü'},
            {id:'star8',name:'Selçuklu Yıldızı',desc:'8 köşeli yıldız — evrenin geometrisi'},
            {id:'geçme',name:'Geçme Örgü',desc:'Örgülü desen — birlik ve bütünlük'},
            {id:'bulut',name:'Bulut Motifi',desc:'Çin etkisiyle gelen bulut deseni'},
            {id:'penç',name:'Penç',desc:'5 yapraklı gül — ilahi mükemmellik'},
          ].map(m => (
            <button class="tp-motif-btn" data-motif={m.id}>
              <strong>{m.name}</strong>
              <span>{m.desc}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- War tab -->
  <div class="tp-tab-panel" id="tp-tab-war">
    <div class="tp-tab-content">
      <div class="tp-tab-text">
        <h3>Bozkır Savaşçısı: Süvari Uygarlığı</h3>
        <p>Türk savaş geleneği atlı okçuluk üzerine kuruldu. "Turan taktiği" — sahte ricat ile çevirme manevrası — yüzyıllar boyunca Çin, Roma, Bizans ve Haçlı ordularını alt etti.</p>
      </div>
      <div class="tp-war-grid">
        {[
          {icon:'🏹',name:'Atlı Okçu',desc:'At sırtında geriye dönük ok atma "Parti atışı" — dünyanın ilk mobil topçusu'},
          {icon:'🔟',name:'Mangala Sistemi',desc:'Ondalık askeri örgütlenme: 10 / 100 / 1.000 / 10.000 — modern ordunun atası'},
