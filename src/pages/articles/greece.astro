---
import BaseLayout from '../../layouts/BaseLayout.astro';

const gods = [
  { name: 'Zeus',     domain: 'Gökyüzü & Şimşek', emoji: '⚡', color: '#f5c518',
    desc: 'Olimpos\'un baş tanrısı. Şimşek ve fırtınanın efendisi, tanrıların ve insanların babası.',
    symbol: 'Yıldırım, Kartal, Meşe' },
  { name: 'Athena',   domain: 'Bilgelik & Savaş',  emoji: '🦉', color: '#7ec8e3',
    desc: 'Atina\'nın koruyucu tanrıçası. Bilgelik, zanaat ve savaş stratejisinin simgesi. Zeus\'un başından doğdu.',
    symbol: 'Baykuş, Zeytin Dalı, Miğfer' },
  { name: 'Poseidon', domain: 'Deniz & Deprem',    emoji: '🔱', color: '#1a6fa8',
    desc: 'Denizlerin ve depremlerin efendisi. Gemicilerin duaları ona yönelirdi; öfkelenince denizleri kasırgaya döndürürdü.',
    symbol: 'Trident, At, Boğa' },
  { name: 'Apollo',   domain: 'Güneş & Kehanet',   emoji: '☀️', color: '#f9a620',
    desc: 'Güneş, müzik ve kehanet tanrısı. Delphi kehanet merkezi ona adanmıştı. Artemis\'in ikiz kardeşi.',
    symbol: 'Lir, Ok-Yay, Defne Dalı' },
  { name: 'Ares',     domain: 'Savaş',             emoji: '⚔️', color: '#c1121f',
    desc: 'Savaşın ve şiddetin tanrısı. Sparta\'nın özellikle sevdiği tanrıydı. Savaş meydanlarında dehşet saçardı.',
    symbol: 'Mızrak, Kalkan, Köpek' },
  { name: 'Hermes',   domain: 'Ticaret & Elçilik', emoji: '🪽', color: '#a8dadc',
    desc: 'Tanrıların habercisi ve gezginlerin koruyucusu. Ölüleri yeraltına taşır; ticaret ve hırsızlığın da tanrısıydı.',
    symbol: 'Kanatlı Sandalet, Caduceus' },
  { name: 'Artemis',  domain: 'Av & Ay',           emoji: '🌙', color: '#b9a0c4',
    desc: 'Av ve ay tanrıçası, Apollo\'nun ikiz kız kardeşi. Vahşi doğanın ve gençliğin koruyucusuydu.',
    symbol: 'Ok-Yay, Geyik, Ay Hilali' },
  { name: 'Dionysos', domain: 'Şarap & Sevinç',   emoji: '🍇', color: '#7b2d8b',
    desc: 'Bağ, şarap ve tiyatronun tanrısı. Tragedya ve komedi oyunları ona onuruna yapılırdı.',
    symbol: 'Üzüm Salkımı, Sarmaşık, Thyrsos' },
];

const alexTimeline = [
  { year: 'MÖ 356', event: 'Doğum',    desc: 'Büyük İskender Makedonya\'da doğdu. Aristoteles\'in öğrencisi olarak büyük bir eğitim aldı.' },
  { year: 'MÖ 336', event: 'Tahta',    desc: 'Babası II. Philippos suikasta kurban gidince 20 yaşında kral oldu. Yunan şehirlerini kısa sürede yeniden kontrolüne aldı.' },
  { year: 'MÖ 334', event: 'Granikos', desc: 'Anadolu\'ya geçen İskender, Granikos Nehri\'nde Pers kuvvetlerini ilk büyük savaşta bozguna uğrattı.' },
  { year: 'MÖ 333', event: 'İssus',    desc: 'Kral III. Darius liderliğindeki Pers ordusunu İssus\'ta yenerek Akdeniz sahillerini ele geçirdi. Darius kaçtı.' },
  { year: 'MÖ 331', event: 'Gaugamela',desc: 'Son büyük meydan savaşında Pers İmparatorluğu\'nu çökertti. Babil ve Persepolis\'e girdi.' },
  { year: 'MÖ 323', event: 'Vefat',    desc: '32 yaşında Babil\'de hayatını kaybetti. Kısa sürede üç kıtaya yayılan imparatorluğu ardında bıraktı.' },
];

const compareBars = [
  { label: 'Askeri Güç',     athens: 50, sparta: 95 },
  { label: 'Demokrasi',      athens: 95, sparta: 20 },
  { label: 'Sanat & Mimari', athens: 90, sparta: 35 },
  { label: 'Felsefe',        athens: 95, sparta: 25 },
  { label: 'Deniz Gücü',     athens: 80, sparta: 45 },
  { label: 'Ticaret',        athens: 85, sparta: 30 },
];

const sports = [
  { sport: 'Stadion',          icon: '🏃', desc: 'Yaklaşık 192 metre uzunluğundaki pistde koşu. İlk ve en prestijli Olimpiyat dalıydı.' },
  { sport: 'Güreş',            icon: '🤼', desc: 'Rakibin omzunu yere değdirme esasına dayanırdı. En popüler dövüş sporuydu.' },
  { sport: 'Pentathlon',       icon: '🥇', desc: 'Koşu, atlama, disk, cirit ve güreşten oluşan beşli müsabaka. En yüce atletik şereftir.' },
  { sport: 'Boks',             icon: '🥊', desc: 'Deri bantlarla sarılı yumruklarla yapılır; hakem "dur!" deyene kadar sürerdi.' },
  { sport: 'Arabalı Yarış',    icon: '🐎', desc: 'Hippodromda dört atın çektiği araba ile yapılırdı. En tehlikeli ve heyecanlı etkinlikti.' },
  { sport: 'Pankration',       icon: '💪', desc: 'Güreş + boks karışımı tam temaslı dövüş. Isırma ve göz çıkarma dışında her şey serbestti.' },
];

const quizQuestions = [
  { q: 'İlk Olimpiyat Oyunları hangi yılda düzenlendi?',
    opts: ['MÖ 490', 'MÖ 776', 'MÖ 600', 'MÖ 323'], correct: 1,
    explain: 'İlk Olimpiyat Oyunları MÖ 776\'da Olympia\'da Zeus onuruna düzenlendi ve 4 yılda bir tekrarlandı.' },
  { q: 'Atina\'nın koruyucu tanrıçası kimdir?',
    opts: ['Hera', 'Artemis', 'Demeter', 'Athena'], correct: 3,
    explain: 'Athena, bilgelik ve savaş tanrıçasıdır. Atinalılar ona Akropol\'deki Parthenon\'u inşa etti.' },
  { q: 'Büyük İskender ile III. Darius\'ın ilk savaşı hangisidir?',
    opts: ['Granikos', 'İssus', 'Gaugamela', 'Thermopylae'], correct: 1,
    explain: 'İskender ve Darius MÖ 333\'te İssus\'ta ilk kez karşılaştı. İskender galip geldi, Darius kaçtı.' },
  { q: 'Theseus, Minotor\'u öldürmek için nereye gitti?',
    opts: ['Olimpos Dağı', 'Truva', 'Girit labirenti', 'Sparta'], correct: 2,
    explain: 'Theseus, Girit Adası\'ndaki labirente girdi. Ariadne\'nin verdiği ip yumağı sayesinde geri çıkabildi.' },
];
---

<BaseLayout title="Antik Yunan" activeNav="greece">
<main class="main-content" id="greece-page">

  <!-- TOPBAR -->
  <div class="g-topbar">
    <a href="/" class="g-back">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </a>
    <span class="g-topbar-title">Antik Yunan</span>
    <nav class="g-era-nav">
      <button class="g-era-btn active" data-target="kurulus">Kuruluş</button>
      <button class="g-era-btn" data-target="sehirler">Şehirler</button>
      <button class="g-era-btn" data-target="tanrilar">Tanrılar</button>
      <button class="g-era-btn" data-target="iskender">İskender</button>
    </nav>
  </div>

  <!-- HERO -->
  <section class="g-hero">
    <div class="g-hero-particles" id="g-particles"></div>
    <div class="g-columns-silhouette">
      <div class="g-col-sil"></div><div class="g-col-sil"></div>
      <div class="g-col-sil"></div><div class="g-col-sil"></div>
      <div class="g-col-sil"></div>
    </div>
    <div class="g-hero-content">
      <div class="g-hero-subtitle">MÖ 800 — MÖ 323</div>
      <h1 class="g-hero-title">ANTİK YUNAN</h1>
      <p class="g-hero-tagline">Demokrasinin, felsefenin ve Olimpiyatların beşiği</p>
      <div class="g-stats-row">
        <div class="g-stat"><span class="g-count" data-target="776">0</span><small>MÖ İlk Olimpiyat</small></div>
        <div class="g-stat"><span class="g-count" data-target="12">0</span><small>Olympos Tanrısı</small></div>
        <div class="g-stat"><span class="g-count" data-target="32">0</span><small>İskender'in Yaşı</small></div>
        <div class="g-stat"><span class="g-count" data-target="150">0</span><small>Delos Üyesi</small></div>
      </div>
    </div>
    <div class="g-hero-waves">
      <svg viewBox="0 0 1200 80" preserveAspectRatio="none">
        <path d="M0,40 C200,80 400,0 600,40 C800,80 1000,0 1200,40 L1200,80 L0,80 Z" fill="#060d1a"/>
      </svg>
    </div>
  </section>

  <!-- SECTION: KURULUŞ -->
  <section class="g-section" id="kurulus">
    <div class="g-section-inner">
      <h2 class="g-section-title"><span>⚡</span> Kuruluş &amp; Theseus Efsanesi</h2>
      <div class="g-intro-text">
        <p>Atina Uygarlığı, <strong>2500 km²'lik</strong> Attika yarımadası üzerinde kurulmuştur. Pire limanı ve Sefis Nehri'nin sunduğu imkânlarla büyüyen Atina, zamanla düşünce ve demokrasinin merkezi oldu.</p>
      </div>

      <!-- Interactive Theseus -->
      <div class="g-theseus-card">
        <div class="g-theseus-left">
          <div class="g-labyrinth-icon">
            <svg viewBox="0 0 100 100" width="120" height="120">
              <rect x="5"  y="5"  width="90" height="90" fill="none" stroke="#c9a227" stroke-width="3"/>
              <rect x="15" y="15" width="70" height="70" fill="none" stroke="#c9a227" stroke-width="2.5"/>
              <rect x="25" y="25" width="50" height="50" fill="none" stroke="#c9a227" stroke-width="2"/>
              <rect x="35" y="35" width="30" height="30" fill="none" stroke="#c9a227" stroke-width="1.5"/>
              <!-- gaps to make it a maze -->
              <line x1="5"  y1="40" x2="15" y2="40" stroke="#060d1a" stroke-width="4"/>
              <line x1="15" y1="65" x2="25" y2="65" stroke="#060d1a" stroke-width="4"/>
              <line x1="25" y1="35" x2="35" y2="35" stroke="#060d1a" stroke-width="4"/>
              <line x1="35" y1="60" x2="45" y2="60" stroke="#060d1a" stroke-width="4"/>
              <line x1="50" y1="35" x2="50" y2="25" stroke="#060d1a" stroke-width="4"/>
              <line x1="65" y1="50" x2="75" y2="50" stroke="#060d1a" stroke-width="4"/>
              <circle cx="50" cy="50" r="6" fill="#8b0000"/>
              <circle cx="50" cy="50" r="3" fill="#ff2222"/>
            </svg>
          </div>
          <div class="g-theseus-items">
            <div class="g-titem"><span>🧵</span><small>Ariadne'nin İpi</small></div>
            <div class="g-titem"><span>⚔️</span><small>Theseus'un Kılıcı</small></div>
            <div class="g-titem"><span>🐂</span><small>Minotor'un Gazabı</small></div>
          </div>
        </div>
        <div class="g-theseus-right">
          <h3>Theseus &amp; Minotor Efsanesi</h3>
          <p>Girit Adası'nın derinliklerinde, insan aklının kavrayamayacağı bir labirent. İçinde yarı insan yarı boğa bir canavar: <strong>Minotor</strong>. Atina'nın gençleri ona kurban edilmektedir. Tek bir yiğit adım öne çıkar.</p>
          <p>Kral Minos'un kızı Ariadne Theseus'a altın bir ip verir — karanlıktan çıkışın tek rehberi. Artık geri dönüş yok.</p>
          <button class="g-labirent-btn" id="open-labirent">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Labirente Gir
          </button>
        </div>
      </div>

      <!-- ── LABYRINTH MODAL ─────────────────────────────── -->
      <div class="g-labi-modal" id="labirent-modal">
        <div class="g-labi-backdrop"></div>
        <div class="g-labi-inner">

          <button class="g-labi-close" id="labi-close-x" title="Kapat">✕</button>

          <!-- NARRATION BAR -->
          <div class="g-labi-narr" id="labi-narr">Labirentin derinliklerine iniyorsun… Altın ipi takip et!</div>

          <!-- PHASE: MAZE -->
          <div id="phase-maze">
            <canvas id="maze-canvas" width="308" height="308"></canvas>
            <div class="g-maze-ctrl">
              <div class="g-ctrl-row">
                <button class="g-dir" data-dr="-1" data-dc="0">▲</button>
              </div>
              <div class="g-ctrl-row">
                <button class="g-dir" data-dr="0" data-dc="-1">◀</button>
                <div class="g-ctrl-center">Θ</div>
                <button class="g-dir" data-dr="0" data-dc="1">▶</button>
              </div>
              <div class="g-ctrl-row">
                <button class="g-dir" data-dr="1" data-dc="0">▼</button>
              </div>
            </div>
            <p class="g-labi-hint">Klavye: ← ↑ → ↓ &nbsp;|&nbsp; Altın iple yolunu takip et!</p>
          </div>

          <!-- PHASE: BATTLE -->
          <div id="phase-battle" style="display:none">
            <div class="g-battle-hud">
              <div class="g-fighter-hud">
                <span class="g-fname theseus-name">⚔️ Theseus</span>
                <div class="g-hp-track"><div class="g-hp-fill g-hp-t" id="hp-theseus-bar"></div></div>
                <span class="g-hp-num" id="hp-theseus-num">100</span>
              </div>
              <div class="g-hud-vs">VS</div>
              <div class="g-fighter-hud">
                <span class="g-fname mino-name">Minotor 🐂</span>
                <div class="g-hp-track"><div class="g-hp-fill g-hp-m" id="hp-mino-bar"></div></div>
                <span class="g-hp-num" id="hp-mino-num">100</span>
              </div>
            </div>
            <canvas id="battle-canvas" width="308" height="210"></canvas>
            <button class="g-attack-btn" id="attack-btn">⚔️ SALDIRI!</button>
            <p class="g-labi-hint">Hızlıca tıkla — Minotor da saldırıyor!</p>
          </div>

          <!-- PHASE: DEFEAT -->
          <div id="phase-defeat" style="display:none">
            <div class="g-victory-wrap">
              <div class="g-victory-trophy">💀</div>
              <h3 class="g-victory-title" style="color:#e74c3c">Minotor Kazandı!</h3>
              <p class="g-victory-story">Güçlü bir darbesiyle Theseus devrild. Ama cesur yürekler yenilgiyi kabul etmez. Tekrar dene!</p>
              <button class="g-close-victory" id="retry-battle">Tekrar Dene ⚔️</button>
            </div>
          </div>

          <!-- PHASE: VICTORY -->
          <div id="phase-victory" style="display:none">
            <div class="g-victory-wrap">
              <div class="g-victory-stars" id="victory-stars"></div>
              <div class="g-victory-trophy">🏆</div>
              <h3 class="g-victory-title">Minotor Yenildi!</h3>
              <p class="g-victory-story">Theseus, labirentin derinliklerinde Minotor'u devirdi. Ariadne'nin altın ipi onu karanlıktan güneş ışığına çıkardı. Gemi Atina'ya döndüğünde tüm şehir coşkuyla karşıladı kahramanını.</p>
              <p class="g-victory-quote">"Artık kimse kurban edilmeyecek." — Theseus</p>
              <div class="g-victory-badges">
                <span>🧵 İpi Takip Ettin</span>
                <span>⚔️ Minotor'u Yendin</span>
                <span>🌅 Gün Işığına Çıktın</span>
              </div>
              <button class="g-close-victory" id="close-victory">Efsaneyi Kapat</button>
            </div>
          </div>

        </div>
      </div>

      <div class="g-info-box">
        <h3>⚓ Attika-Delos Birliği <span class="g-badge">MÖ 477 – 404</span></h3>
        <p>Pers tehdidine karşı kurulan, 150'yi aşkın Grek kent devletini bir araya getiren askeri-siyasi ittifak. Perikles MÖ 454'te merkezi Atina'ya taşıdı. Atina'nın donanmayı kendi çıkarları için kullanması Peloponez Savaşı'nı (MÖ 431) patlattı ve birlik MÖ 404'te çöktü.</p>
      </div>
    </div>
  </section>

  <!-- SECTION: ŞEHİR DEVLETLERİ -->
  <section class="g-section g-section-alt" id="sehirler">
    <div class="g-section-inner">
      <h2 class="g-section-title"><span>🏛️</span> Şehir Devletleri</h2>
      <p class="g-section-lead">Antik Yunan hiçbir zaman tek bir devlet değildi. Birbiriyle rekabet eden yüzlerce <em>polis</em> (şehir devleti) vardı. İkisi öne çıktı:</p>

      <div class="g-vs-container">
        <div class="g-vs-city athens">
          <div class="g-vs-city-header">
            <span class="g-vs-emblem">🦉</span>
            <h3>Atina</h3>
            <small>Demokrasi &amp; Bilgelik</small>
          </div>
          <ul class="g-vs-facts">
            <li>Dünyanın ilk demokrasisini kurdu</li>
            <li>Platon, Sokrates, Aristoteles vatandaşıydı</li>
            <li>Parthenon ve Akropol'ün evi</li>
            <li>Güçlü ticaret ve deniz filosu</li>
            <li>Özgür vatandaşlar mecliste oy kullandı</li>
          </ul>
        </div>
        <div class="g-vs-divider">VS</div>
        <div class="g-vs-city sparta">
          <div class="g-vs-city-header">
            <span class="g-vs-emblem">⚔️</span>
            <h3>Sparta</h3>
            <small>Disiplin &amp; Güç</small>
          </div>
          <ul class="g-vs-facts">
            <li>7 yaşında askerî eğitim başlar (agoge)</li>
            <li>Yunanistan'ın en güçlü kara ordusu</li>
            <li>Kadınlar mülk ve spor haklarına sahipti</li>
            <li>Helot köleler tarım işlerini üstlendi</li>
            <li>Thermopylae'de 300 kişiyle efsane yazdı</li>
          </ul>
        </div>
      </div>

      <div class="g-compare-bars" id="compare-bars">
        {compareBars.map(row => (
          <div class="g-bar-row">
            <span class="g-bar-label">{row.label}</span>
            <div class="g-bars">
              <div class="g-bar-track">
                <div class="g-bar-fill athens-fill" data-width={`${row.athens}%`}></div>
                <span class="g-bar-val">{row.athens}</span>
              </div>
              <div class="g-bar-track">
                <div class="g-bar-fill sparta-fill" data-width={`${row.sparta}%`}></div>
                <span class="g-bar-val">{row.sparta}</span>
              </div>
            </div>
          </div>
        ))}
        <div class="g-bar-legend">
          <span class="athens-dot">● Atina</span>
          <span class="sparta-dot">● Sparta</span>
        </div>
      </div>

      <div class="g-pyramid-wrap">
        <h3 class="g-sub-title">Sosyal Hiyerarşi (Atina)</h3>
        <div class="g-pyramid">
          <div class="g-p-level l1"><span>Soylular (Öpatridler)</span></div>
          <div class="g-p-level l2"><span>Burjuva (Geomoreler)</span></div>
          <div class="g-p-level l3"><span>Özgür Yabancılar (Metekler)</span></div>
          <div class="g-p-level l4"><span>Köleler</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION: OLİMPİYATLAR -->
  <section class="g-section" id="olimpiyat">
    <div class="g-section-inner">
      <h2 class="g-section-title"><span>🏟️</span> Olimpiyat Oyunları</h2>
      <p class="g-section-lead">MÖ 776'dan MÖ 393'e kadar her dört yılda bir Olympia'da düzenlendi. Savaşan kentler bile barış ilan ederdi.</p>
      <div class="g-olympic-grid">
        {sports.map(s => (
          <div class="g-sport-card">
            <div class="g-sport-icon">{s.icon}</div>
            <h4>{s.sport}</h4>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION: TANRILAR -->
  <section class="g-section g-section-alt" id="tanrilar">
    <div class="g-section-inner">
      <h2 class="g-section-title"><span>🌩️</span> Olimpos Tanrıları</h2>
      <p class="g-section-lead">Her tanrının kendine özgü alanı ve sembolü vardı. Kartların üzerine gel!</p>
      <div class="g-gods-grid">
        {gods.map(god => (
          <div class="g-god-card">
            <div class="g-god-inner">
              <div class="g-god-front" style={`--gc:${god.color}`}>
                <div class="g-god-emoji">{god.emoji}</div>
                <h4 class="g-god-name">{god.name}</h4>
                <small>{god.domain}</small>
              </div>
              <div class="g-god-back" style={`--gc:${god.color}`}>
                <p>{god.desc}</p>
                <div class="g-god-symbol">🔑 {god.symbol}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION: MİMARİ -->
  <section class="g-section" id="mimari">
    <div class="g-section-inner">
      <h2 class="g-section-title"><span>🏛️</span> Yunan Mimarisi</h2>
      <p class="g-section-lead">Üç farklı sütun düzeni tüm Batı mimarisinin temelini attı. Bir tanesini seç:</p>
      <div class="g-arch-tabs">
        <button class="g-arch-btn active" data-arch="doric">Dorik</button>
        <button class="g-arch-btn" data-arch="ionic">İyonik</button>
        <button class="g-arch-btn" data-arch="corinthian">Korint</button>
      </div>
      <div class="g-arch-panels">
        <div class="g-arch-panel active" id="arch-doric">
          <div class="g-col-visual">
            <div class="g-cap doric-cap"></div>
            <div class="g-shaft"></div>
            <div class="g-base doric-base"></div>
          </div>
          <div class="g-arch-info">
