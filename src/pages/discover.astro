---
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = [
  {
    href: '/articles/black-hole',
    title: 'Kara Delikler',
    desc: 'Evrenin en gizemli yapılarına interaktif yolculuk. Canvas animasyonlar ve quiz ile.',
    tag: 'Bilim',
    tagClass: 'category-science',
    emoji: '🕳️',
    bg: 'linear-gradient(135deg, #1a0b2e, #000)',
    color: '#ff4500',
  },
  {
    href: '/articles/carthage',
    title: 'Kartaca',
    desc: 'Akdeniz\'in unutulan imparatorluğu. Flip kartlar ve kronoloji ile tarih yolculuğu.',
    tag: 'Tarih',
    tagClass: 'category-history',
    emoji: '⚔️',
    bg: 'linear-gradient(135deg, #1a2634, #2d4a6b)',
    color: '#c5a059',
  },
  {
    href: '/gallery',
    title: 'Galeri',
    desc: 'Hayvanlar, manzaralar ve sanat eserleri. Lightbox ile tam ekran görüntüleme.',
    tag: 'Kültür',
    tagClass: 'category-general',
    emoji: '🖼️',
    bg: 'linear-gradient(135deg, #1a3a2e, #2d6b4a)',
    color: '#4ade80',
  },
];
---

<BaseLayout title="Kesfet" activeNav="discover">
  <main class="main-content">
    <div class="feed-header">Kesfet</div>

    <div style="padding:20px; display:flex; flex-direction:column; gap:16px;">
      <p style="color:#536471; font-size:0.9rem;">Bilim, tarih ve kultur icerikleri.</p>

      {articles.map(a => (
        <a href={a.href} style="text-decoration:none; display:block;">
          <div style={`background:${a.bg}; border-radius:20px; padding:32px 24px; display:flex; align-items:center; gap:20px; transition:transform 0.2s, box-shadow 0.2s; cursor:pointer;`}
               onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 12px 32px rgba(0,0,0,0.3)'"
               onmouseout="this.style.transform=''; this.style.boxShadow=''">
            <span style="font-size:3rem; flex-shrink:0;">{a.emoji}</span>
            <div style="flex:1;">
              <span class={`category-badge ${a.tagClass}`}>{a.tag}</span>
              <h2 style={`font-size:1.3rem; font-weight:700; color:${a.color}; margin:4px 0 8px;`}>{a.title}</h2>
              <p style="font-size:0.85rem; color:rgba(255,255,255,0.7); line-height:1.6;">{a.desc}</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="m9 18 6-6-6-6"/></svg>
          </div>
        </a>
      ))}

      <div style="background:#f7f9f9; border-radius:20px; padding:24px; border:2px dashed #e2e8f0; text-align:center;">
        <p style="font-size:1.5rem; margin-bottom:8px;">🚀</p>
        <p style="font-weight:700; margin-bottom:4px;">Yakininda</p>
        <p style="font-size:0.85rem; color:#536471;">Roma Imparatorlugu, Muzik ve Oyunlar bolumu yapiim asamasinda.</p>
      </div>
    </div>
  </main>
</BaseLayout>
