---
import '../styles/global.css';
import { createAuthClient } from '../lib/supabase';

interface Props {
  title?: string;
  activeNav?: string;
}
const { title = 'Basements', activeNav = 'home' } = Astro.props;

const headers = new Headers();
const supabase = createAuthClient(Astro.request, headers);
const { data: { user } } = await supabase.auth.getUser();

const navItems = [
  { href: '/', label: 'Ana Sayfa', id: 'home', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>` },
  { href: '/discover', label: 'Keşfet', id: 'discover', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>` },
  { href: '/hizli-bilgiler', label: 'Hızlı Bilgiler', id: 'hizli-bilgiler', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>` },
  { href: '/articles/rome', label: 'Roma', id: 'rome', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V8l9-6 9 6v14"/><path d="M9 22V12h6v10"/></svg>` },
  { href: '/articles/greece', label: 'Yunan', id: 'greece', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M6 20V10"/><path d="M18 20V10"/><path d="M2 10h20"/><path d="M6 10V4h12v6"/><path d="M10 20v-5h4v5"/></svg>` },
  { href: '/gallery', label: 'Galeri', id: 'gallery', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/><rect width="18" height="18" x="3" y="3" rx="2"/></svg>` },
  { href: '/muzik', label: 'Müzik', id: 'muzik', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>` },
  { href: '/profile', label: 'Profil', id: 'profile', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>` },
];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Basements</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="app-shell">
      <!-- Desktop Sidebar -->
      <aside class="sidebar">
        <a href="/" class="sidebar-logo">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          <span>Basements</span>
        </a>

        <nav class="sidebar-nav">
          {navItems.map(item => (
            <a
              href={item.href}
              class={`nav-link${activeNav === item.id ? ' active' : ''}`}
            >
              <Fragment set:html={item.icon} />
              <span>{item.label}</span>
            </a>
          ))}
        </nav>

        {user ? (
          <>
            <a href="/gonderi-olustur" class="post-btn" id="open-compose">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
              <span>Gönderi Paylaş</span>
            </a>
            <form method="POST" action="/api/auth/logout" style="margin:0;">
              <button type="submit" class="nav-link" style="width:100%; background:none; border:none; cursor:pointer; color:#ef4444; text-align:left;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
                <span>Çıkış Yap</span>
              </button>
            </form>
          </>
        ) : (
          <a href="/login" class="post-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
            <span>Giriş Yap</span>
          </a>
        )}
      </aside>

      <!-- Main content slot -->
      <slot />
    </div>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <div class="mobile-nav-inner">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`mobile-nav-btn${activeNav === item.id ? ' active' : ''}`}
          >
            <Fragment set:html={item.icon} />
          </a>
        ))}
      </div>
    </nav>
  </body>
</html>
