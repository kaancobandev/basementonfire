---
import '../styles/global.css';
import { createAuthClient, supabase as db } from '../lib/supabase';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  activeNav?: string;
}
const { title = 'Basements', activeNav = 'home' } = Astro.props;

const headers = new Headers();
const supabase = createAuthClient(Astro.request, headers);
const { data: { user } } = await supabase.auth.getUser();

let unreadCount = 0;
let unreadMsgCount = 0;
let myDbId: number | null = null;
let myConvIds: number[] = [];
if (user) {
  const { data: me } = await db.from('users').select('id').eq('auth_id', user.id).single();
  if (me) {
    myDbId = me.id;
    const [notifRes, convRes] = await Promise.all([
      db.from('notifications').select('*', { count: 'exact', head: true }).eq('user_id', me.id).eq('is_read', false),
      db.from('conversations').select('id').or(`user1_id.eq.${me.id},user2_id.eq.${me.id}`),
    ]);
    unreadCount = notifRes.count ?? 0;
    myConvIds = convRes.data?.map((c: any) => c.id) ?? [];
    if (myConvIds.length) {
      const { count: msgCount } = await db
        .from('messages')
        .select('*', { count: 'exact', head: true })
        .in('conversation_id', myConvIds)
        .neq('sender_id', me.id)
        .eq('is_read', false);
      unreadMsgCount = msgCount ?? 0;
    }
  }
}

const navItems = [
  { href: '/', label: 'Ana Sayfa', id: 'home', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>` },
  { href: '/discover', label: 'İçerikler', id: 'discover', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>` },
  { href: '/akis', label: 'Akış', id: 'hizli-bilgiler', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>` },
  { href: '/muzik', label: 'Müzik', id: 'muzik', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>` },
  { href: '/messages', label: 'Mesajlar', id: 'messages', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>` },
  { href: '/profile', label: 'Profil', id: 'profile', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>` },
];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Basements</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>try{if(localStorage.getItem('theme')==='dark')document.documentElement.setAttribute('data-theme','dark')}catch{}</script>
    <ClientRouter />
  </head>
  <body>
    <div class="app-shell">
      <!-- Desktop Sidebar -->
      <aside class="sidebar">
        <a href="/" class="sidebar-logo">
          <img src="/logo_basement3.png" alt="Basements" class="sidebar-logo-img" />
          <span>Basements</span>
        </a>

        <nav class="sidebar-nav">
          {navItems.map(item => (
            <a
              href={item.href}
              class={`nav-link${activeNav === item.id ? ' active' : ''}`}
            >
              <span class="nav-icon-wrap">
                <Fragment set:html={item.icon} />
                {item.id === 'notifications' && (
                  <span class="notif-badge js-notif-badge" style={unreadCount === 0 ? 'display:none' : ''}>{unreadCount > 99 ? '99+' : unreadCount}</span>
                )}
                {item.id === 'messages' && (
                  <span class="notif-badge js-msg-badge" style={unreadMsgCount === 0 ? 'display:none' : ''}>{unreadMsgCount > 99 ? '99+' : unreadMsgCount}</span>
                )}
              </span>
              <span>{item.label}</span>
            </a>
          ))}
        </nav>

        {user ? (
          <>
            <a href="/gonderi-olustur" class="post-btn" id="open-compose">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
              <span>Gönderi Paylaş</span>
            </a>
            <a href="/settings" class={`nav-link${activeNav === 'settings' ? ' active' : ''}`}>
              <span class="nav-icon-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
              </span>
              <span>Ayarlar</span>
            </a>
            <form method="POST" action="/api/auth/logout" style="margin:0;">
              <button type="submit" class="nav-link" style="width:100%; background:none; border:none; cursor:pointer; color:#ef4444; text-align:left;">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
                <span>Çıkış Yap</span>
              </button>
            </form>
          </>
        ) : (
          <a href="/login" class="post-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
            <span>Giriş Yap</span>
          </a>
        )}
      </aside>

      <!-- Main content slot -->
      <slot />
    </div>

    <!-- Floating notification bell (only on home page) -->
    {activeNav === 'home' && <a
      href="/notifications"
      class="notif-float"
      aria-label="Bildirimler"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <span class="notif-float-badge js-notif-badge" style={unreadCount === 0 ? 'display:none' : ''}>{unreadCount > 99 ? '99+' : unreadCount}</span>
    </a>}

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <div class="mobile-nav-inner">
        <a href="/" class={`mobile-nav-btn${activeNav === 'home' ? ' active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </a>
        <a href="/discover" class={`mobile-nav-btn${activeNav === 'discover' ? ' active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </a>
        <a href="/akis" class={`mobile-nav-btn${activeNav === 'hizli-bilgiler' ? ' active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </a>
        <a href="/muzik" class={`mobile-nav-btn${activeNav === 'muzik' ? ' active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </a>
        {user && (
          <button class="mobile-create-btn" id="mobile-create-btn" type="button" aria-label="Paylaş">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
          </button>
        )}
        <a href="/messages" class={`mobile-nav-btn${activeNav === 'messages' ? ' active' : ''}`}>
          <span class="nav-icon-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {unreadMsgCount > 0 && (
              <span class="notif-badge js-msg-badge">{unreadMsgCount > 99 ? '99+' : unreadMsgCount}</span>
            )}
          </span>
        </a>
        <a href="/profile" class={`mobile-nav-btn${activeNav === 'profile' ? ' active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
        </a>
      </div>
    </nav>

    <!-- Create type bottom sheet -->
    <div id="mc-sheet-bg" class="mc-sheet-bg">
      <div class="mc-sheet">
        <div class="mc-sheet-handle"></div>
        <p class="mc-sheet-title">Ne paylaşmak istiyorsun?</p>
        <div class="mc-sheet-options">
          <button class="mc-option" data-type="photo" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            Fotoğraf
          </button>
          <button class="mc-option" data-type="reels" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect width="15" height="14" x="1" y="5" rx="2" ry="2"/></svg>
            Reels
          </button>
          <button class="mc-option" data-type="story" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            Hikaye
          </button>
        </div>
        <button class="mc-cancel" id="mc-cancel" type="button">İptal</button>
      </div>
    </div>
    <!-- Realtime meta -->
    <div id="rt-meta" data-my-id={myDbId ?? ''} data-conv-ids={JSON.stringify(myConvIds)} hidden></div>

    <!-- Toast container -->
    <div id="toast-root" class="toast-root" aria-live="polite"></div>

    <!-- Page loading overlay -->
    <div id="page-loading-overlay" aria-hidden="true">
      <img src="https://media2.giphy.com/media/BSx6mzbW1ew7K/giphy.gif" alt="" />
    </div>
  </body>
</html>

<style>
.toast-root {
  position: fixed;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 9999;
  pointer-events: none;
}

.toast {
  background: #1e1a14;
  border: 1px solid rgba(212,165,100,0.25);
  color: #e8e0d8;
  font-size: 0.85rem;
  padding: 10px 18px;
  border-radius: 9999px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  pointer-events: auto;
  white-space: nowrap;
  animation: toast-in 0.25s ease;
  display: flex;
  align-items: center;
  gap: 8px;
}

.toast.toast-notif { border-color: rgba(212,165,100,0.4); }
.toast.toast-exit  { animation: toast-out 0.3s ease forwards; }

@keyframes toast-in  { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
@keyframes toast-out { to   { opacity:0; transform:translateY(12px); } }

@media (min-width: 768px) {
  .toast-root { bottom: 32px; }
}

#page-loading-overlay {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: none;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.72);
}

#page-loading-overlay img {
  width: 35vw;
  height: 35vh;
  object-fit: cover;
  opacity: 0.8;
}

/* Floating notification bell */
.notif-float {
  position: fixed;
  /* Right edge of main-content = viewport - right-panel (350px) - 16px margin */
  right: calc(350px + 16px);
  top: 14px;
  z-index: 50;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  box-shadow: 0 2px 8px rgba(0,0,0,0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: background 0.15s, color 0.15s, box-shadow 0.15s;
}
.notif-float:hover,
.notif-float--active {
  background: #f0f2f5;
  color: var(--color-text);
  box-shadow: 0 4px 14px rgba(0,0,0,0.13);
}
.notif-float-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 17px;
  height: 17px;
  padding: 0 4px;
  border-radius: 9px;
  background: #ef4444;
  color: #fff;
  font-size: 0.65rem;
  font-weight: 700;
  line-height: 17px;
  text-align: center;
  pointer-events: none;
}

/* Tablet: right panel hidden, bell at right edge */
@media (max-width: 1200px) {
  .notif-float { right: 16px; }
}

/* Mobile: smaller, account for mobile nav height */
@media (max-width: 767px) {
  .notif-float {
    right: 12px;
    top: 10px;
    width: 36px;
    height: 36px;
  }
}

/* Mobile create button */
.mobile-create-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: white;
  border: none;
  border-radius: 10px;
  width: 44px;
  height: 32px;
  cursor: pointer;
  padding: 0;
  transition: background 0.15s, transform 0.1s;
  flex-shrink: 0;
}
.mobile-create-btn:hover,
.mobile-create-btn:active {
  background: var(--color-primary-hover);
  transform: scale(1.05);
}

/* Create type bottom sheet */
.mc-sheet-bg {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: flex-end;
}
.mc-sheet-bg.mc-open { display: flex; }
.mc-sheet {
  width: 100%;
  background: var(--color-surface);
  border-radius: 20px 20px 0 0;
  padding: 12px 20px 36px;
  animation: mc-sheet-up 0.25s ease;
}
@keyframes mc-sheet-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.mc-sheet-handle {
  width: 40px;
  height: 4px;
  background: var(--color-border);
  border-radius: 2px;
  margin: 0 auto 18px;
}
.mc-sheet-title {
  font-size: 1rem;
  font-weight: 700;
  text-align: center;
  margin: 0 0 18px;
  color: var(--color-text);
}
.mc-sheet-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 14px;
}
.mc-option {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  border: 1px solid var(--color-border);
  border-radius: 14px;
  background: none;
  cursor: pointer;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text);
  font-family: inherit;
  text-align: left;
  transition: background 0.12s, border-color 0.12s;
}
.mc-option:hover { background: #f0f2f5; border-color: var(--color-primary); }
.mc-cancel {
  width: 100%;
  padding: 13px;
  border: none;
  background: none;
  color: var(--color-text-muted);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  font-family: inherit;
  border-radius: 10px;
  transition: background 0.12s;
}
.mc-cancel:hover { background: #f0f2f5; }
</style>

<script>
import { supa } from '../lib/supabase-browser';

// ── Toast helper ─────────────────────────────────────────────────────────────
function showToast(msg: string, cls = '') {
  const toastRoot = document.getElementById('toast-root');
  if (!toastRoot) return;
  const t = document.createElement('div');
  t.className = `toast ${cls}`.trim();
  t.innerHTML = msg;
  toastRoot.appendChild(t);
  setTimeout(() => {
    t.classList.add('toast-exit');
    t.addEventListener('animationend', () => t.remove(), { once: true });
  }, 4000);
}

function incrementBadges(selector: string) {
  document.querySelectorAll<HTMLElement>(selector).forEach(badge => {
    const cur = parseInt(badge.textContent ?? '0') || 0;
    const next = cur + 1;
    badge.textContent = next > 99 ? '99+' : String(next);
    badge.style.display = '';
  });
}

// ── Realtime — kanallar window üzerinde saklanır, swap'ta yeniden kurulmaz ───
const w = window as any;

function setupRealtime() {
  const rtMeta  = document.getElementById('rt-meta') as HTMLElement | null;
  const myId    = rtMeta?.dataset.myId ? parseInt(rtMeta.dataset.myId) : null;
  const convIds = rtMeta?.dataset.convIds ? (JSON.parse(rtMeta.dataset.convIds) as number[]) : [];

  if (!myId) return;

  // Daha önce aynı kullanıcı için kurulduysa atlat
  if (w.__rtUserId === myId) return;
  w.__rtUserId = myId;

  // Eski kanalları temizle
  if (w.__rtNotifCh) { try { supa.removeChannel(w.__rtNotifCh); } catch {} }
  if (w.__rtMsgCh)   { try { supa.removeChannel(w.__rtMsgCh);   } catch {} }

  w.__rtNotifCh = supa
    .channel(`notif-user-${myId}`)
    .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'notifications', filter: `user_id=eq.${myId}` },
      (payload: any) => {
        const type: string = payload.new?.type ?? '';
        const icons: Record<string, string>  = { follow: '👤', comment: '💬', like: '❤️', mention: '@' };
        const labels: Record<string, string> = {
          follow:  'Biri seni takip etmeye başladı',
          comment: 'Gönderine yeni bir yorum yapıldı',
          like:    'Gönderini biri beğendi',
          mention: 'Biri seni bir gönderide etiketledi',
        };
        showToast(`${icons[type] ?? '🔔'} ${labels[type] ?? 'Yeni bildirim'}`, 'toast-notif');
        incrementBadges('.js-notif-badge');
      }
    ).subscribe();

  if (convIds.length) {
    w.__rtConvIds = convIds;
    w.__rtMsgCh = supa
      .channel(`msg-user-${myId}`)
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages' },
        (payload: any) => {
          const msg = payload.new;
          if (msg.sender_id === myId) return;
          const activeConvIds: number[] = w.__rtConvIds ?? [];
          if (!activeConvIds.includes(msg.conversation_id)) return;
          const url = new URL(window.location.href);
          const onMessages = url.pathname === '/messages';
          const openConv = onMessages ? parseInt(url.searchParams.get('c') ?? '0') : 0;
          if (onMessages && openConv === msg.conversation_id) return;
          showToast('💬 Yeni mesaj aldın', 'toast-notif');
          incrementBadges('.js-msg-badge');
        }
      ).subscribe();
  }
}

// Her View Transitions swap'ından sonra conv listesi güncellenebilir
function refreshConvIds() {
  const rtMeta  = document.getElementById('rt-meta') as HTMLElement | null;
  const convIds = rtMeta?.dataset.convIds ? (JSON.parse(rtMeta.dataset.convIds) as number[]) : [];
  if (convIds.length) w.__rtConvIds = convIds;
}

setupRealtime();
document.addEventListener('astro:after-swap', () => {
  setupRealtime();
  refreshConvIds();
});

// ── Page loading overlay ──────────────────────────────────────────────────────
const LOADING_GIFS = [
  'https://media2.giphy.com/media/BSx6mzbW1ew7K/giphy.gif',
  'https://media2.giphy.com/media/uEb7Wps1mWe5ffEkQv/giphy.gif',
];

function getOverlay() {
  return document.getElementById('page-loading-overlay') as HTMLElement | null;
}

function hideOverlay() {
  if (w.__loadingTimer) { clearTimeout(w.__loadingTimer); w.__loadingTimer = null; }
  const ov = getOverlay();
  if (ov) ov.style.display = 'none';
}

// View Transitions navigasyonu başlayınca 1 saniyelik timer başlat
document.addEventListener('astro:before-preparation', () => {
  if (w.__loadingTimer) clearTimeout(w.__loadingTimer);
  w.__loadingTimer = setTimeout(() => {
    const ov = getOverlay();
    if (!ov) return;
    const img = ov.querySelector('img') as HTMLImageElement | null;
    if (img) img.src = LOADING_GIFS[Math.floor(Math.random() * LOADING_GIFS.length)];
    ov.style.display = 'flex';
  }, 1000);
});

// Sayfa swap tamamlandığında overlay'i gizle
document.addEventListener('astro:after-swap', hideOverlay);

// Tam sayfa yüklemesi (VT dışı, örn. dış linkler) için
window.addEventListener('pageshow', hideOverlay);

// ── Mobile create sheet ───────────────────────────────────────────────────────
function initMobileCreate() {
  const createBtn = document.getElementById('mobile-create-btn');
  const sheetBg   = document.getElementById('mc-sheet-bg');
  const cancelBtn = document.getElementById('mc-cancel');
  if (!createBtn || !sheetBg) return;

  function openSheet()  { sheetBg.classList.add('mc-open'); }
  function closeSheet() { sheetBg.classList.remove('mc-open'); }

  createBtn.addEventListener('click', openSheet);
  cancelBtn?.addEventListener('click', closeSheet);
  sheetBg.addEventListener('click', (e) => {
    if (e.target === sheetBg) closeSheet();
  });

  sheetBg.querySelectorAll<HTMLButtonElement>('.mc-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = (btn as HTMLButtonElement).dataset.type;
      closeSheet();
      if (type === 'photo' || type === 'reels') {
        window.location.href = '/akis?create=1';
      } else if (type === 'story') {
        window.location.href = '/?story=1';
      }
    });
  });
}

initMobileCreate();
document.addEventListener('astro:after-swap', initMobileCreate);
</script>
